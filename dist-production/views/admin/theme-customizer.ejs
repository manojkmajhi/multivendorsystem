<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Theme Customizer - Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; display: flex; height: 100vh; overflow: hidden; }
    
    .customizer-panel { width: 420px; background: #fff; border-right: 1px solid #ddd; overflow-y: auto; display: flex; flex-direction: column; }
    .panel-header { padding: 20px; border-bottom: 1px solid #eee; background: #f8f9fa; }
    .panel-header h1 { font-size: 20px; margin-bottom: 8px; }
    .panel-header p { font-size: 13px; color: #666; }
    
    .panel-body { flex: 1; padding: 20px; }
    .control-group { margin-bottom: 30px; }
    .control-group h3 { font-size: 14px; font-weight: 600; margin-bottom: 15px; color: #333; text-transform: uppercase; letter-spacing: 0.5px; }
    
    .control-item { margin-bottom: 18px; }
    .control-item label { display: block; font-size: 13px; font-weight: 500; margin-bottom: 6px; color: #555; }
    .control-item input[type="color"] { width: 100%; height: 45px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; }
    .control-item input[type="text"], .control-item input[type="number"], .control-item select { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px; font-family: monospace; }
    .control-item small { display: block; margin-top: 4px; font-size: 12px; color: #888; }
    
    .panel-footer { padding: 20px; border-top: 1px solid #eee; background: #f8f9fa; }
    .btn { padding: 12px 24px; border: none; border-radius: 4px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn-primary { background: #007bff; color: white; width: 100%; margin-bottom: 10px; }
    .btn-primary:hover { background: #0056b3; }
    .btn-secondary { background: #6c757d; color: white; width: 100%; }
    .btn-secondary:hover { background: #545b62; }
    
    .preview-frame { flex: 1; background: #f0f0f0; position: relative; }
    .preview-frame iframe { width: 100%; height: 100%; border: none; }
    .preview-loading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 14px; color: #666; }
    
    .preset-buttons { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 15px; }
    .preset-btn { padding: 8px 16px; border: none; border-radius: 4px; color: white; font-size: 12px; font-weight: 600; cursor: pointer; }
    
    .success-msg { background: #d4edda; color: #155724; padding: 12px; border-radius: 4px; margin-bottom: 15px; font-size: 13px; display: none; }
    .success-msg.show { display: block; }
  </style>
</head>
<body>
  <div class="customizer-panel">
    <div class="panel-header">
      <h1>🎨 Theme Customizer</h1>
      <p>Customize your website colors in real-time</p>
    </div>
    
    <div class="panel-body">
      <div id="success-message" class="success-msg"></div>
      
      <div class="control-group">
        <h3>🎯 Primary Colors</h3>
        
        <div class="control-item">
          <label>Button Background</label>
          <input type="color" id="btn_bg" value="<%= colors.btn_bg || '#000000' %>" />
          <input type="text" id="btn_bg_text" value="<%= colors.btn_bg || '#000000' %>" />
          <small>Background color for all buttons</small>
        </div>
        
        <div class="control-item">
          <label>Button Text</label>
          <input type="color" id="btn_text" value="<%= colors.btn_text || '#ffffff' %>" />
          <input type="text" id="btn_text_text" value="<%= colors.btn_text || '#ffffff' %>" />
          <small>Text color for buttons</small>
        </div>
        
        <div class="control-item">
          <label>Button Hover</label>
          <input type="color" id="btn_hover" value="<%= colors.btn_hover || '#333333' %>" />
          <input type="text" id="btn_hover_text" value="<%= colors.btn_hover || '#333333' %>" />
          <small>Button color on hover</small>
        </div>
      </div>
      
      <div class="control-group">
        <h3>🔗 Links</h3>
        
        <div class="control-item">
          <label>Link Color</label>
          <input type="color" id="link_color" value="<%= colors.link_color || '#007bff' %>" />
          <input type="text" id="link_color_text" value="<%= colors.link_color || '#007bff' %>" />
          <small>Default link color</small>
        </div>
        
        <div class="control-item">
          <label>Link Hover</label>
          <input type="color" id="link_hover" value="<%= colors.link_hover || '#0056b3' %>" />
          <input type="text" id="link_hover_text" value="<%= colors.link_hover || '#0056b3' %>" />
          <small>Link color on hover</small>
        </div>
      </div>
      
      <div class="control-group">
        <h3>🏠 Navbar</h3>
        
        <div class="control-item">
          <label>Navbar Background</label>
          <input type="color" id="navbar_bg" value="<%= colors.navbar_bg || '#ffffff' %>" />
          <input type="text" id="navbar_bg_text" value="<%= colors.navbar_bg || '#ffffff' %>" />
        </div>
        
        <div class="control-item">
          <label>Navbar Text</label>
          <input type="color" id="navbar_text" value="<%= colors.navbar_text || '#000000' %>" />
          <input type="text" id="navbar_text_text" value="<%= colors.navbar_text || '#000000' %>" />
        </div>
      </div>
      
      <div class="control-group">
        <h3>🛍️ Product Cards</h3>
        
        <div class="control-item">
          <label>Card Background</label>
          <input type="color" id="card_bg" value="<%= colors.card_bg || '#f8f8f8' %>" />
          <input type="text" id="card_bg_text" value="<%= colors.card_bg || '#f8f8f8' %>" />
        </div>
        
        <div class="control-item">
          <label>Card Border Radius</label>
          <input type="number" id="card_radius" value="<%= colors.card_radius || '2' %>" min="0" max="20" />
          <small>Border roundness (0-20px)</small>
        </div>
      </div>
      
      <div class="control-group">
        <h3>📝 Footer</h3>
        
        <div class="control-item">
          <label>Footer Background</label>
          <input type="color" id="footer_bg" value="<%= colors.footer_bg || '#343a40' %>" />
          <input type="text" id="footer_bg_text" value="<%= colors.footer_bg || '#343a40' %>" />
        </div>
        
        <div class="control-item">
          <label>Footer Text</label>
          <input type="color" id="footer_text" value="<%= colors.footer_text || '#ffffff' %>" />
          <input type="text" id="footer_text_text" value="<%= colors.footer_text || '#ffffff' %>" />
        </div>
      </div>
      
      <div class="control-group">
        <h3>✅ Status Colors</h3>
        
        <div class="control-item">
          <label>Success</label>
          <input type="color" id="success_color" value="<%= colors.success_color || '#28a745' %>" />
          <input type="text" id="success_color_text" value="<%= colors.success_color || '#28a745' %>" />
        </div>
        
        <div class="control-item">
          <label>Danger/Error</label>
          <input type="color" id="danger_color" value="<%= colors.danger_color || '#dc3545' %>" />
          <input type="text" id="danger_color_text" value="<%= colors.danger_color || '#dc3545' %>" />
        </div>
      </div>
      
      <div class="control-group">
        <h3>🎨 Quick Presets</h3>
        <div class="preset-buttons">
          <button class="preset-btn" style="background: #000" onclick="applyPreset('dark')">Dark</button>
          <button class="preset-btn" style="background: #007bff" onclick="applyPreset('blue')">Blue</button>
          <button class="preset-btn" style="background: #dc3545" onclick="applyPreset('red')">Red</button>
          <button class="preset-btn" style="background: #28a745" onclick="applyPreset('green')">Green</button>
          <button class="preset-btn" style="background: #6f42c1" onclick="applyPreset('purple')">Purple</button>
          <button class="preset-btn" style="background: #fd7e14" onclick="applyPreset('orange')">Orange</button>
        </div>
        <button class="preset-btn" style="background: #6c757d; width: 100%; margin-top: 10px;" onclick="resetToDefaults()">↺ Reset to Default Colors</button>
      </div>
    </div>
    
    <div class="panel-footer">
      <button class="btn btn-primary" onclick="saveTheme()">💾 Publish Changes</button>
      <button class="btn btn-secondary" onclick="window.location='/admin/'">← Back to Admin</button>
    </div>
  </div>
  
  <div class="preview-frame">
    <div class="preview-loading">Loading preview...</div>
    <iframe id="preview" src="/?preview=1"></iframe>
  </div>
  
  <script>
    // Number inputs
    document.getElementById('card_radius').addEventListener('input', updatePreview);
    
    const ORIGINAL_DEFAULTS = { btn_bg: '#000000', btn_text: '#ffffff', btn_hover: '#333333', link_color: '#007bff', link_hover: '#0056b3', navbar_bg: '#ffffff', navbar_text: '#000000', card_bg: '#f8f8f8', card_radius: '2', footer_bg: '#343a40', footer_text: '#ffffff', success_color: '#28a745', danger_color: '#dc3545' };
    
    const presets = {
      dark: { btn_bg: '#000000', btn_text: '#ffffff', btn_hover: '#333333', link_color: '#007bff', link_hover: '#0056b3', navbar_bg: '#1a1a1a', navbar_text: '#ffffff', card_bg: '#2a2a2a', card_radius: '4', footer_bg: '#000000', footer_text: '#ffffff', success_color: '#28a745', danger_color: '#dc3545' },
      blue: { btn_bg: '#007bff', btn_text: '#ffffff', btn_hover: '#0056b3', link_color: '#007bff', link_hover: '#0056b3', success_color: '#28a745', danger_color: '#dc3545' },
      red: { btn_bg: '#dc3545', btn_text: '#ffffff', btn_hover: '#c82333', link_color: '#dc3545', link_hover: '#bd2130', success_color: '#28a745', danger_color: '#dc3545' },
      green: { btn_bg: '#28a745', btn_text: '#ffffff', btn_hover: '#218838', link_color: '#28a745', link_hover: '#1e7e34', success_color: '#28a745', danger_color: '#dc3545' },
      purple: { btn_bg: '#6f42c1', btn_text: '#ffffff', btn_hover: '#5a32a3', link_color: '#6f42c1', link_hover: '#59339d', success_color: '#28a745', danger_color: '#dc3545' },
      orange: { btn_bg: '#fd7e14', btn_text: '#ffffff', btn_hover: '#e8590c', link_color: '#fd7e14', link_hover: '#dc6502', success_color: '#28a745', danger_color: '#dc3545' }
    };
    
    function applyPreset(name) {
      const colors = presets[name];
      Object.keys(colors).forEach(key => {
        document.getElementById(key).value = colors[key];
        document.getElementById(key + '_text').value = colors[key];
      });
      updatePreview();
    }
    
    function resetToDefaults() {
      if (confirm('Reset all colors to original defaults?')) {
        Object.keys(ORIGINAL_DEFAULTS).forEach(key => {
          const elem = document.getElementById(key);
          const textElem = document.getElementById(key + '_text');
          if (elem) elem.value = ORIGINAL_DEFAULTS[key];
          if (textElem) textElem.value = ORIGINAL_DEFAULTS[key];
        });
        updatePreview();
      }
    }
    
    function getColors() {
      return {
        btn_bg: document.getElementById('btn_bg').value,
        btn_text: document.getElementById('btn_text').value,
        btn_hover: document.getElementById('btn_hover').value,
        link_color: document.getElementById('link_color').value,
        link_hover: document.getElementById('link_hover').value,
        navbar_bg: document.getElementById('navbar_bg').value,
        navbar_text: document.getElementById('navbar_text').value,
        card_bg: document.getElementById('card_bg').value,
        card_radius: document.getElementById('card_radius').value,
        footer_bg: document.getElementById('footer_bg').value,
        footer_text: document.getElementById('footer_text').value,
        success_color: document.getElementById('success_color').value,
        danger_color: document.getElementById('danger_color').value
      };
    }
    
    function updatePreview() {
      const colors = getColors();
      const iframe = document.getElementById('preview');
      if (iframe.contentWindow) {
        iframe.contentWindow.postMessage({ type: 'updateTheme', colors }, '*');
      }
    }
    
    async function saveTheme() {
      const colors = getColors();
      try {
        const response = await fetch('/admin/theme-customizer/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ colors })
        });
        const result = await response.json();
        if (result.success) {
          const msg = document.getElementById('success-message');
          msg.textContent = '✓ Theme saved successfully! Changes are now live.';
          msg.classList.add('show');
          setTimeout(() => msg.classList.remove('show'), 3000);
        }
      } catch (e) {
        alert('Failed to save theme: ' + e.message);
      }
    }
    
    // Sync color picker with text input (both ways)
    ['btn_bg', 'btn_text', 'btn_hover', 'link_color', 'link_hover', 'navbar_bg', 'navbar_text', 'card_bg', 'footer_bg', 'footer_text', 'success_color', 'danger_color'].forEach(id => {
      const picker = document.getElementById(id);
      const text = document.getElementById(id + '_text');
      
      picker.addEventListener('input', function() {
        text.value = this.value;
        updatePreview();
      });
      
      text.addEventListener('input', function() {
        if (/^#[0-9A-Fa-f]{6}$/.test(this.value)) {
          picker.value = this.value;
          updatePreview();
        }
      });
    });
    
    // Wait for iframe to load before sending updates
    const iframe = document.getElementById('preview');
    iframe.addEventListener('load', function() {
      setTimeout(updatePreview, 500);
    });
  </script>
</body>
</html>
