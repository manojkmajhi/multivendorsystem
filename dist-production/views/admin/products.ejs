<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Products - Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/staticfiles/admin-style.css?v=3.0" />
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="admin-navbar">
    <div class="admin-navbar-container">
      <a href="/admin/" class="admin-brand">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" />
        <% } %>
      </a>
      
      <!-- Desktop Navigation Links -->
      <div class="desktop-nav-links">
        <a href="/admin/" class="nav-link">
          <span class="nav-icon">📊</span>
          <span>Dashboard</span>
        </a>
        <a href="/admin/orders" class="nav-link">
          <span class="nav-icon">🛒</span>
          <span>Orders</span>
        </a>
        <a href="/admin/products" class="nav-link active">
          <span class="nav-icon">📦</span>
          <span>Products</span>
        </a>
        <a href="/admin/categories" class="nav-link">
          <span class="nav-icon">📁</span>
          <span>Categories</span>
        </a>
        <a href="/admin/hero-images" class="nav-link">
          <span class="nav-icon">🖼️</span>
          <span>Hero Images</span>
        </a>
        <a href="/admin/settings" class="nav-link">
          <span class="nav-icon">⚙️</span>
          <span>Settings</span>
        </a>
        <form method="POST" action="/admin/logout" style="display: inline;">
          <button type="submit" class="nav-link nav-logout-btn">
            <span class="nav-icon">🚪</span>
            <span>Logout</span>
          </button>
        </form>
      </div>
      
      <!-- Mobile Hamburger Menu -->
      <button class="mobile-menu-toggle" onclick="toggleSidebar()" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Sidebar -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
    <div class="sidebar-content">
      <div class="sidebar-header">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" class="sidebar-logo" />
        <% } %>
        <h3 class="sidebar-title"><%= (siteSetting && siteSetting.name) || 'Admin Panel' %></h3>
        <button class="sidebar-close" onclick="toggleSidebar()" aria-label="Close menu">&times;</button>
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/" class="sidebar-link">
          <span class="sidebar-icon">📊</span>
          <span>Dashboard</span>
        </a>
        <a href="/admin/orders" class="sidebar-link">
          <span class="sidebar-icon">🛒</span>
          <span>Orders</span>
        </a>
        <a href="/admin/products" class="sidebar-link active">
          <span class="sidebar-icon">📦</span>
          <span>Products</span>
        </a>
        <a href="/admin/categories" class="sidebar-link">
          <span class="sidebar-icon">📁</span>
          <span>Categories</span>
        </a>
        <a href="/admin/hero-images" class="sidebar-link">
          <span class="sidebar-icon">🖼️</span>
          <span>Hero Images</span>
        </a>
        <a href="/admin/settings" class="sidebar-link">
          <span class="sidebar-icon">⚙️</span>
          <span>Settings</span>
        </a>
      </nav>
      
      <div class="sidebar-footer">
        <form method="POST" action="/admin/logout">
          <button type="submit" class="sidebar-logout-btn">
            <span class="sidebar-icon">🚪</span>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="admin-container">
    <div class="page-header">
      <h1 class="page-title">Products</h1>
      <a class="btn btn-primary" href="/admin/products/new">+ New Product</a>
    </div>

    <% if(msg){ %>
      <div class="alert alert-success"><%= msg %></div>
    <% } %>

    <% if(items && items.length > 0) { %>
      <!-- Search Box -->
      <div class="search-container">
        <div class="search-box">
          <span class="search-icon">🔍</span>
          <input 
            type="search" 
            id="productSearch" 
            class="search-input" 
            placeholder="Search products by name, category, or type..."
            autocomplete="off"
          />
          <span class="search-count" id="searchCount"></span>
        </div>
      </div>

      <div class="table-container">
        <div class="table-responsive">
          <table id="productsTable">
            <thead>
              <tr>
                <th style="width:40px;">#</th>
                <th>Name & Short Description</th>
                <th>Category</th>
                <th>Type</th>
                <th>Price</th>
                <th>Status</th>
                <th style="width:280px;">Actions</th>
              </tr>
            </thead>
            <tbody>
            <% items.forEach((p,idx) => { %>
              <tr class="product-row" data-search="<%= (p.name + ' ' + (p.short_description||'') + ' ' + p.category + ' ' + p.type).toLowerCase() %>">
                <td><%= idx+1 %></td>
                <td>
                  <strong><%= p.name %></strong>
                  <% if(p.short_description){ %>
                    <div style="font-size:11px; color:#666; margin-top:2px; max-width:260px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                      <%= p.short_description %>
                    </div>
                  <% } %>
                </td>
                <td><%= p.category %></td>
                <td><span class="badge badge-primary"><%= p.type %></span></td>
                <td><strong>Rs. <%= p.price %></strong></td>
                <td>
                  <% if(typeof p.active === 'boolean'){ %>
                    <span class="badge <%= p.active? 'badge-success':'badge-secondary' %>">
                      <%= p.active? 'Active':'Inactive' %>
                    </span>
                  <% } %>
                </td>
                <td>
                  <div class="table-actions">
                    <a href="/admin/products/<%= p.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form method="POST" action="/admin/products/<%= p.id %>/toggle-active">
                      <button class="btn btn-sm btn-outline-warning">
                        <%= p.active? 'Disable':'Enable' %>
                      </button>
                    </form>
                    <form method="POST" action="/admin/products/<%= p.id %>/delete" onsubmit="return confirm('Delete this product?');">
                      <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
        
        <!-- No Results Message -->
        <div id="noResults" class="empty-state" style="display: none; padding: 3rem;">
          <div class="empty-state-icon">🔍</div>
          <h3 class="empty-state-title">No products found</h3>
          <p class="empty-state-text">Try adjusting your search terms.</p>
        </div>
      </div>
    <% } else { %>
      <div class="card">
        <div class="card-body">
          <div class="empty-state">
            <div class="empty-state-icon">📦</div>
            <h3 class="empty-state-title">No Products Yet</h3>
            <p class="empty-state-text">Get started by adding your first product.</p>
            <a href="/admin/products/new" class="btn btn-primary mt-3">+ Add Your First Product</a>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Footer -->
  <footer class="admin-footer">
    &copy; <%= new Date().getFullYear() %> <%= (siteSetting && siteSetting.name) || 'Admin' %>. All rights reserved.
  </footer>

  <script src="/staticfiles/admin-enhancements.js?v=3.0"></script>
</body>
</html>
