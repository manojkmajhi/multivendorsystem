<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= item? 'Edit':'New' %> Product - Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/staticfiles/admin-style.css?v=3.0" />
  <style>
    .variant-toggle { background: #f8f9fa; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; }
    .variant-builder { background: #fff; border: 2px dashed #dee2e6; padding: 1.5rem; border-radius: 8px; margin-top: 1rem; }
    .attribute-selector { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .attribute-chip { padding: 0.5rem 1rem; background: #e7f3ff; border: 1px solid #2b90d9; border-radius: 20px; cursor: pointer; }
    .attribute-chip.selected { background: #2b90d9; color: white; }
    .variant-grid { display: grid; gap: 1rem; margin-top: 1rem; }
    .variant-card { border: 1px solid #dee2e6; padding: 1rem; border-radius: 8px; background: #f8f9fa; }
    .variant-card input { margin-bottom: 0.5rem; }
  </style>
</head>
<body>
  <nav class="admin-navbar">
    <div class="admin-navbar-container">
      <a href="/admin/" class="admin-brand">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" />
        <% } %>
      </a>
      <div class="desktop-nav-links">
        <a href="/admin/" class="nav-link"><span class="nav-icon">📊</span><span>Dashboard</span></a>
        <a href="/admin/products" class="nav-link active"><span class="nav-icon">📦</span><span>Products</span></a>
        <a href="/admin/categories" class="nav-link"><span class="nav-icon">📁</span><span>Categories</span></a>
        <a href="/admin/hero-images" class="nav-link"><span class="nav-icon">🖼️</span><span>Hero Images</span></a>
        <a href="/admin/settings" class="nav-link"><span class="nav-icon">⚙️</span><span>Settings</span></a>
        <form method="POST" action="/admin/logout" style="display: inline;">
          <button type="submit" class="nav-link nav-logout-btn"><span class="nav-icon">🚪</span><span>Logout</span></button>
        </form>
      </div>
      <button class="mobile-menu-toggle" onclick="toggleSidebar()" aria-label="Toggle menu"><span></span><span></span><span></span></button>
    </div>
  </nav>

  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
    <div class="sidebar-content">
      <div class="sidebar-header">
        <% if(siteSetting && siteSetting.logo_url){ %><img src="<%= siteSetting.logo_url %>" alt="Logo" class="sidebar-logo" /><% } %>
        <h3 class="sidebar-title"><%= (siteSetting && siteSetting.name) || 'Admin Panel' %></h3>
        <button class="sidebar-close" onclick="toggleSidebar()" aria-label="Close menu">&times;</button>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin/" class="sidebar-link"><span class="sidebar-icon">📊</span><span>Dashboard</span></a>
        <a href="/admin/products" class="sidebar-link active"><span class="sidebar-icon">📦</span><span>Products</span></a>
        <a href="/admin/categories" class="sidebar-link"><span class="sidebar-icon">📁</span><span>Categories</span></a>
        <a href="/admin/hero-images" class="sidebar-link"><span class="sidebar-icon">🖼️</span><span>Hero Images</span></a>
        <a href="/admin/settings" class="sidebar-link"><span class="sidebar-icon">⚙️</span><span>Settings</span></a>
      </nav>
      <div class="sidebar-footer">
        <form method="POST" action="/admin/logout"><button type="submit" class="sidebar-logout-btn"><span class="sidebar-icon">🚪</span><span>Logout</span></button></form>
      </div>
    </div>
  </div>

  <div class="admin-container">
    <div class="page-header">
      <h1 class="page-title"><%= item? 'Edit':'New' %> Product</h1>
      <a href="/admin/products" class="btn btn-outline-primary">← Back to Products</a>
    </div>

    <div style="max-width: 900px;">
      <div class="card">
        <div class="card-header"><h2 class="card-title">Product Information</h2></div>
        <div class="card-body">
          <form method="POST" enctype="multipart/form-data" id="productForm">
            
            <!-- Basic Product Info -->
            <div class="form-group">
              <label class="form-label">Product Name *</label>
              <input name="name" class="form-control" value="<%= item? item.name:'' %>" required placeholder="e.g., Premium T-Shirt" />
            </div>

            <div class="grid-2-cols">
              <div class="form-group">
                <label class="form-label">Base Price (Rs.) *</label>
                <input name="price" type="number" step="0.01" class="form-control" value="<%= item? item.price:0 %>" required />
                <small class="form-text">Starting price (variants can adjust)</small>
              </div>
              <div class="form-group">
                <label class="form-label">Category *</label>
                <select name="category" class="form-control" required>
                  <option value="">-- Select --</option>
                  <% categories.forEach(c => { %>
                    <option value="<%= c.name || c %>" <%= item && item.category === (c.name||c) ? 'selected':'' %>><%= c.name || c %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Short Description</label>
              <textarea name="short_description" class="form-control" rows="2"><%= item && item.short_description ? item.short_description : '' %></textarea>
            </div>

            <div class="form-group">
              <label class="form-label">Long Description</label>
              <textarea name="long_description" class="form-control" rows="4"><%= item && item.long_description ? item.long_description : '' %></textarea>
            </div>

            <div class="form-group">
              <label class="form-label">Product Image</label>
              <input type="file" name="imageFile" class="form-control" accept="image/*" />
              <input name="image" class="form-control" value="<%= item? item.image:'' %>" placeholder="Or enter URL" style="margin-top: 0.5rem;" />
            </div>

            <hr style="margin: 2rem 0;">

            <!-- Variant Toggle -->
            <div class="variant-toggle">
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                <input type="checkbox" id="hasVariants" name="has_variants" <%= item && item.has_variants ? 'checked' : '' %> onchange="toggleVariantBuilder()" />
                <strong>This product has variants (Size, Color, etc.)</strong>
              </label>
              <small style="color: #666; display: block; margin-top: 0.5rem;">Enable if product comes in different sizes, colors, or other variations</small>
            </div>

            <!-- Simple Product Fields (shown when no variants) -->
            <div id="simpleFields" style="<%= item && item.has_variants ? 'display:none;' : '' %>">
              <div class="grid-2-cols">
                <div class="form-group">
                  <label class="form-label">SKU</label>
                  <input name="base_sku" class="form-control" value="<%= item? item.base_sku:'' %>" placeholder="PROD-001" />
                </div>
                <div class="form-group">
                  <label class="form-label">Stock</label>
                  <input name="stock" type="number" class="form-control" value="<%= item? item.stock:0 %>" />
                </div>
              </div>
            </div>

            <!-- Variant Builder (shown when has variants) -->
            <div id="variantBuilder" class="variant-builder" style="<%= item && item.has_variants ? '' : 'display:none;' %>">
              <h3 style="margin-bottom: 1rem;">Variant Configuration</h3>
              
              <!-- Step 1: Select Attributes -->
              <div class="form-group">
                <label class="form-label">Select Attributes</label>
                <div class="attribute-selector" id="attributeSelector">
                  <% if(typeof attributes !== 'undefined' && attributes.length > 0) { %>
                    <% attributes.forEach(attr => { %>
                      <div class="attribute-chip" data-attr-id="<%= attr.id %>" data-attr-name="<%= attr.name %>" onclick="toggleAttribute(this)">
                        <%= attr.name %>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <p style="color: #666;">No attributes available. <a href="/admin/attributes/new">Create attributes first</a></p>
                  <% } %>
                </div>
              </div>

              <!-- Step 2: Select Values for Each Attribute -->
              <div id="attributeValuesContainer"></div>

              <!-- Step 3: Generate Variants Button -->
              <button type="button" class="btn btn-primary" onclick="generateVariants()">Generate Variants</button>

              <!-- Step 4: Variant List -->
              <div id="variantList" class="variant-grid"></div>
            </div>

            <hr style="margin: 2rem 0;">

            <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
              <button type="submit" class="btn btn-success"><%= item? 'Update':'Create' %> Product</button>
              <a href="/admin/products" class="btn btn-outline-primary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="/staticfiles/admin-enhancements.js?v=3.0"></script>
  <script>
    let selectedAttributes = [];
    let attributeValues = <%= JSON.stringify(typeof attributeValues !== 'undefined' ? attributeValues : {}) %>;
    let existingVariants = <%= JSON.stringify(item && item.variants ? item.variants : []) %>;

    function toggleVariantBuilder() {
      const hasVariants = document.getElementById('hasVariants').checked;
      document.getElementById('simpleFields').style.display = hasVariants ? 'none' : 'block';
      document.getElementById('variantBuilder').style.display = hasVariants ? 'block' : 'none';
    }

    function toggleAttribute(chip) {
      chip.classList.toggle('selected');
      const attrId = chip.dataset.attrId;
      const attrName = chip.dataset.attrName;
      
      if (chip.classList.contains('selected')) {
        selectedAttributes.push({ id: attrId, name: attrName });
      } else {
        selectedAttributes = selectedAttributes.filter(a => a.id !== attrId);
      }
      
      renderAttributeValues();
    }

    function renderAttributeValues() {
      const container = document.getElementById('attributeValuesContainer');
      container.innerHTML = '';
      
      selectedAttributes.forEach(attr => {
        const values = attributeValues[attr.id] || [];
        const div = document.createElement('div');
        div.className = 'form-group';
        div.innerHTML = `
          <label class="form-label">${attr.name} Values</label>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            ${values.map(v => `
              <label style="display: flex; align-items: center; gap: 0.25rem; padding: 0.5rem; background: #f8f9fa; border-radius: 4px;">
                <input type="checkbox" class="attr-value" data-attr-id="${attr.id}" data-value="${v.value}" checked />
                ${v.value}
              </label>
            `).join('')}
          </div>
        `;
        container.appendChild(div);
      });
    }

    function generateVariants() {
      const combinations = [];
      const attrData = {};
      
      selectedAttributes.forEach(attr => {
        const checkedValues = Array.from(document.querySelectorAll(`.attr-value[data-attr-id="${attr.id}"]:checked`))
          .map(cb => cb.dataset.value);
        attrData[attr.name] = checkedValues;
      });
      
      // Generate all combinations
      const keys = Object.keys(attrData);
      if (keys.length === 0) return alert('Select at least one attribute');
      
      function cartesian(obj) {
        const entries = Object.entries(obj);
        const result = entries.reduce((acc, [key, values]) => {
          return acc.flatMap(combo => values.map(val => ({ ...combo, [key]: val })));
        }, [{}]);
        return result;
      }
      
      const variants = cartesian(attrData);
      renderVariantList(variants);
    }

    function renderVariantList(variants) {
      const container = document.getElementById('variantList');
      container.innerHTML = '<h4 style="margin-top: 1.5rem;">Generated Variants</h4>';
      
      variants.forEach((combo, idx) => {
        const label = Object.entries(combo).map(([k, v]) => `${k}: ${v}`).join(', ');
        const existing = existingVariants.find(ev => JSON.stringify(ev.attribute_combination) === JSON.stringify(combo));
        
        const card = document.createElement('div');
        card.className = 'variant-card';
        card.innerHTML = `
          <strong>${label}</strong>
          <input type="hidden" name="variants[${idx}][combination]" value='${JSON.stringify(combo)}' />
          <input type="text" name="variants[${idx}][sku]" placeholder="SKU" class="form-control" value="${existing ? existing.sku : ''}" />
          <input type="number" name="variants[${idx}][price_adjustment]" placeholder="Price Adjustment" class="form-control" value="${existing ? existing.price_adjustment : 0}" step="0.01" />
          <input type="number" name="variants[${idx}][stock]" placeholder="Stock" class="form-control" value="${existing ? existing.stock : 0}" />
          <input type="text" name="variants[${idx}][image]" placeholder="Image URL (optional)" class="form-control" value="${existing ? existing.image : ''}" />
        `;
        container.appendChild(card);
      });
    }

    // Load existing variants on edit
    if (existingVariants.length > 0) {
      // Auto-select attributes and render
      setTimeout(() => {
        const attrNames = Object.keys(existingVariants[0].attribute_combination || {});
        document.querySelectorAll('.attribute-chip').forEach(chip => {
          if (attrNames.includes(chip.dataset.attrName)) {
            chip.click();
          }
        });
        setTimeout(() => generateVariants(), 100);
      }, 100);
    }
  </script>
</body>
</html>
