{
  "name": "allstrawhats",
  "version": "1.0.0",
  "description": "Minimal full-stack setup for All Strawhats (anime store frontend + Express backend)",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "build": "node build-production.js",
    "build:prod": "node build-production.js",
    "deploy": "node build-production.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop allstrawhats",
    "pm2:restart": "pm2 restart allstrawhats",
    "pm2:logs": "pm2 logs allstrawhats",
    "pm2:status": "pm2 status",
    "production": "pm2 start ecosystem.config.js",
    "prod": "pm2 start ecosystem.config.js"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.44.4",
    "archiver": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
