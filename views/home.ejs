<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title><%= siteSetting.name %> | Custom Laptop Stickers in Nepal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.theme.default.css" />
  <link rel="stylesheet" href="/staticfiles/style.blue.css" />
  <link rel="stylesheet" href="/staticfiles/floating-button.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-pbCf3Z52eQX1ZsaAJ+lZeI7IuAv89xDSHLVbkP4SRrped1IovnEwlHGawEq+y3OCAXoTr4Wr9L5xRcmRl6Vw2g==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <style>
    html, body {
      height: 100%;
      margin: 0;
    }
    body {
      font-family: 'Libre Franklin', Arial, sans-serif;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .main-content {
      flex: 1 0 auto;
    }
    footer {
      flex-shrink: 0;
    }
    .category-item{display:block; position:relative; border:1px solid #bebebe; overflow:hidden; border-radius:2px; background:#fff;}
    .category-item img{transition:transform .45s; width:100%;}
    .category-item:hover img{transform:scale(1.12);}  
    .category-item-title{position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); background:#fff; padding:.35rem 1rem; font-size:.95rem; font-weight:700; letter-spacing:.05em; border:2px dotted #0a0a0a; text-transform:uppercase;}
    .scroll-menu-wrapper{position:relative; padding:10px 0; height:220px;} .menu{white-space:nowrap; overflow-x:auto; overflow-y:hidden;} .menu::-webkit-scrollbar{width:0;} .scroll-item{display:inline-block; width:200px;}
    @media (max-width:600px){ .scroll-menu-wrapper{height:150px;} .scroll-item{width:120px;} .category-item-title{padding:.2rem .4rem; font-size:.7rem;} }
    .product{text-align:center; background:#f8f8f8; border:1px solid #f8f8f8; transition:box-shadow .25s, transform .25s;} .product:hover{box-shadow:0 6px 18px -6px rgba(0,0,0,.12); transform:translateY(-3px);} .product img{height:150px; object-fit:contain;}
    
    /* Hero carousel - fixed aspect ratio and better design */
    .hero-wrapper{position:relative; width:100%; padding-top:0; margin-bottom:1.5rem;}
    #hero-carousel{position:relative; width:100%; border-radius:8px; overflow:hidden; box-shadow:0 4px 12px rgba(0,0,0,.08);}
    #hero-carousel .owl-stage-outer, #hero-carousel .owl-stage, #hero-carousel .owl-item{height:100%;}
    #hero-carousel .item{position:relative; width:100%; padding-top:42%; overflow:hidden; background:#f8f9fa;}
    #hero-carousel .item a, #hero-carousel .item .hero-image-wrapper{position:absolute; top:0; left:0; width:100%; height:100%; display:block;}
    #hero-carousel img{position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover; opacity:1; transition:opacity .4s ease-in-out;}
    #hero-carousel .hero-label{position:absolute; left:20px; bottom:20px; right:20px; background:rgba(0,0,0,.7); backdrop-filter:blur(8px); color:#fff; padding:10px 18px; border-radius:6px; font-size:15px; font-weight:600; letter-spacing:.8px; text-transform:uppercase; box-shadow:0 4px 12px rgba(0,0,0,.25); z-index:10; max-width:fit-content;}
    #hero-carousel .owl-dots{position:absolute; bottom:15px; left:50%; transform:translateX(-50%); z-index:20; display:flex; gap:8px;}
    #hero-carousel .owl-dot{width:8px; height:8px; border-radius:50%; background:rgba(255,255,255,.5); transition:all .3s; border:none; padding:0;}
    #hero-carousel .owl-dot.active{width:24px; border-radius:4px; background:#fff;}
    #hero-carousel .owl-nav{display:none;}
    
    @media (max-width:768px){
      #hero-carousel .item{padding-top:56%;}
      #hero-carousel .hero-label{left:12px; bottom:12px; right:12px; padding:8px 12px; font-size:12px; letter-spacing:.6px;}
      #hero-carousel .owl-dots{bottom:10px; gap:6px;}
      #hero-carousel .owl-dot{width:6px; height:6px;}
      #hero-carousel .owl-dot.active{width:18px;}
    }
    @media (max-width:576px){
      #hero-carousel .item{padding-top:65%;}
      #hero-carousel .hero-label{left:10px; bottom:10px; right:10px; padding:6px 10px; font-size:11px; letter-spacing:.5px;}
      .hero-wrapper{margin-bottom:1rem;}
    }
  </style>
</head>
<body>
  <div class="main-content">
  <nav class="navbar navbar-light fixed-top py-0 px-2">
    <div class="container px-0 px-lg-3">
  <a class="navbar-brand" href="/"><img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" height="60"></a>
  <form method="POST" id="search-form-in-navbar">
        <div class="input-group search-input-group">
          <input class="form-control form-control-lg search" id="search" name="search" type="text" placeholder="Search Stickers">
          <div class="input-group-append">
            <button class="input-group-text search-icon" id="search-icon-id"><i class="fas fa-search"></i></button>
          </div>
        </div>
      </form>
      <ul class="navbar-nav ml-auto phone-in-navbar" style="display: none;">
        <li class="nav-item"><a class="nav-link" href="tel:9802326980"> <i class="fas fa-phone-alt"></i> 9802326980<sup><small> NP</small></sup></a></li>
      </ul>
    </div>
  </nav>

  <div style="margin-top: 80px;"></div>

  <!-- Hero Images Slider (if any) -->
  <% if(heroImages && heroImages.length){ %>
  <div class="container">
    <div class="hero-wrapper">
      <div class="owl-carousel" id="hero-carousel">
        <% heroImages.forEach(h=>{ %>
          <div class="item">
            <% if(h.link_url){ %>
              <a href="<%= h.link_url %>" class="hero-image-wrapper">
                <img src="<%= h.image_url %>" alt="<%= h.title || 'Hero Image' %>">
              </a>
            <% } else { %>
              <div class="hero-image-wrapper">
                <img src="<%= h.image_url %>" alt="<%= h.title || 'Hero Image' %>">
              </div>
            <% } %>
            <% if(h.title){ %>
              <div class="hero-label"><%= h.title %></div>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
  <% } %>

  <div class="container">
    <section class="pt-2 pt-sm-4">
      <header class="text-center mb-3">
        <p class="small text-muted text-uppercase mb-1">Crafted With Love</p>
        <h2 class="h5 text-uppercase" style="letter-spacing:1.3px;">Browse Sticker Categories</h2>
      </header>
      <div class="scroll-menu-wrapper">
        <ul class="menu list-unstyled mb-0 pl-0">
          <% categories.forEach(c=>{ %>
            <div class="text-center scroll-item">
              <a class="category-item" href="/shop/<%= c.name %>/">
                <img src="<%= c.image || '/staticfiles/brand.svg' %>" alt="<%- c.name.replace(/"/g,'&quot;') %>">
                <span class="category-item-title"><%= c.name %></span>
              </a>
            </div>
          <% }) %>
        </ul>
      </div>
    </section>

    <section class="py-3 py-sm-4">
      <header>
        <p class="small text-muted text-uppercase mb-1">You Will Love These</p>
        <h2 class="h5 text-uppercase mb-2">Popular Stickers</h2>
      </header>
      <div class="row">
        <% products.forEach(p=>{ %>
          <div class="col-xl-3 col-lg-4 col-6 px-1 py-1">
            <div class="product pt-2" style="height:100%;">
              <div class="position-relative mb-1">
                <div class="<%= p.id %>-added-message show-added-message" style="display:none; position:absolute; left:4px; top:4px; background:#000; color:#fff; font-size:11px; padding:2px 5px; border-radius:3px;">Added</div>
                <a class="d-block" href="/details/<%= p.id %>/"><img src="<%= p.image %>" class="img-fluid"></a>
              </div>
              <ul class="mb-2 mt-0 list-inline">
                <li class="list-inline-item m-0 p-0"><button class="btn btn-sm btn-dark py-1 px-2" onclick="addToCart('<%= p.id %>','1', false)">Add to Cart</button></li>
                <li class="list-inline-item mr-0"><a class="btn btn-sm btn-outline-dark py-1 px-2 view-btn" data-id="<%= p.id %>" data-img="<%= p.image %>" data-name="<%- p.name.replace(/\"/g,'&quot;') %>" data-price="<%= p.price %>" data-link="/details/<%= p.id %>/"><i class="fas fa-expand"></i></a></li>
              </ul>
              <h5 class="mb-0 text-sm"><a class="reset-anchor" href="/details/<%= p.id %>/"><%= p.name %></a></h5>
              <p class="small text-muted mb-2">Rs. <%= p.price %></p>
            </div>
          </div>
        <% }) %>
        <% if(!products.length){ %>
          <div class="col-12"><p class="text-muted">No products yet.</p></div>
        <% } %>
      </div>
    </section>
  </div>

  <!-- Product Quick View Modal -->
  <div class="modal fade" id="productView" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-body p-0">
          <div class="row align-items-stretch">
            <div class="col-lg-6 p-lg-0">
              <a id="modal-img-link" class="product-view d-block h-100 bg-cover bg-center"></a>
            </div>
            <div class="col-lg-6">
              <button class="close p-4" type="button" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">×</span></button>
              <div class="p-5 my-md-4">
                <h2 class="h4" id="product-modal-title"></h2>
                <p class="text-muted" id="product-modal-price"></p>
                <ul style="list-style:none;" class="descripton-ul pl-0 text-uppercase mb-4">
                  <li><i class="fas fa-check"></i> Waterproof</li>
                  <li><i class="fas fa-check"></i> Premium</li>
                  <li><i class="fas fa-check"></i> No Residue</li>
                  <li><i class="fas fa-check"></i> Scratch Proof</li>
                  <li><i class="fas fa-check"></i> No Fading</li>
                </ul>
                <div class="row align-items-stretch mb-4">
                  <div class="col-sm-7 pr-sm-0">
                    <div class="border d-flex align-items-center justify-content-between py-1 px-3"><span class="small text-uppercase text-gray mr-4 no-select">Quantity</span>
                      <div class="quantity">
                        <button class="dec-btn p-0"><i class="fas fa-caret-left"></i></button>
                        <input class="form-control border-0 shadow-0 p-0" type="text" value="1" id="qty">
                        <button class="inc-btn p-0"><i class="fas fa-caret-right"></i></button>
                      </div>
                    </div>
                  </div>
                  <div class="col-sm-5 pl-sm-0"><button class="btn btn-dark btn-sm btn-block h-100 d-flex align-items-center justify-content-center px-0" id="add-to-cart">Add to cart</button></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div> <!-- End main-content -->

  <!-- Floating Cart Trigger (reuse existing scripts) -->
  <%- include('partials/floating-cart') %>

  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/js/bootstrap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
  <script src="/staticfiles/owl.carousel2.thumbs.min.js"></script>
  <script src="/staticfiles/cart-shared.js?v=4"></script>
  <script src="/staticfiles/front.js?v=2"></script>
  <script src="https://kit.fontawesome.com/d6db3c2373.js" crossorigin="anonymous"></script>
  <script>
    // Initialize hero carousel
    $('#hero-carousel').owlCarousel({items:1, loop:true, autoplay:true, autoplayTimeout:4000, dots:true});
    if(typeof addToCart === 'undefined') { console.warn('addToCart not in scope - ensure front.js loaded'); }
    
    // Quantity button handlers (ensure they work in modal)
    $(document).on('click', '.dec-btn', function () {
      var siblings = $(this).siblings('input');
      if (parseInt(siblings.val(), 10) >= 1) {
        siblings.val(parseInt(siblings.val(), 10) - 1);
      }
    });
    
    $(document).on('click', '.inc-btn', function () {
      var siblings = $(this).siblings('input');
      siblings.val(parseInt(siblings.val(), 10) + 1);
    });
    
    // Product quick view logic
    $(document).on('click','.view-btn', function(){ var $t=$(this); viewproduct($t.data('id'), $t.data('img'), $t.data('name'), $t.data('price'), 'description', $t.data('link')); });
    var selected; 
    function viewproduct(id,image,name,price,description,link){ 
      selected=id; 
      $('#productView').modal(); 
      $('#modal-img-link').css('background-image','url('+image+')'); 
      $('#product-modal-title').html(name); 
      $('#product-modal-price').html('Rs. '+price); 
      $('#modal-img-link').attr('href',link); 
      $('#add-to-cart').val(id);
    } 
    $('#add-to-cart').click(function(){ 
      addToCart($('#add-to-cart').val(), $('#qty').val(), true); 
      $('#productView').modal('toggle'); 
    });
    
    // Search form handler
    $('#search-form-in-navbar').submit(function(e){ e.preventDefault(); var search_term=$('#search').val(); if(search_term){ window.location=window.location.origin+'/search/all/?q='+search_term; }});
    
    // --- Floating cart core (extracted from original static index) ---
    function getCookie(name){ var cookieValue=null; if(document.cookie && document.cookie!==''){ var cookies=document.cookie.split(';'); for(var i=0;i<cookies.length;i++){ var cookie=cookies[i].trim(); if(cookie.substring(0,name.length+1)===(name+'=')){ cookieValue=decodeURIComponent(cookie.substring(name.length+1)); break; } } } return cookieValue; }
    function uuidv4(){ return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,function(c){ var r=Math.random()*16|0,v=c=='x'?r:(r&0x3|0x8); return v.toString(16); }); }
  // cart logic now provided by shared /staticfiles/cart-shared.js
  </script>

  <footer class="bg-dark text-white shadow" style="color: #fff; margin-top: 40px;">
    <div class="container py-4">
      <div class="row">
        <div class="col-lg-6">
          <p class="small text-gray mb-0">© <%= new Date().getFullYear() %> All rights reserved.</p>
          <p class="small text-gray mb-0">Crafted by <a class="text-white reset-anchor" href="https://ulpuskins.com" target="_blank">ULPU Skins</a></p>
        </div>
        <div class="col-lg-6 text-lg-right">
          <p class="small mb-0">FIND US &nbsp;
            <a href="https://facebook.com/allstrawhats/" target="_blank"><i class="fab fa-facebook-square mr-1" style="color: #f5f5f5;"></i></a>
            <a href="https://instagram.com/allstrawhats/" target="_blank"><i class="fab fa-instagram" style="color: #f5f5f5;"></i></a>
          </p>
          <p class="text-sm text-gray mb-0"><a class="text-gray reset-anchor" href="mailto:info@allstrawhats.com" target="_blank"><i class="fas fa-envelope"></i> &nbsp;info@allstrawhats.com</a></p>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>

