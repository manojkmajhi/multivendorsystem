<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Farmer Login - <%= siteSetting.name %></title>
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
  <link rel="stylesheet" href="/custom-theme.css">
  <style>
    .back-link { color: #666; text-decoration: none; transition: color 0.2s; }
    .back-link:hover { color: #333; text-decoration: underline; }
  </style>
</head>
<body class="bg-light">
  <div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
      <div class="col-md-5">
        <div class="card shadow">
          <div class="card-body p-5">
            <h3 class="text-center mb-4">Farmer Login</h3>
            <form action="/farmers/login" method="POST">
              <div class="form-group">
                <label>Email (@cropsay.com)</label>
                <input type="email" name="email" class="form-control" placeholder="yourname@cropsay.com" required>
              </div>
              <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" class="form-control" required>
              </div>
              <button type="submit" class="btn btn-dark btn-block">Login</button>
            </form>
            <div class="text-center mt-3">
              <a href="/farmers/forgot-password" class="back-link">Forgot Password?</a><br>
              <a href="/farmers/signup" class="back-link">Don't have an account? Signup</a><br>
              <a href="/farmers/" class="back-link">← Back to Farmers</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
