<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - <%= siteSetting.name %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card mt-5">
                    <div class="card-header">
                        <h4>Reset Your Password</h4>
                    </div>
                    <div class="card-body">
                        <form id="resetForm">
                            <input type="hidden" id="access_token" value="<%= access_token %>">
                            
                            <div class="mb-3">
                                <label for="password" class="form-label">New Password</label>
                                <input type="password" class="form-control" id="password" required minlength="6">
                            </div>
                            
                            <div class="mb-3">
                                <label for="confirmPassword" class="form-label">Confirm Password</label>
                                <input type="password" class="form-control" id="confirmPassword" required>
                            </div>
                            
                            <button type="submit" class="btn btn-primary w-100">Update Password</button>
                        </form>
                        
                        <div id="message" class="mt-3"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $('#resetForm').on('submit', function(e) {
            e.preventDefault();
            
            const password = $('#password').val();
            const confirmPassword = $('#confirmPassword').val();
            const access_token = $('#access_token').val();
            
            if (password !== confirmPassword) {
                $('#message').html('<div class="alert alert-danger">Passwords do not match</div>');
                return;
            }
            
            $.post('/api/farmers/update-password', {
                access_token: access_token,
                password: password
            })
            .done(function(data) {
                if (data.success) {
                    $('#message').html('<div class="alert alert-success">' + data.message + '</div>');
                    setTimeout(() => {
                        window.location.href = '/farmers/login';
                    }, 2000);
                } else {
                    $('#message').html('<div class="alert alert-danger">' + data.message + '</div>');
                }
            })
            .fail(function() {
                $('#message').html('<div class="alert alert-danger">Failed to update password</div>');
            });
        });
    </script>
</body>
</html>