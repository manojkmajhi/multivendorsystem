<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin Login</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/css/admin-style.css?v=3.0" />
  <style>
    body {
      display: flex;
      min-height: 100vh;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 1rem;
    }
    .login-container {
      width: 100%;
      max-width: 420px;
    }
    .login-card {
      background: #ffffff;
      padding: 2.5rem 2rem;
      border-radius: 12px;
      box-shadow: 0 20px 60px -10px rgba(0,0,0,0.3);
    }
    .login-header {
      text-align: center;
      margin-bottom: 2rem;
    }
    .login-logo {
      width: 80px;
      height: 80px;
      background: var(--primary-color);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
      font-size: 36px;
      color: white;
    }
    .login-title {
      font-size: 24px;
      font-weight: 700;
      color: var(--gray-900);
      margin: 0 0 0.5rem 0;
    }
    .login-subtitle {
      font-size: 14px;
      color: var(--gray-500);
    }
    .btn-login {
      width: 100%;
      padding: 0.875rem;
      font-size: 16px;
      font-weight: 600;
      margin-top: 0.5rem;
    }
    .login-footer {
      text-align: center;
      margin-top: 2rem;
      color: rgba(255, 255, 255, 0.9);
      font-size: 13px;
    }
    .error-message {
      background: var(--danger-light);
      color: #991b1b;
      padding: 0.75rem 1rem;
      border-radius: var(--border-radius-sm);
      margin-bottom: 1.5rem;
      font-size: 14px;
      border-left: 3px solid var(--danger-color);
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-card">
      <div class="login-header">
        <div class="login-logo">🔐</div>
        <h1 class="login-title">Admin Panel</h1>
        <p class="login-subtitle">Sign in to manage your store</p>
      </div>

      <% if(typeof error !== 'undefined' && error) { %>
        <div class="error-message">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/login">
        <input type="hidden" name="next" value="<%= next %>" />
        
        <div class="form-group">
          <label class="form-label">Admin Password</label>
          <input 
            type="password" 
            class="form-control" 
            name="password" 
            required 
            autofocus 
            placeholder="Enter your admin password"
            autocomplete="current-password"
          />
        </div>

        <button type="submit" class="btn btn-primary btn-login">
          Sign In
        </button>
      </form>
    </div>

    <div class="login-footer">
      &copy; <%= new Date().getFullYear() %> Cropsay Admin. All rights reserved.
    </div>
  </div>
</body>
</html>