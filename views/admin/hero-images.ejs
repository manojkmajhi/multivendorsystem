<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Hero Images - Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/staticfiles/admin-style.css?v=3.0" />
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="admin-navbar">
    <div class="admin-navbar-container">
      <a href="/admin/" class="admin-brand">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" />
        <% } %>
      </a>
      
      <button class="mobile-menu-toggle" onclick="toggleSidebar()" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Sidebar -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
    <div class="sidebar-content">
      <div class="sidebar-header">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" class="sidebar-logo" />
        <% } %>
        <h3 class="sidebar-title"><%= (siteSetting && siteSetting.name) || 'Admin Panel' %></h3>
        <button class="sidebar-close" onclick="toggleSidebar()" aria-label="Close menu">&times;</button>
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/" class="sidebar-link">
          <span class="sidebar-icon">📊</span>
          <span>Dashboard</span>
        </a>
        <a href="/admin/products" class="sidebar-link">
          <span class="sidebar-icon">📦</span>
          <span>Products</span>
        </a>
        <a href="/admin/categories" class="sidebar-link">
          <span class="sidebar-icon">📁</span>
          <span>Categories</span>
        </a>
        <a href="/admin/hero-images" class="sidebar-link active">
          <span class="sidebar-icon">🖼️</span>
          <span>Hero Images</span>
        </a>
        <a href="/admin/settings" class="sidebar-link">
          <span class="sidebar-icon">⚙️</span>
          <span>Settings</span>
        </a>
      </nav>
      
      <div class="sidebar-footer">
        <form method="POST" action="/admin/logout">
          <button type="submit" class="sidebar-logout-btn">
            <span class="sidebar-icon">🚪</span>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="admin-container">
    <div class="page-header">
      <h1 class="page-title">Hero Images</h1>
    </div>

    <% if(msg){ %>
      <div class="alert alert-success"><%= msg %></div>
    <% } %>

    <div class="grid-form-table">
      <!-- Hero Images Table -->
      <div>
        <% if(items && items.length > 0) { %>
          <div class="table-container">
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th style="width:60px;">Pos</th>
                    <th style="width:100px;">Preview</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Link</th>
                    <th style="width:90px;">Status</th>
                    <th style="width:180px;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% items.forEach(img => { %>
                    <tr>
                      <td><strong><%= img.position %></strong></td>
                      <td>
                        <img class="img-thumbnail" src="<%= img.image_url %>" alt="<%= img.title || 'Hero image' %>">
                      </td>
                      <td><strong><%= img.title || '-' %></strong></td>
                      <td style="font-size:13px;color:var(--gray-600);max-width:200px;">
                        <%= img.description ? (img.description.substring(0, 50) + (img.description.length > 50 ? '...' : '')) : '-' %>
                      </td>
                      <td style="font-size:12px;word-break:break-all;max-width:150px;">
                        <%= img.link_url || '-' %>
                      </td>
                      <td>
                        <span class="badge <%= img.active? 'badge-success':'badge-secondary' %>">
                          <%= img.active? 'Active':'Inactive' %>
                        </span>
                      </td>
                      <td>
                        <div class="table-actions">
                          <form method="POST" action="/admin/hero-images/<%= img.id %>/toggle-active">
                            <button class="btn btn-sm btn-outline-warning">Toggle</button>
                          </form>
                          <form method="POST" action="/admin/hero-images/<%= img.id %>/delete" onsubmit="return confirm('Delete this hero image?');">
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        <% } else { %>
          <div class="card">
            <div class="card-body">
              <div class="empty-state">
                <div class="empty-state-icon">🖼️</div>
                <h3 class="empty-state-title">No Hero Images Yet</h3>
                <p class="empty-state-text">Add hero images to showcase on your homepage.</p>
              </div>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Add Hero Image Form -->
      <div>
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Add Hero Image</h2>
          </div>
          <div class="card-body">
            <form method="POST" action="/admin/hero-images/new">
              <div class="form-group">
                <label class="form-label">Title *</label>
                <input class="form-control" name="title" required placeholder="e.g., One Piece Collection" />
              </div>
              
              <div class="form-group">
                <label class="form-label">Image URL *</label>
                <input class="form-control" name="image_url" required placeholder="/staticfiles/hero-banner.jpg or https://..." />
                <small class="form-text">Use a high-quality banner image</small>
              </div>
              
              <div class="form-group">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="description" placeholder="Short supporting text" rows="3"></textarea>
              </div>
              
              <div class="form-group">
                <label class="form-label">Link URL</label>
                <input class="form-control" name="link_url" placeholder="/shop/All/" />
                <small class="form-text">Where should this banner link to?</small>
              </div>
              
              <div class="form-group">
                <label class="form-label">CTA Label</label>
                <input class="form-control" name="cta_label" placeholder="Shop now" />
                <small class="form-text">Button text (optional)</small>
              </div>
              
              <div class="form-group">
                <label class="form-label">Position</label>
                <input type="number" class="form-control" name="position" value="0" />
                <small class="form-text">Display order (lower numbers appear first)</small>
              </div>
              
              <button type="submit" class="btn btn-primary">Add Hero Image</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="admin-footer">
    &copy; <%= new Date().getFullYear() %> <%= (siteSetting && siteSetting.name) || 'Admin' %>. All rights reserved.
  </footer>

  <script src="/staticfiles/admin-enhancements.js?v=3.0"></script>
</body>
</html>