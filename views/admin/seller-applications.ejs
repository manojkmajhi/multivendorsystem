<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Seller Applications - Admin</title>
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <link rel="stylesheet" href="/css/admin-style.css">
  <link rel="stylesheet" href="/custom-theme.css">
</head>
<body>
  <%- include('../partials/admin-nav', { active: 'seller-applications' }) %>

  <div class="container-fluid mt-4">
    <h2><i class="fas fa-file-alt"></i> Seller Applications</h2>
    
    <% if (msg) { %>
      <div class="alert alert-success"><%= msg %></div>
    <% } %>

    <div class="table-responsive mt-3">
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Business</th>
            <th>Location</th>
            <th>Status</th>
            <th>Applied</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% applications.forEach(app => { %>
            <tr>
              <td><%= app.full_name %></td>
              <td><%= app.phone %></td>
              <td><%= app.email || '-' %></td>
              <td><%= app.business_name || '-' %></td>
              <td><%= app.location || '-' %></td>
              <td>
                <span class="badge badge-<%= app.status === 'pending' ? 'warning' : app.status === 'approved' ? 'success' : 'danger' %>">
                  <%= app.status %>
                </span>
              </td>
              <td><%= new Date(app.created_at).toLocaleDateString() %></td>
              <td>
                <% if (app.status === 'pending') { %>
                  <button class="btn btn-sm btn-success" onclick="approveApplication('<%= app.id %>', '<%= app.full_name %>', '<%= app.phone %>', '<%= app.email || '' %>')">
                    <i class="fas fa-check"></i> Approve
                  </button>
                  <button class="btn btn-sm btn-danger" onclick="rejectApplication('<%= app.id %>')">
                    <i class="fas fa-times"></i> Reject
                  </button>
                <% } %>
                <button class="btn btn-sm btn-info" data-toggle="modal" data-target="#viewModal<%= app.id %>">
                  <i class="fas fa-eye"></i> View
                </button>
              </td>
            </tr>

            <!-- View Modal -->
            <div class="modal fade" id="viewModal<%= app.id %>" tabindex="-1">
              <div class="modal-dialog">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title">Application Details</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                  </div>
                  <div class="modal-body">
                    <p><strong>Name:</strong> <%= app.full_name %></p>
                    <p><strong>Phone:</strong> <%= app.phone %></p>
                    <p><strong>Email:</strong> <%= app.email || '-' %></p>
                    <p><strong>Business:</strong> <%= app.business_name || '-' %></p>
                    <p><strong>Location:</strong> <%= app.location || '-' %></p>
                    <% if (app.message) { %>
                      <p><strong>Message:</strong><br><%= app.message %></p>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Approve Modal -->
  <div class="modal fade" id="approveModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Approve Seller Application</h5>
          <button type="button" class="close" data-dismiss="modal">&times;</button>
        </div>
        <form id="approveForm">
          <input type="hidden" id="appId" name="application_id">
          <div class="modal-body">
            <p>Create account for: <strong id="sellerName"></strong></p>
            <div class="form-group">
              <label>Email (@cropsay.com) *</label>
              <div class="input-group">
                <input type="text" id="emailPrefix" name="email_prefix" class="form-control" required>
                <div class="input-group-append">
                  <span class="input-group-text">@cropsay.com</span>
                </div>
              </div>
            </div>
            <div class="form-group">
              <label>Temporary Password *</label>
              <input type="text" name="password" class="form-control" value="<%= Math.random().toString(36).slice(-8) %>" required>
              <small class="text-muted">Send this password to the seller</small>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-success">Create Account & Approve</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function approveApplication(id, name, phone, email) {
      $('#appId').val(id);
      $('#sellerName').text(name);
      
      // Suggest email prefix from name
      const prefix = name.toLowerCase().replace(/\s+/g, '.');
      $('#emailPrefix').val(prefix);
      
      $('#approveModal').modal('show');
    }

    $('#approveForm').on('submit', function(e) {
      e.preventDefault();
      const formData = $(this).serialize();
      
      $.post('/admin/seller-applications/approve', formData)
        .done(function(res) {
          if (res.success) {
            alert('Seller approved! Email: ' + res.email + '\\nPassword: ' + res.password + '\\n\\nPlease send these credentials to the seller.');
            location.reload();
          } else {
            alert('Error: ' + (res.error || 'Failed to approve'));
          }
        })
        .fail(function() {
          alert('Failed to approve application');
        });
    });

    function rejectApplication(id) {
      if (!confirm('Are you sure you want to reject this application?')) return;
      
      $.post('/admin/seller-applications/reject', { application_id: id })
        .done(function() {
          alert('Application rejected');
          location.reload();
        })
        .fail(function() {
          alert('Failed to reject application');
        });
    }
  </script>
</body>
</html>