<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Categories - Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/staticfiles/admin-style.css?v=3.0" />
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="admin-navbar">
    <div class="admin-navbar-container">
      <a href="/admin/" class="admin-brand">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" />
        <% } %>
      </a>
      
      <!-- Desktop Navigation Links -->
      <div class="desktop-nav-links">
        <a href="/admin/" class="nav-link">
          <span class="nav-icon">📊</span>
          <span>Dashboard</span>
        </a>
        <a href="/admin/products" class="nav-link">
          <span class="nav-icon">📦</span>
          <span>Products</span>
        </a>
        <a href="/admin/categories" class="nav-link active">
          <span class="nav-icon">📁</span>
          <span>Categories</span>
        </a>
        <a href="/admin/hero-images" class="nav-link">
          <span class="nav-icon">🖼️</span>
          <span>Hero Images</span>
        </a>
        <a href="/admin/settings" class="nav-link">
          <span class="nav-icon">⚙️</span>
          <span>Settings</span>
        </a>
        <form method="POST" action="/admin/logout" style="display: inline;">
          <button type="submit" class="nav-link nav-logout-btn">
            <span class="nav-icon">🚪</span>
            <span>Logout</span>
          </button>
        </form>
      </div>
      
      <!-- Mobile Hamburger Menu -->
      <button class="mobile-menu-toggle" onclick="toggleSidebar()" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Sidebar -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
    <div class="sidebar-content">
      <div class="sidebar-header">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" class="sidebar-logo" />
        <% } %>
        <h3 class="sidebar-title"><%= (siteSetting && siteSetting.name) || 'Admin Panel' %></h3>
        <button class="sidebar-close" onclick="toggleSidebar()" aria-label="Close menu">&times;</button>
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/" class="sidebar-link">
          <span class="sidebar-icon">📊</span>
          <span>Dashboard</span>
        </a>
        <a href="/admin/products" class="sidebar-link">
          <span class="sidebar-icon">📦</span>
          <span>Products</span>
        </a>
        <a href="/admin/categories" class="sidebar-link active">
          <span class="sidebar-icon">📁</span>
          <span>Categories</span>
        </a>
        <a href="/admin/hero-images" class="sidebar-link">
          <span class="sidebar-icon">🖼️</span>
          <span>Hero Images</span>
        </a>
        <a href="/admin/settings" class="sidebar-link">
          <span class="sidebar-icon">⚙️</span>
          <span>Settings</span>
        </a>
      </nav>
      
      <div class="sidebar-footer">
        <form method="POST" action="/admin/logout">
          <button type="submit" class="sidebar-logout-btn">
            <span class="sidebar-icon">🚪</span>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="admin-container">
    <div class="page-header">
      <h1 class="page-title">Categories</h1>
    </div>

    <% if(msg){ %>
      <div class="alert alert-success"><%= msg %></div>
    <% } %>

    <div class="grid-form-table">
      <!-- Categories Table -->
      <div>
        <% if(items && items.length > 0) { %>
          <!-- Search Box -->
          <div class="search-container">
            <div class="search-box">
              <span class="search-icon">🔍</span>
              <input 
                type="search" 
                id="categorySearch" 
                class="search-input" 
                placeholder="Search categories by name..."
                autocomplete="off"
              />
              <span class="search-count" id="searchCount"></span>
            </div>
          </div>

          <div class="table-container">
            <div class="table-responsive">
              <table id="categoriesTable">
                <thead>
                  <tr>
                    <th>Category Name</th>
                    <th style="width:120px;">Image</th>
                    <th style="width:180px;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% items.forEach(c => { %>
                    <tr class="category-row" data-search="<%= c.name.toLowerCase() %>">
                      <td><strong><%= c.name %></strong></td>
                      <td>
                        <% if(c.image_url || c.image){ %>
                          <img src="<%= c.image_url || c.image %>" class="img-preview" alt="<%= c.name %>">
                        <% } else { %>
                          <span class="text-muted">No image</span>
                        <% } %>
                      </td>
                      <td>
                        <div class="table-actions">
                          <button class="btn btn-sm btn-outline-primary" 
                                  data-id="<%= c.id || c.name %>" 
                                  data-name="<%= c.name %>" 
                                  data-image="<%= c.image_url || c.image || '' %>"
                                  onclick="editCategory(this.dataset.id, this.dataset.name, this.dataset.image)">
                            Edit
                          </button>
                          <form method="POST" action="/admin/categories/<%= c.id || c.name %>/delete" onsubmit="return confirm('Delete this category? This cannot be undone.');" style="display:inline;">
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            
            <!-- No Results Message -->
            <div id="noResults" class="empty-state" style="display: none; padding: 3rem;">
              <div class="empty-state-icon">🔍</div>
              <h3 class="empty-state-title">No categories found</h3>
              <p class="empty-state-text">Try adjusting your search terms.</p>
            </div>
          </div>
        <% } else { %>
          <div class="card">
            <div class="card-body">
              <div class="empty-state">
                <div class="empty-state-icon">📁</div>
                <h3 class="empty-state-title">No Categories Yet</h3>
                <p class="empty-state-text">Create your first category to organize your products.</p>
              </div>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Add Category Form -->
      <div>
        <div class="card">
          <div class="card-header">
            <h2 class="card-title" id="formTitle">Add Category</h2>
          </div>
          <div class="card-body">
            <form method="POST" action="/admin/categories/new" id="categoryForm" enctype="multipart/form-data">
              <input type="hidden" name="categoryId" id="categoryId" value="" />
              
              <div class="form-group">
                <label class="form-label">Category Name *</label>
                <input class="form-control" name="name" id="categoryName" required placeholder="e.g., Stickers, Pillows" />
              </div>
              
              <div class="form-group">
                <label class="form-label">Category Image</label>
                <div style="margin-bottom: 1rem;">
                  <input type="file" name="imageFile" id="categoryImageFile" class="form-control" accept="image/*" onchange="previewCategoryImage(event)" />
                  <small class="form-text">Upload an image from your computer (JPG, PNG, WebP, max 5MB)</small>
                </div>
                <div style="margin-top: 1rem;">
                  <label style="display: block; margin-bottom: 0.5rem; color: var(--gray-700);">Or enter image URL:</label>
                  <input class="form-control" name="image_url" id="categoryImageUrl" placeholder="/staticfiles/Category.jpg or https://..." />
                  <small class="form-text">If you upload a file, it will override the URL</small>
                </div>
              </div>
              
              <div class="form-group" id="categoryImagePreview" style="display: none;">
                <label class="form-label">Image Preview</label>
                <div style="padding: 1rem; background: var(--gray-100); border-radius: var(--border-radius-sm); display: inline-block;">
                  <img id="categoryPreviewImg" style="max-height: 150px; max-width: 100%; object-fit: contain;" alt="Preview">
                </div>
              </div>
              
              <div style="display: flex; gap: 0.5rem;">
                <button type="submit" class="btn btn-primary" id="submitBtn">Add Category</button>
                <button type="button" class="btn btn-outline-secondary" id="cancelBtn" onclick="resetForm()" style="display: none;">Cancel</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="admin-footer">
    &copy; <%= new Date().getFullYear() %> <%= (siteSetting && siteSetting.name) || 'Admin' %>. All rights reserved.
  </footer>

  <script src="/staticfiles/admin-enhancements.js?v=3.0"></script>
  <script>
    function previewCategoryImage(event) {
      const file = event.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          document.getElementById('categoryPreviewImg').src = e.target.result;
          document.getElementById('categoryImagePreview').style.display = 'block';
        };
        reader.readAsDataURL(file);
      } else {
        document.getElementById('categoryImagePreview').style.display = 'none';
      }
    }
    
    function editCategory(id, name, imageUrl) {
      document.getElementById('formTitle').textContent = 'Edit Category';
      document.getElementById('categoryForm').action = '/admin/categories/' + id + '/edit';
      document.getElementById('categoryId').value = id;
      document.getElementById('categoryName').value = name;
      document.getElementById('categoryImageUrl').value = imageUrl;
      document.getElementById('submitBtn').textContent = 'Update Category';
      document.getElementById('cancelBtn').style.display = 'inline-block';
      
      if (imageUrl) {
        document.getElementById('categoryPreviewImg').src = imageUrl;
        document.getElementById('categoryImagePreview').style.display = 'block';
      }
      
      // Scroll to form
      document.getElementById('categoryForm').scrollIntoView({ behavior: 'smooth' });
    }
    
    function resetForm() {
      document.getElementById('formTitle').textContent = 'Add Category';
      document.getElementById('categoryForm').action = '/admin/categories/new';
      document.getElementById('categoryForm').reset();
      document.getElementById('categoryId').value = '';
      document.getElementById('submitBtn').textContent = 'Add Category';
      document.getElementById('cancelBtn').style.display = 'none';
      document.getElementById('categoryImagePreview').style.display = 'none';
    }
  </script>
</body>
</html>