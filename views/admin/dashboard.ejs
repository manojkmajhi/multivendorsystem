<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - <%= (siteSetting && siteSetting.name) || 'All Strawhats' %></title>
  <link rel="stylesheet" href="/staticfiles/admin-style.css?v=3.0">
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="admin-navbar">
    <div class="admin-navbar-container">
      <a href="/admin/" class="admin-brand">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" />
        <% } %>
      </a>
      
      <!-- Desktop Navigation Links -->
      <div class="desktop-nav-links">
        <a href="/admin/" class="nav-link active">
          <span class="nav-icon">📊</span>
          <span>Dashboard</span>
        </a>
        <a href="/admin/products" class="nav-link">
          <span class="nav-icon">📦</span>
          <span>Products</span>
        </a>
        <a href="/admin/categories" class="nav-link">
          <span class="nav-icon">📁</span>
          <span>Categories</span>
        </a>
        <a href="/admin/hero-images" class="nav-link">
          <span class="nav-icon">🖼️</span>
          <span>Hero Images</span>
        </a>
        <a href="/admin/settings" class="nav-link">
          <span class="nav-icon">⚙️</span>
          <span>Settings</span>
        </a>
        <form method="POST" action="/admin/logout" style="display: inline;">
          <button type="submit" class="nav-link nav-logout-btn">
            <span class="nav-icon">🚪</span>
            <span>Logout</span>
          </button>
        </form>
      </div>
      
      <!-- Mobile Hamburger Menu -->
      <button class="mobile-menu-toggle" onclick="toggleSidebar()" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Sidebar -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
    <div class="sidebar-content">
      <div class="sidebar-header">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" class="sidebar-logo" />
        <% } %>
        <h3 class="sidebar-title"><%= (siteSetting && siteSetting.name) || 'Admin Panel' %></h3>
        <button class="sidebar-close" onclick="toggleSidebar()" aria-label="Close menu">&times;</button>
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/" class="sidebar-link active">
          <span class="sidebar-icon">📊</span>
          <span>Dashboard</span>
        </a>
        <a href="/admin/products" class="sidebar-link">
          <span class="sidebar-icon">📦</span>
          <span>Products</span>
        </a>
        <a href="/admin/categories" class="sidebar-link">
          <span class="sidebar-icon">📁</span>
          <span>Categories</span>
        </a>
        <a href="/admin/hero-images" class="sidebar-link">
          <span class="sidebar-icon">🖼️</span>
          <span>Hero Images</span>
        </a>
        <a href="/admin/settings" class="sidebar-link">
          <span class="sidebar-icon">⚙️</span>
          <span>Settings</span>
        </a>
      </nav>
      
      <div class="sidebar-footer">
        <form method="POST" action="/admin/logout">
          <button type="submit" class="sidebar-logout-btn">
            <span class="sidebar-icon">🚪</span>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="admin-container">
    <div class="page-header">
      <h1 class="page-title">Dashboard</h1>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card primary">
        <div class="stat-label">Total Products</div>
        <div class="stat-value"><%= stats.products %></div>
      </div>
      <div class="stat-card success">
        <div class="stat-label">Categories</div>
        <div class="stat-value"><%= stats.categories %></div>
      </div>
      <div class="stat-card warning">
        <div class="stat-label">Hero Images</div>
        <div class="stat-value"><%= stats.heroImages || 0 %></div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Quick Actions</h2>
      </div>
      <div class="card-body">
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <a href="/admin/products/new" class="btn btn-primary">
            + Add Product
          </a>
          <a href="/admin/products" class="btn btn-outline-primary">
            Manage Products
          </a>
          <a href="/admin/categories" class="btn btn-outline-primary">
            Manage Categories
          </a>
          <a href="/admin/hero-images" class="btn btn-outline-primary">
            Manage Hero Images
          </a>
          <a href="/admin/settings" class="btn btn-outline-primary">
            ⚙ Settings
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="admin-footer">
    &copy; <%= new Date().getFullYear() %> <%= (siteSetting && siteSetting.name) || 'Admin' %>. All rights reserved.
  </footer>

  <script src="/staticfiles/admin-enhancements.js?v=3.0"></script>
</body>
</html>
