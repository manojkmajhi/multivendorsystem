<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title><%= activeCategory %> | All Strawhats</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/css/lightbox.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.theme.default.css" />
  <link rel="stylesheet" href="/staticfiles/style.blue.css" />
  <link rel="stylesheet" href="/staticfiles/floating-button.css" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@300;400;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Martel+Sans:wght@300;400;800&display=swap" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-pbCf3Z52eQX1ZsaAJ+lZeI7IuAv89xDSHLVbkP4SRrped1IovnEwlHGawEq+y3OCAXoTr4Wr9L5xRcmRl6Vw2g==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <style>
    html, body {
      height: 100%;
      margin: 0;
    }
    body {
      font-family: 'Libre Franklin', Arial, sans-serif;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .main-content {
      flex: 1 0 auto;
    }
    footer {
      flex-shrink: 0;
    }
    /* Use the exact navbar markup/style from home for consistency */
    nav.navbar{box-shadow:0 2px 6px rgba(0,0,0,.05); background:#fff;}
  /* Inline minimal breadcrumb (no box) */
  .nav-spacer{height:120px;} /* pushes content below fixed nav */
  .breadcrumb-inline{margin-top:0; margin-bottom:10px; font-size:11px; letter-spacing:1.5px; text-transform:uppercase;}
  @media (max-width:575.98px){ .nav-spacer{height:130px;} }
  .breadcrumb{background:transparent; font-size:11px; letter-spacing:1.5px; text-transform:uppercase; margin:0; padding:0;}
    .breadcrumb-item + .breadcrumb-item::before{content:'/'; color:#999; padding:0 6px;}
    .breadcrumb-item a{color:#555;}
    .breadcrumb-item a:hover{color:#000; text-decoration:none;}
    .breadcrumb-item.active{color:#000; font-weight:600;}
    /* Sidebar categories */
    .category-box{background:#0a0a0a; padding:14px 18px;}
    .category-box strong{color:#fff; font-size:11px; letter-spacing:1px;}
    .category-list a{display:block; color:#555; padding:4px 0; font-size:14px; text-decoration:none; transition:color .25s;}
    .category-list a.active,.category-list a:hover{color:#000; font-weight:600;}
    /* Product cards mimic home page */
    .product-grid .product{background:#f8f8f8; border:1px solid #f8f8f8; min-height:100%; transition:box-shadow .25s, transform .25s; border-radius:2px;}
    .product-grid .product:hover{box-shadow:0 6px 18px -6px rgba(0,0,0,.12); transform:translateY(-3px);}    
    .product-grid .product img{height:150px; object-fit:contain; transition:transform .3s;}
    .product-grid .product:hover img{transform:scale(1.04);}    
    .product-grid .product h5{font-size:13px; line-height:16px; font-weight:600; margin-top:0; min-height:32px;}
    .product-grid .product h5 a{color:#000; text-decoration:none;}
    .product-grid .product ul{margin-bottom:6px !important;}
    .product-grid .btn-dark{background:#000; border-color:#000; font-size:12px;}
    .product-grid .btn-outline-dark{border-color:#000; font-size:12px;}
    .show-added-message{position:absolute; top:6px; left:6px; background:#0a0a0a; color:#fff; padding:2px 6px; font-size:11px; border-radius:3px; display:none;}
    .range-indicator{font-size:12px; letter-spacing:1px;}
    .pagination .page-link{color:#000; font-size:12px; border:none; background:transparent;}
    .pagination .page-item.active .page-link{background:#000; border-radius:2px; color:#fff;}
    .pagination .page-item:not(.active) .page-link:hover{background:#000; color:#fff; border-radius:2px;}
  /* Mobile integrated category dropdown panel */
  .category-heading-btn{outline:none;}
  .category-heading-btn:focus{box-shadow:none;}
  .category-heading-btn .caret-icon{display:inline-block; transition:transform .3s cubic-bezier(.55,.06,.34,1.37); font-size:.8em; position:relative; top:-1px;}
  .category-heading-btn.active .caret-icon{transform:rotate(180deg);}
  .product-header-row{position:relative;}
  #mobileCatPanel{position:absolute; top:100%; left:0; right:0; background:#fff; border:1px solid #e5e5e5; border-radius:12px; box-shadow:0 22px 40px -12px rgba(0,0,0,.35); padding:12px 14px 16px; transform:translateY(8px) scale(.96); transform-origin:top center; opacity:0; pointer-events:none; transition:opacity .28s ease, transform .32s cubic-bezier(.22,1.15,.53,1); z-index:1200;}
  #mobileCatPanel.open{opacity:1; transform:translateY(0) scale(1); pointer-events:auto;}
  #mobileCatPanel .panel-header{display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;}
  #mobileCatPanel .panel-header span{font-size:11px; letter-spacing:1px; font-weight:600; color:#555;}
  #mobileCatPanel .close-panel{background:#000; color:#fff; border:none; width:28px; height:28px; border-radius:50%; line-height:28px; text-align:center; font-size:16px; font-weight:400; padding:0; cursor:pointer; transition:transform .25s, background .25s;}
  #mobileCatPanel .close-panel:hover{background:#111;}
  #mobileCatPanel .close-panel:active{transform:scale(.85);}
  #mobileCatPanel ul{list-style:none; margin:2px 0 0; padding:0; display:flex; flex-wrap:wrap;}
  #mobileCatPanel ul li{margin:6px 6px 0 0;}
  #mobileCatPanel a.cat-chip{display:inline-block; background:#f3f3f3; padding:7px 14px 6px; border-radius:28px; font-size:12px; letter-spacing:.5px; text-decoration:none; color:#333; font-weight:500; line-height:1; position:relative; overflow:hidden; transition:background .25s, color .25s, box-shadow .25s;}
  #mobileCatPanel a.cat-chip:hover{background:#111; color:#fff;}
  #mobileCatPanel a.cat-chip.active{background:#000; color:#fff; box-shadow:0 6px 18px -6px rgba(0,0,0,.5);}
  #mobileCatOverlay{position:fixed; inset:0; background:rgba(0,0,0,.33); backdrop-filter:saturate(160%) blur(2px); opacity:0; pointer-events:none; transition:opacity .25s ease; z-index:1100;}
  #mobileCatOverlay.show{opacity:1; pointer-events:auto;}
  @supports not (backdrop-filter: blur(2px)){ #mobileCatOverlay{background:rgba(0,0,0,.45);} }
    .one{background:#fff; border:1px solid #e5e5e5; border-radius:6px; box-shadow:0 12px 30px -8px rgba(0,0,0,.25);} 
    @media (max-width: 991.98px){ .desktop-sidebar{display:none;} }
  </style>
</head>
<body>
  <!-- Consistent navbar from home page -->
  <nav class="navbar navbar-light fixed-top py-0 px-2">
    <div class="container px-0 px-lg-3">
  <a class="navbar-brand" href="/"><img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" height="60"></a>
  <form method="POST" id="search-form-in-navbar">
        <div class="input-group search-input-group">
          <input class="form-control form-control-lg search" id="search" name="search" type="text" placeholder="Search Stickers">
          <div class="input-group-append">
            <button class="input-group-text search-icon" id="search-icon-id"><i class="fas fa-search"></i></button>
          </div>
        </div>
      </form>
      <ul class="navbar-nav ml-auto phone-in-navbar" style="display: none;">
        <li class="nav-item"><a class="nav-link" href="tel:9802326980"> <i class="fas fa-phone-alt"></i> 9802326980<sup><small> NP</small></sup></a></li>
      </ul>
    </div>
  </nav>

  <%- include('partials/floating-cart') %>

  <div class="main-content">

  <div class="nav-spacer"></div>
  <!-- Inline breadcrumb (no box) -->
  <div class="container breadcrumb-inline">
    <div class="d-flex align-items-center justify-content-between flex-wrap">
      <nav aria-label="breadcrumb" class="mb-2 mb-sm-0">
        <ol class="breadcrumb px-0 mb-0">
          <li class="breadcrumb-item"><a href="/">Home</a></li>
          <li class="breadcrumb-item"><a href="/shop/All/">Shop</a></li>
          <% if(activeCategory && activeCategory.toLowerCase()!=='all'){ %>
            <li class="breadcrumb-item active" aria-current="page"><%= activeCategory %></li>
          <% } %>
        </ol>
      </nav>
    </div>
  </div>

  <div class="container py-3">
    <div class="row">
      <!-- Sidebar -->
      <div class="col-lg-3 desktop-sidebar mt-2 mt-lg-4">
        <div class="category-box mb-3"><strong class="small text-uppercase">CATEGORIES</strong></div>
        <ul class="list-unstyled pl-lg-3 mb-4 category-list">
          <li class="mb-2"><a class="reset-anchor <%= activeCategory.toLowerCase()==='all' ? 'active':'' %>" href="/shop/All/">All</a></li>
          <% categories.forEach(c=>{ %>
            <li class="mb-2 <%= activeCategory.toLowerCase()===c.name.toLowerCase() ? 'font-weight-bold text-dark':'' %>"><a class="reset-anchor <%= activeCategory.toLowerCase()===c.name.toLowerCase() ? 'active':'' %>" href="/shop/<%= c.name %>/"><%= c.name %></a></li>
          <% }) %>
        </ul>
      </div>

      <!-- Products -->
      <div class="col-lg-9 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-2 mt-2 mt-lg-4 product-header-row">
          <!-- Desktop plain heading -->
          <h4 class="text-uppercase mb-0 d-none d-lg-block" style="font-weight:400; letter-spacing:1px;"><%= activeCategory %></h4>
          <!-- Mobile button triggers modal category picker -->
          <div class="d-lg-none mb-0">
            <button id="mobileCatToggle" class="category-heading-btn btn btn-link p-0 text-uppercase" type="button" style="font-weight:400; letter-spacing:1px; font-size:1.25rem; text-decoration:none; color:#000;">
              | <span class="current-cat"><%= activeCategory %></span> <span class="caret-icon">&#9662;</span> |
            </button>
            <!-- Hidden panel -->
            <div id="mobileCatPanel" aria-hidden="true">
              <div class="panel-header">
                <span>CATEGORIES</span>
                <button class="close-panel" type="button" aria-label="Close">&times;</button>
              </div>
              <ul>
                <li><a class="cat-chip <%= activeCategory.toLowerCase()==='all' ? 'active':'' %>" href="/shop/All/">All</a></li>
                <% categories.forEach(c=>{ %>
                  <li><a class="cat-chip <%= activeCategory.toLowerCase()===c.name.toLowerCase() ? 'active':'' %>" href="/shop/<%= c.name %>/"><%= c.name %></a></li>
                <% }) %>
              </ul>
            </div>
          </div>
          <div class="range-indicator d-none d-md-block ml-auto"> <% if(total){ %>SHOWING <%= showingStart %>-<%= showingEnd %> OF <%= total %><% } %> </div>
        </div>
        <div class="range-indicator d-md-none mb-2"> <% if(total){ %><%= showingStart %>-<%= showingEnd %> OF <%= total %><% } %> </div>
        <div class="row product-grid">
          <% if (!products.length) { %>
            <div class="col-12"><p class="text-muted">No products found.</p></div>
          <% } %>
          <% products.forEach(p=>{ %>
            <div class="col-xl-3 col-lg-4 col-6 px-1 py-1">
              <div class="product text-center pt-2 bg-light" style="border:1px solid #f8f8f8; height:100%!important;">
                <div class="position-relative mb-1">
                  <div class="<%= p.id %>-added-message show-added-message"></div>
                  <a class="d-block" href="/details/<%= p.id %>/"><img class="img-fluid" src="<%= p.image %>" alt="<%- p.name.replace(/"/g,'&quot;') %>" loading="lazy"></a>
                </div>
                <ul class="mb-2 mt-0 list-inline">
                  <li class="list-inline-item m-0 p-0"><button class="btn btn-sm btn-dark py-1 px-2" onclick="addToCart('<%= p.id %>', '1', false)">Add to Cart</button></li>
                  <li class="list-inline-item mr-0"><a class="btn btn-sm btn-outline-dark py-1 px-2 view-btn" data-id="<%= p.id %>" data-img="<%= p.image %>" data-name="<%- p.name.replace(/"/g,'&quot;') %>" data-price="<%= p.price %>" data-link="/details/<%= p.id %>/"><i class="fas fa-expand"></i></a></li>
                </ul>
                <h5 class="mb-0 text-sm"><a class="reset-anchor" href="/details/<%= p.id %>/"><%= p.name %></a></h5>
                <p class="small text-muted mb-2">Rs. <%= p.price %></p>
              </div>
            </div>
          <% }) %>
        </div>
        <% if(totalPages > 1){ %>
          <nav aria-label="Page navigation" class="mt-2">
            <ul class="pagination pagination-sm justify-content-center justify-content-lg-end">
              <li class="page-item <%= page===1 ? 'disabled':'' %>"><a class="page-link" href="<%= page===1 ? '#' : ('?page='+(page-1)) %>">«</a></li>
              <% for(let p=1; p<= totalPages; p++){ %>
                <li class="page-item <%= p===page ? 'active':'' %>"><a class="page-link" href="<%= p===page ? '#' : ('?page='+p) %>"><%= p %></a></li>
              <% } %>
              <li class="page-item <%= page===totalPages ? 'disabled':'' %>"><a class="page-link" href="<%= page===totalPages ? '#' : ('?page='+(page+1)) %>">»</a></li>
            </ul>
          </nav>
        <% } %>
      </div>
    </div>
  </div>
  <!-- Overlay for mobile category panel -->
  <div id="mobileCatOverlay" class="d-lg-none" aria-hidden="true"></div>
  <div class="modal fade" id="productView" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-body p-0">
          <div class="row align-items-stretch">
            <div class="col-lg-6 p-lg-0">
              <a id="modal-img-link" class="product-view d-block h-100 bg-cover bg-center"></a>
            </div>
            <div class="col-lg-6">
              <button class="close p-4" type="button" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">×</span></button>
              <div class="p-5 my-md-4">
                <h2 class="h4" id="product-modal-title"></h2>
                <p class="text-muted" id="product-modal-price"></p>
                <ul style="list-style:none;" class="descripton-ul pl-0 text-uppercase mb-4">
                  <li><i class="fas fa-check"></i> Waterproof</li>
                  <li><i class="fas fa-check"></i> Premium</li>
                  <li><i class="fas fa-check"></i> No Residue</li>
                  <li><i class="fas fa-check"></i> Scratch Proof</li>
                  <li><i class="fas fa-check"></i> No Fading</li>
                </ul>
                <div class="row align-items-stretch mb-4">
                  <div class="col-sm-7 pr-sm-0">
                    <div class="border d-flex align-items-center justify-content-between py-1 px-3"><span class="small text-uppercase text-gray mr-4 no-select">Quantity</span>
                      <div class="quantity">
                        <button class="dec-btn p-0"><i class="fas fa-caret-left"></i></button>
                        <input class="form-control border-0 shadow-0 p-0" type="text" value="1" id="qty">
                        <button class="inc-btn p-0"><i class="fas fa-caret-right"></i></button>
                      </div>
                    </div>
                  </div>
                  <div class="col-sm-5 pl-sm-0"><button class="btn btn-dark btn-sm btn-block h-100 d-flex align-items-center justify-content-center px-0" id="add-to-cart">Add to cart</button></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div> <!-- End main-content -->

  <!-- Floating cart partial included earlier; removed duplicated markup and JS -->
  <script>
    // Product quick view logic retained
    $(document).on('click','.view-btn', function(){ const $t=$(this); viewproduct($t.data('id'), $t.data('img'), $t.data('name'), $t.data('price'), 'description', $t.data('link')); });
    var selected; function viewproduct(id,image,name,price,description,link){ selected=id; $('#productView').modal(); $('#modal-img-link').css('background-image','url('+image+')'); $('#product-modal-title').html(name); $('#product-modal-price').html('Rs. '+price); $('#modal-img-link').attr('href',link); $('#add-to-cart').val(id);} $('#add-to-cart').click(function(){ addToCart($('#add-to-cart').val(), $('#qty').val(), true); $('#productView').modal('toggle'); });
    $('#search-form-in-navbar').submit(function(e){ e.preventDefault(); var search_term=$('#search').val(); if(search_term){ window.location=window.location.origin+'/search/all/?q='+search_term; }});
    // Custom mobile category panel logic
    var $panel = $('#mobileCatPanel');
    var $overlay = $('#mobileCatOverlay');
    var $toggle = $('#mobileCatToggle');
    function openPanel(){ $toggle.addClass('active'); $panel.addClass('open').attr('aria-hidden','false'); $overlay.addClass('show').attr('aria-hidden','false'); }
    function closePanel(){ $toggle.removeClass('active'); $panel.removeClass('open').attr('aria-hidden','true'); $overlay.removeClass('show').attr('aria-hidden','true'); }
    $toggle.on('click', function(e){ e.stopPropagation(); if($panel.hasClass('open')){ closePanel(); } else { openPanel(); } });
    $panel.on('click', 'a.cat-chip', function(){ closePanel(); });
    $panel.on('click', '.close-panel', function(){ closePanel(); });
    $overlay.on('click', function(){ closePanel(); });
    $(window).on('resize', function(){ if(window.innerWidth >= 992){ closePanel(); } });
    // Close on escape
    $(document).on('keydown', function(e){ if(e.key==='Escape'){ closePanel(); } });
  </script>

  <footer class="bg-dark text-white shadow" style="color: #fff; margin-top: 40px;">
    <div class="container py-4">
      <div class="row">
        <div class="col-lg-6">
          <p class="small text-gray mb-0">© <%= new Date().getFullYear() %> All rights reserved.</p>
          <p class="small text-gray mb-0">Crafted by <a class="text-white reset-anchor" href="https://ulpuskins.com" target="_blank">ULPU Skins</a></p>
        </div>
        <div class="col-lg-6 text-lg-right">
          <p class="small mb-0">FIND US &nbsp;
            <a href="https://facebook.com/allstrawhats/" target="_blank"><i class="fab fa-facebook-square mr-1" style="color: #f5f5f5;"></i></a>
            <a href="https://instagram.com/allstrawhats/" target="_blank"><i class="fab fa-instagram" style="color: #f5f5f5;"></i></a>
          </p>
          <p class="text-sm text-gray mb-0"><a class="text-gray reset-anchor" href="mailto:info@allstrawhats.com" target="_blank"><i class="fas fa-envelope"></i> &nbsp;info@allstrawhats.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/js/bootstrap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/js/lightbox.min.js"></script>
  <script src="/staticfiles/owl.carousel2.thumbs.min.js"></script>
  <script src="/staticfiles/cart-shared.js?v=4"></script>
  <script src="/staticfiles/front.js"></script>
  <script src="https://kit.fontawesome.com/d6db3c2373.js" crossorigin="anonymous"></script>
</body>
</html>