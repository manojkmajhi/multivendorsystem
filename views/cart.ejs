<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Cart | All Strawhats</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/staticfiles/style.blue.css" />
  <link rel="stylesheet" href="/custom-theme.css?v=<%= Date.now() %>" />
  <link rel="stylesheet" href="/staticfiles/floating-button.css" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@300;400;700&display=swap" />
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <style>
    html,body{height:100%;}
    body{font-family:'Libre Franklin',Arial,sans-serif; background:#fff; display:flex; flex-direction:column;}
    .page-wrapper{flex:1 0 auto; width:100%; display:flex; flex-direction:column;}
    nav.navbar{box-shadow:0 2px 6px rgba(0,0,0,.05); background:#fff;}
    .nav-spacer{height:90px;}
    .breadcrumb-inline{font-size:11px; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:12px;}
    .breadcrumb{background:transparent; padding:0; margin:0;}
    .breadcrumb-item+.breadcrumb-item::before{content:'/'; padding:0 6px; color:#999;}
    /* Table + rows */
    .cart-table table{border-collapse:separate; border-spacing:0 6px;}
    .cart-table thead th{font-size:11px; letter-spacing:1.5px; font-weight:700; color:#555; border:none; text-transform:uppercase; background:transparent; padding:0 10px 4px;}
  .cart-table tbody tr{background:#f8f8f8; transition:box-shadow .25s, transform .25s, opacity .35s ease; border-radius:8px;}
  .cart-table tbody tr:hover{box-shadow:0 6px 18px -6px rgba(0,0,0,.14); transform:translateY(-2px);}    
  .cart-table td{border:none; vertical-align:middle; padding:14px 12px;}
    .cart-table img{width:68px; height:68px; object-fit:contain; background:#fff; border:1px solid #eee; border-radius:4px;}
    /* Quantity control */
  .qty-control{display:inline-flex; align-items:center; background:#fff; border:1px solid #d0d0d0; border-radius:5px; overflow:hidden; box-shadow:0 2px 4px -2px rgba(0,0,0,.08);}
  .qty-control button{background:transparent; border:none; width:34px; height:34px; line-height:34px; font-size:15px; padding:0; color:#111; cursor:pointer; outline:none; font-weight:600;}
    .qty-control button:hover{background:#111; color:#fff;}
  .qty-input{width:52px; height:34px; border:0; border-left:1px solid #eee; border-right:1px solid #eee; text-align:center; font-size:14px; background:#fff; padding:0; font-weight:600; letter-spacing:.5px;}
    .qty-input:focus{outline:none;}
  .qty-pulse{animation:qty-pulse .6s ease;} @keyframes qty-pulse{0%{background:#fff2c6;}60%{background:#fff;}100%{background:#fff;}}
    .line-subtotal{font-weight:600;}
    /* Remove */
    .remove-btn{background:none; border:none; color:#dc3545; font-size:12px; letter-spacing:.5px; text-transform:uppercase; font-weight:600; padding:0;}
    .remove-btn i{font-size:14px;}
    .remove-btn:hover{color:#a00; text-decoration:underline;}
    /* Summary card */
  .cart-summary-box{background:linear-gradient(145deg,#fafafa,#f1f1f1); padding:20px 22px 22px; border-radius:10px; box-shadow:0 8px 26px -10px rgba(0,0,0,.18); position:sticky; top:100px; border:1px solid #ececec;}
    .summary-title{font-size:13px; letter-spacing:1.5px; font-weight:700; margin-bottom:16px;}
    .cart-summary-box p{font-size:14px;}
    .summary-total{font-size:17px; letter-spacing:.5px;}
    .btn-dark{background:#000; border-color:#000;}
    .btn-outline-dark{border-color:#000;}
    /* Empty */
    .empty-state{padding:70px 0 90px; text-align:center;}
    .empty-state h4{font-weight:600; letter-spacing:1px; font-size:22px;}
    .empty-state p{color:#666;}
    /* Responsive */
    @media (max-width:991.98px){ .cart-summary-box{margin-top:20px; position:static;} }
    @media (max-width:767.98px){
      .cart-table table thead{display:none;}
      .cart-table table tbody tr{display:block; padding:12px 14px 6px; border-radius:10px; margin-bottom:10px;}
      .cart-table td{display:flex; padding:3px 0; border:none;}
      .cart-table td:first-child{justify-content:center; margin-bottom:8px;}
      .cart-table td:nth-child(2){font-size:15px; font-weight:600; margin-bottom:6px;}
      .cart-table td:nth-child(3), .cart-table td:nth-child(4), .cart-table td:nth-child(5), .cart-table td:nth-child(6){justify-content:space-between;}
      .cart-table td:nth-child(4), .cart-table td:nth-child(5){font-size:13px;}
      .remove-btn{font-size:11px;}
      .mobile-total-bar{display:flex; position:fixed; left:0; right:0; bottom:0; background:#111; color:#fff; padding:10px 14px; align-items:center; justify-content:space-between; z-index:4000; box-shadow:0 -4px 14px -6px rgba(0,0,0,.4);} 
      .mobile-total-bar strong{font-size:15px; letter-spacing:.5px;} 
      .mobile-total-bar .mobile-checkout-btn{background:#fff; color:#000; font-weight:600; border:none; padding:8px 16px; border-radius:4px; font-size:13px;} 
      footer{padding-bottom:70px;}
    }
    .cart-table tbody tr + tr{margin-top:10px;}
    footer{margin-top:30px; flex-shrink:0;}
  </style>
</head>
<body>
<div class="page-wrapper">
  <nav class="navbar navbar-light fixed-top py-0 px-2">
    <div class="container px-0 px-lg-3">
  <a class="navbar-brand" href="/"><img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" height="60" /></a>
      <form method="POST" id="search-form-in-navbar">
        <div class="input-group search-input-group">
          <input class="form-control form-control-lg search" id="search" name="search" type="text" placeholder="Search Anime Products" />
          <div class="input-group-append">
            <button class="input-group-text search-icon" id="search-icon-id"><i class="fas fa-search"></i></button>
          </div>
        </div>
      </form>
      <ul class="navbar-nav ml-auto phone-in-navbar" style="display:none;">
        <li class="nav-item"><a class="nav-link" href="tel:9814789009"> <i class="fas fa-phone-alt"></i> 9814789009<sup><small> NP</small></sup></a></li>
      </ul>
    </div>
  </nav>
  <div class="nav-spacer"></div>

  <div class="container breadcrumb-inline">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb px-0">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/shop/All/">Shop</a></li>
        <li class="breadcrumb-item active" aria-current="page">Cart</li>
      </ol>
    </nav>
  </div>

  <div class="container pb-4 pb-md-5 flex-grow-1">
    <% if(!items.length){ %>
      <div class="empty-state">
        <h4>Your cart is empty</h4>
        <p class="text-muted mb-4">Browse categories and add some items.</p>
        <a href="/shop/All/" class="btn btn-dark">Go to Shop</a>
      </div>
    <% } else { %>
      <div class="row">
  <div class="col-lg-8 mb-3 mb-lg-0">
          <div class="table-responsive cart-table">
            <table class="table table-sm align-middle mb-0">
              <thead class="text-uppercase small text-muted">
                <tr>
                  <th style="width:72px;">Item</th>
                  <th>Name</th>
                  <th class="text-center" style="width:150px;">Qty</th>
                  <th class="text-right" style="width:120px;">Price</th>
                  <th class="text-right" style="width:120px;">Subtotal</th>
                  <th style="width:70px;"></th>
                </tr>
              </thead>
              <tbody>
                <% items.forEach(i=>{ %>
                  <tr data-id="<%= i.id %>" data-variant-id="<%= i.variantId || '' %>">
                    <td><img src="<%= i.image %>" alt="<%- i.name.replace(/\"/g,'&quot;') %>" class="border" /></td>
                    <td style="line-height:18px; font-size:14px; font-weight:600;"> <a href="/details/<%= i.id %>/" class="text-dark"><%= i.name %></a> </td>
                    <td class="text-center">
                      <div class="qty-control">
                        <button class="dec-btn" aria-label="Decrease quantity">&minus;</button>
                        <input type="text" class="qty-input" value="<%= i.qty %>" />
                        <button class="inc-btn" aria-label="Increase quantity">+</button>
                      </div>
                    </td>
                    <td class="text-right">Rs. <%= i.price %></td>
                    <td class="text-right font-weight-bold">Rs. <span class="line-subtotal"><%= i.subtotal %></span></td>
                    <td class="text-right"><button class="remove-btn" aria-label="Remove item"><i class="fas fa-times"></i> Remove</button></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="cart-summary-box">
            <div class="summary-title">SUMMARY</div>
            <p class="mb-1 d-flex justify-content-between"><span class="text-muted">Items</span><span><%= itemCount %></span></p>
            <hr class="my-2"/>
            <p class="mb-0 d-flex justify-content-between align-items-center"><span class="summary-total">Total</span><strong>Rs. <span id="cart-total"><%= total %></span></strong></p>
            <p class="mt-1 mb-3 small text-muted">(Inclusive of all items pricing)</p>
            <a href="/shop/All/" class="btn btn-outline-dark btn-sm mb-2 w-100">Continue Shopping</a>
            <a href="/checkout/" class="btn btn-dark btn-block" style="font-weight:600; letter-spacing:.5px;">Checkout</a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
  <% if(items.length){ %>
  <div class="mobile-total-bar d-md-none" style="display:none;">
    <div>
      <div style="font-size:11px; letter-spacing:1px; opacity:.75;">TOTAL</div>
      <strong>Rs. <span id="mobile-total"><%= total %></span></strong>
    </div>
  <a class="mobile-checkout-btn" href="/checkout/">Checkout</a>
  </div>
  <% } %>

  <footer class="bg-dark text-white shadow" style="color:#fff;">
    <div class="container py-4">
      <div class="row">
        <div class="col-lg-6">
          <p class="small text-gray mb-0">&copy; <%= new Date().getFullYear() %> All rights reserved.</p>
          <p class="small text-gray mb-0">Crafted by <a class="text-white reset-anchor" href="https://gauravsah.com.np" target="_blank">Gaurav Sah</a></p>
        </div>
        <div class="col-lg-6 text-lg-right">
          <p class="small mb-0">FIND US &nbsp; <a href="https://facebook.com/allstrawhats/" target="_blank"><i class="fab fa-facebook-square mr-1" style="color:#f5f5f5;"></i></a> <a href="https://instagram.com/allstrawhats/" target="_blank"><i class="fab fa-instagram" style="color:#f5f5f5;"></i></a></p>
          <p class="text-sm text-gray mb-0"><a class="text-gray reset-anchor" href="mailto:info@allstrawhats.com" target="_blank"><i class="fas fa-envelope"></i> &nbsp;info@allstrawhats.com</a></p>
        </div>
      </div>
    </div>
  </footer>

</div><!-- /.page-wrapper -->

  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/js/bootstrap.min.js"></script>
  <script src="https://kit.fontawesome.com/d6db3c2373.js" crossorigin="anonymous"></script>
  <script>
    function getCookie(name){ var cookieValue=null; if(document.cookie && document.cookie!==''){ var cookies=document.cookie.split(';'); for(var i=0;i<cookies.length;i++){ var cookie=cookies[i].trim(); if(cookie.substring(0,name.length+1)===(name+'=')){ cookieValue=decodeURIComponent(cookie.substring(name.length+1)); break; }}} return cookieValue; }
    function uuidv4(){ return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,function(c){ var r=Math.random()*16|0,v=c=='x'?r:(r&0x3|0x8); return v.toString(16); }); }
  function animateQty(row){ const input=$(row).find('.qty-input'); input.addClass('qty-pulse'); setTimeout(()=>input.removeClass('qty-pulse'),600); }
  function setQty(id, qty, variantId){ if(qty<0) qty=0; const params = {productid:id, qty:qty}; if(variantId) params.variantid = variantId; $.get('/set_cart_qty/', params, function(){ if(qty===0){ const selector = variantId ? 'tr[data-id="'+id+'"][data-variant-id="'+variantId+'"]' : 'tr[data-id="'+id+'"]'; const tr=$(selector).addClass('removing'); tr.css('opacity','0'); setTimeout(()=>tr.remove(),350); } else { const selector = variantId ? 'tr[data-id="'+id+'"][data-variant-id="'+variantId+'"]' : 'tr[data-id="'+id+'"]'; const row=$(selector).get(0); const price=parseInt($(row).find('td').eq(3).text().replace(/[^0-9]/g,''),10); $(row).find('.line-subtotal').text(price*qty); $(row).find('.qty-input').val(qty); animateQty(row); } recalcTotals(); if($('.cart-table tbody tr').length===0){ setTimeout(()=>location.reload(),360); } }); }
    function recalcTotals(){ var total=0, count=0; $('.cart-table tbody tr').each(function(){ var qty=parseInt($(this).find('.qty-input').val(),10); var subtotal=parseInt($(this).find('.line-subtotal').text(),10); total+=subtotal; count+=qty; }); $('#cart-total').text(total); $('#mobile-total').text(total); if(total>0){ $('.mobile-total-bar').show(); } }
  $(document).on('click','.inc-btn',function(e){ e.preventDefault(); var row=$(this).closest('tr'); var id=row.data('id'); var variantId=row.data('variant-id')||null; var qty=parseInt(row.find('.qty-input').val(),10)+1; setQty(id, qty, variantId); });
  $(document).on('click','.dec-btn',function(e){ e.preventDefault(); var row=$(this).closest('tr'); var id=row.data('id'); var variantId=row.data('variant-id')||null; var qty=parseInt(row.find('.qty-input').val(),10)-1; setQty(id, qty, variantId); });
  $(document).on('blur','.qty-input',function(){ var row=$(this).closest('tr'); var id=row.data('id'); var variantId=row.data('variant-id')||null; var val=parseInt($(this).val(),10); if(isNaN(val)||val<0) val=0; setQty(id,val,variantId); });
    $(document).on('click','.remove-btn',function(e){ e.preventDefault(); var row=$(this).closest('tr'); var id=row.data('id'); var variantId=row.data('variant-id')||null; setQty(id,0,variantId); });
    $('#search-form-in-navbar').submit(function(e){ e.preventDefault(); var search_term=$('#search').val(); if(search_term){ window.location=window.location.origin+'/search/all/?q='+search_term; }});
    recalcTotals();
  </script>
</body>
</html>
