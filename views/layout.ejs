<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= (siteSetting && siteSetting.name) ? siteSetting.name : 'All Strawhats' %> - <%= title %></title>
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/staticfiles/style.blue.css">
  <link rel="stylesheet" href="/custom-theme.css?v=<%= Date.now() %>">
  <link rel="stylesheet" href="/staticfiles/floating-button.css">
  <link rel="stylesheet" href="/staticfiles/performance-animations.css">
  <!-- Product modal styles - Minimal Design -->
  <link rel="stylesheet" href="/staticfiles/product-modal-minimal.css">
  <style>
    .user-icon-wrapper {
      display: flex;
      align-items: center;
      margin-left: 12px;
    }
    .user-icon-btn {
      background: none;
      border: none;
      font-size: 28px;
      color: #333;
      cursor: pointer;
      padding: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      transition: all 0.2s;
      position: relative;
    }
    .user-icon-btn:hover {
      background: #f5f5f5;
      transform: scale(1.05);
    }
    .user-icon-btn.logged-in {
      color: #28a745;
    }
    .user-icon-btn.logged-in::after {
      content: '';
      position: absolute;
      bottom: 8px;
      right: 8px;
      width: 8px;
      height: 8px;
      background: #28a745;
      border: 2px solid white;
      border-radius: 50%;
    }
    @media (max-width: 768px) {
      .user-icon-btn {
        font-size: 24px;
        padding: 6px;
      }
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-light fixed-top py-0 px-2">
    <div class="container px-0 px-lg-3">
      <a class="navbar-brand" href="/">
        <img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" height="60" alt="<%= (siteSetting && siteSetting.name) || 'All Strawhats' %>">
      </a>
  <form method="POST" id="search-form-in-navbar">
        <div class="input-group search-input-group">
          <input class="form-control form-control-lg search" id="search" name="search" type="text" placeholder="Search Anime Products">
          <div class="input-group-append">
            <button class="input-group-text search-icon" id="search-icon-id"><i class="fas fa-search"></i></button>
          </div>
        </div>
      </form>
      <div class="user-icon-wrapper">
        <button id="userIcon" class="user-icon-btn" title="My Account" onclick="openUserModal()">
          <i class="fas fa-user-circle"></i>
        </button>
      </div>
      <ul class="navbar-nav ml-auto phone-in-navbar" style="display: none;">
        <li class="nav-item"><a class="nav-link" href="tel:9814789009"> <i class="fas fa-phone-alt"></i> 9814789009<sup><small> NP</small></sup></a></li>
      </ul>
    </div>
  </nav>
  <div style="height:80px;"></div>
  <div class="container py-3">
    <%- body %>
  </div>
  <% if(!(title && (title.toLowerCase().includes('cart') || title.toLowerCase().includes('checkout')))) { %>
    <%- include('partials/floating-cart') %>
  <% } %>
  <%- include('partials/user-auth-popup') %>
  <footer class="text-center text-muted py-4">
  <small>&copy; <%= new Date().getFullYear() %> <%= (siteSetting && siteSetting.name) || 'All Strawhats' %></small>
  </footer>
  <!-- Performance optimizations -->
  <script src="/staticfiles/performance-optimized.js" defer></script>
  <script src="/staticfiles/image-optimizer.js" defer></script>
  
  <!-- Core libraries -->
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  
  <!-- Optimized cart functionality -->
  <script src="/staticfiles/cart-optimized.js?v=1" defer></script>
  
  <!-- Legacy support -->
  <script src="/staticfiles/perf.js" defer></script>
</body>
</html>