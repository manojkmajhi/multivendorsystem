<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= (siteSetting && siteSetting.name) ? siteSetting.name : 'Multivendor System' %><% if(typeof seo !== 'undefined' && seo.site_tagline && title !== 'Home') { %> | <%= seo.site_tagline %><% } %><% if(title && title !== 'Home') { %> - <%= title %><% } %></title>
  <% if(typeof seo !== 'undefined' && seo.meta_description) { %>
  <meta name="description" content="<%= seo.meta_description %>" />
  <% } %>
  <% if(typeof seo !== 'undefined' && seo.meta_keywords) { %>
  <meta name="keywords" content="<%= seo.meta_keywords %>" />
  <% } %>
  <style>
    html{overflow-y:scroll;}html,body{height:100%;margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;}body{color:#111;background:#fff;}.navbar{background-color:#f8f9fa!important;box-shadow:0 5px 20px rgba(70,70,70,.4);padding:.5rem 1rem;position:fixed;top:0;left:0;right:0;z-index:1030;}.navbar .container{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;}.navbar-brand{display:inline-block;padding-top:.3125rem;padding-bottom:.3125rem;margin-right:1rem;}.navbar-brand img{height:60px;width:auto;}.search-input-group{display:flex;position:relative;flex-wrap:wrap;align-items:stretch;width:100%;}.search{border:1px solid #3f3f3f!important;border-radius:20px 0 0 20px!important;padding:.375rem .75rem;font-size:1rem;background-color:#fff;}.search-icon{border-radius:0 30px 30px 0!important;background-color:#fff!important;border:1px solid #3f3f3f!important;border-left:0!important;cursor:pointer;display:flex;align-items:center;padding:.375rem .75rem;}#search-form-in-navbar{width:28%;margin:0 auto;}.container{width:100%;padding-right:15px;padding-left:15px;margin-right:auto;margin-left:auto;}@media(min-width:576px){.container{max-width:540px;}}@media(min-width:768px){.container{max-width:720px;}}@media(min-width:992px){.container{max-width:960px;}}@media(min-width:1200px){.container{max-width:1140px;}}@media(max-width:768px){.navbar-brand img{height:45px;}#search-form-in-navbar{width:55%;}.search{height:35px;}}
  </style>
  <link rel="preconnect" href="https://maxcdn.bootstrapcdn.com" crossorigin>
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
  <link rel="preload" href="/css/style.blue.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link rel="stylesheet" href="/css/style.blue.css">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  </noscript>
  <link rel="stylesheet" href="/custom-theme.css?v=<%= Date.now() %>">
  <link rel="stylesheet" href="/css/floating-button.css">
  <link rel="stylesheet" href="/css/performance-animations.css">
  <link rel="stylesheet" href="/css/product-modal-minimal.css">
  <link rel="stylesheet" href="/css/loading-indicator.css">
  <style>
    .user-icon-wrapper {
      display: flex;
      align-items: center;
      margin-left: 12px;
    }
    .user-icon-btn {
      background: none;
      border: none;
      font-size: 28px;
      color: #333;
      cursor: pointer;
      padding: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      transition: all 0.2s;
      position: relative;
    }
    .user-icon-btn:hover {
      background: #f5f5f5;
      transform: scale(1.05);
    }
    .user-icon-btn.logged-in {
      color: #28a745;
    }
    .user-icon-btn.logged-in::after {
      content: '';
      position: absolute;
      bottom: 8px;
      right: 8px;
      width: 8px;
      height: 8px;
      background: #28a745;
      border: 2px solid white;
      border-radius: 50%;
    }
    @media (max-width: 768px) {
      .user-icon-btn {
        font-size: 24px;
        padding: 6px;
      }
    }
  </style>
</head>
<body>
  <div id="page-loader"></div>
  <nav class="navbar navbar-light fixed-top py-0 px-2">
    <div class="container px-0 px-lg-3">
      <a class="navbar-brand" href="/">
        <img src="<%= (siteSetting && siteSetting.logo_url) || '/images/brand.svg' %>" height="60" alt="<%= (siteSetting && siteSetting.name) || 'Multivendor System' %>">
      </a>
  <form method="POST" id="search-form-in-navbar">
        <div class="input-group search-input-group">
          <input class="form-control form-control-lg search" id="search" name="search" type="text" placeholder="Search Products">
          <div class="input-group-append">
            <button class="input-group-text search-icon" id="search-icon-id"><i class="fas fa-search"></i></button>
          </div>
        </div>
      </form>
      <div class="user-icon-wrapper">
        <button id="userIcon" class="user-icon-btn" title="My Account" onclick="openUserModal()">
          <i class="fas fa-user-circle"></i>
        </button>
      </div>
      <ul class="navbar-nav ml-auto phone-in-navbar" style="display: none;">
        <li class="nav-item"><a class="nav-link" href="tel:9811728715"> <i class="fas fa-phone-alt"></i> Need Help? 9811728715</a></li>
      </ul>
    </div>
  </nav>
  <div style="margin-top:80px;"></div>
  <div class="container py-3">
    <%- body %>
  </div>
  <% if(!(title && (title.toLowerCase().includes('cart') || title.toLowerCase().includes('checkout')))) { %>
    <%- include('partials/floating-cart') %>
  <% } %>
  <%- include('partials/user-auth-popup') %>
  <footer class="bg-dark text-white shadow" style="color: #fff; margin-top: 40px;">
    <div class="container py-4">
      <div class="row">
        <div class="col-lg-6">
          <p class="small mb-2"><a class="text-white" href="/sellers/"><i class="fas fa-users"></i> Our Sellers</a></p>
          <p class="small text-gray mb-0">© <%= new Date().getFullYear() %> All rights reserved.</p>
          <!-- <p class="small text-gray mb-0">Crafted by <a class="text-white reset-anchor" href="https://gauravsah.com.np" target="_blank">Gaurav Sah</a></p> -->
        </div>
        <div class="col-lg-6 text-lg-right">
          <p class="small mb-0">FIND US &nbsp;
            <a href="<%= (typeof socialLinks !== 'undefined' && socialLinks.facebook_url) ? socialLinks.facebook_url : '#' %>" target="_blank"><i class="fab fa-facebook-square mr-1" style="color: #f5f5f5;"></i></a>
            <a href="<%= (typeof socialLinks !== 'undefined' && socialLinks.instagram_url) ? socialLinks.instagram_url : '#' %>" target="_blank"><i class="fab fa-instagram" style="color: #f5f5f5;"></i></a>
          </p>
          <p class="text-sm text-gray mb-0"><a class="text-gray reset-anchor" href="mailto:<%= (typeof socialLinks !== 'undefined' && socialLinks.contact_email) ? socialLinks.contact_email : 'info@multivendor.com' %>" target="_blank"><i class="fas fa-envelope"></i> &nbsp;<%= (typeof socialLinks !== 'undefined' && socialLinks.contact_email) ? socialLinks.contact_email : 'info@multivendor.com' %></a></p>
          <p class="text-sm text-gray mb-0 mt-2"><a class="text-white reset-anchor" href="/track-order"><i class="fas fa-shipping-fast"></i> Track Order</a></p>
        </div>
      </div>
    </div>
  </footer>
  <script src="/js/font-loader.js"></script>
  <script src="/js/performance-boost.js" defer></script>
  <script src="/js/image-fast-load.js?v=<%= Date.now() %>" defer></script>
  <script src="/js/ultra-fast-cart.js" defer></script>
  <script src="/js/page-transition.js" defer></script>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <script src="/js/cart-optimized.js?v=2" defer></script>
</body>
</html>