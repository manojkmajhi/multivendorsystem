<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= category.name %> | Cropsay</title>
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.blue.css">
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
</head>
<body>
  <nav class="navbar navbar-light fixed-top py-0 px-2">
    <div class="container px-0 px-lg-3">
  <a class="navbar-brand" href="/"><img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" height="60" alt="<%= (siteSetting && siteSetting.name) || 'Cropsay' %>"></a>
  <form method="POST" id="search-form-in-navbar">
        <div class="input-group search-input-group">
          <input class="form-control form-control-lg search" id="search" name="search" type="text" placeholder="Search Farm Products">
          <div class="input-group-append">
            <button class="input-group-text search-icon" id="search-icon-id"><i class="fas fa-search"></i></button>
          </div>
        </div>
      </form>
      <ul class="navbar-nav ml-auto phone-in-navbar" style="display: none;">
        <li class="nav-item"><a class="nav-link" href="tel:9814789009"> <i class="fas fa-phone-alt"></i> 9814789009<sup><small> NP</small></sup></a></li>
      </ul>
    </div>
  </nav>
  <div style="height:80px;"></div>
  <div class="container py-3">
    <h1 class="h4 mb-3"><%= category.name %></h1>
    <div class="row">
      <% products.forEach(p => { %>
        <div class="col-md-3 col-6 mb-3">
          <div class="border p-2 h-100 d-flex flex-column">
            <img class="img-fluid mb-2 blur-up lazy-image" data-src="<%= p.image %>" src="/staticfiles/placeholder-blur.jpg" alt="<%= p.name %>" style="max-height:160px;object-fit:contain;" loading="lazy" decoding="async" />
            <h6 class="mb-1"><%= p.name %></h6>
            <p class="text-muted mb-2">Rs. <%= p.price %></p>
            <button class="btn btn-sm btn-dark mt-auto" onclick="addToCart('<%= p.id %>', 1, true)">Add to Cart</button>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <footer class="bg-dark text-white shadow" style="color: #fff; margin-top: 40px;">
    <div class="container py-4">
      <div class="row">
        <div class="col-lg-6">
          <p class="small mb-2"><a class="text-white" href="/farmers/"><i class="fas fa-users"></i> Our Farmers</a></p>
          <p class="small text-gray mb-0">© <%= new Date().getFullYear() %> All rights reserved.</p>
          <p class="small text-gray mb-0">Crafted by <a class="text-white reset-anchor" href="https://gauravsah.com.np" target="_blank">Gaurav Sah</a></p>
        </div>
        <div class="col-lg-6 text-lg-right">
          <p class="small mb-0">FIND US &nbsp;
            <a href="<%= (typeof socialLinks !== 'undefined' && socialLinks.facebook_url) ? socialLinks.facebook_url : 'https://facebook.com/cropsay/' %>" target="_blank"><i class="fab fa-facebook-square mr-1" style="color: #f5f5f5;"></i></a>
            <a href="<%= (typeof socialLinks !== 'undefined' && socialLinks.instagram_url) ? socialLinks.instagram_url : 'https://instagram.com/cropsay/' %>" target="_blank"><i class="fab fa-instagram" style="color: #f5f5f5;"></i></a>
          </p>
          <p class="text-sm text-gray mb-0"><a class="text-gray reset-anchor" href="mailto:<%= (typeof socialLinks !== 'undefined' && socialLinks.contact_email) ? socialLinks.contact_email : 'info@cropsay.com' %>" target="_blank"><i class="fas fa-envelope"></i> &nbsp;<%= (typeof socialLinks !== 'undefined' && socialLinks.contact_email) ? socialLinks.contact_email : 'info@cropsay.com' %></a></p>
          <p class="text-sm text-gray mb-0 mt-2"><a class="text-white reset-anchor" href="/track-order"><i class="fas fa-shipping-fast"></i> Track Order</a></p>
        </div>
      </div>
    </div>
  </footer>
  <script src="/js/cart-optimized.js?v=3" defer></script>
  <script>
    function addToCart(id, qty){
      window.addToCart(id, qty, true);
    }
    (function(){
      function minimalInit(){
        var imgs = document.querySelectorAll('img.lazy-image');
        imgs.forEach(function(img){ img.classList.add('blur-up');
          if ('loading' in HTMLImageElement.prototype) {
            img.addEventListener('load', function(){ img.classList.add('loaded'); });
            var ds = img.getAttribute('data-src'); if (ds && (!img.src || img.src.indexOf('placeholder-blur') !== -1)) img.src = ds;
          } else {
            var onScroll = function(){ if (img.getBoundingClientRect().top < window.innerHeight + 200 && !img.classList.contains('loaded')){ var s=img.getAttribute('data-src'); if(s){ var t=new Image(); t.onload=function(){ img.src=s; img.classList.add('loaded'); }; t.src=s; } window.removeEventListener('scroll', onScroll);} };
            window.addEventListener('scroll', onScroll, {passive:true}); onScroll();
          }
        });
      }
      if (window.ImageOptimizer && typeof window.ImageOptimizer.init === 'function') {
        try{ window.ImageOptimizer.addOptimizationCSS(); }catch(e){}
        try{ window.ImageOptimizer.init(); }catch(e){}
      } else {
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', minimalInit);
        else minimalInit();
      }
    })();
  </script>
</body>
</html>