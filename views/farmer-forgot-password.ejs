<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password - <%= siteSetting.name || 'Cropsay' %></title>
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
  <link rel="stylesheet" href="/custom-theme.css">
  <style>
    body { background: #f8f9fa; }
    
    .card { border: none; border-radius: 8px; }
    
    .step { display: none; }
    .step.active { display: block; }
    
    .step-indicator {
      display: flex;
      gap: 6px;
      margin-bottom: 20px;
      justify-content: center;
    }
    
    .step-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #ddd;
      transition: all 0.2s;
    }
    
    .step-dot.active {
      background: #333;
      width: 18px;
      border-radius: 3px;
    }
    
    .otp-input-boxes {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 15px;
      flex-wrap: nowrap;
    }
    
    .otp-box {
      width: 48px;
      height: 56px;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 22px;
      font-weight: 600;
      text-align: center;
      font-family: 'Courier New', monospace;
      transition: all 0.2s;
    }
    
    .otp-box:focus {
      outline: none;
      border-color: #333;
      box-shadow: 0 0 0 2px rgba(0,0,0,0.05);
    }
    
    .error-message {
      color: #dc3545;
      font-size: 12px;
      margin-top: 8px;
      text-align: center;
      display: none;
    }
    
    .error-message.show {
      display: block;
    }
    
    .info-text {
      font-size: 12px;
      color: #666;
      text-align: center;
      margin-top: 8px;
    }

    .success-container {
      text-align: center;
      padding: 30px 20px;
    }

    .success-icon {
      font-size: 56px;
      color: #28a745;
      margin-bottom: 15px;
      animation: scaleIn 0.4s ease-out;
    }

    .success-title {
      font-size: 22px;
      color: #333;
      font-weight: 600;
      margin-bottom: 10px;
    }

    .success-message {
      font-size: 14px;
      color: #666;
      margin-bottom: 20px;
      line-height: 1.5;
    }

    .success-button {
      background-color: #28a745;
      color: white;
      padding: 10px 30px;
      border: none;
      border-radius: 5px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: background-color 0.3s;
    }

    .success-button:hover {
      background-color: #218838;
      text-decoration: none;
      color: white;
    }

    @keyframes scaleIn {
      from {
        transform: scale(0.8);
        opacity: 0;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }

    .form-group label {
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 6px;
    }

    .form-control {
      font-size: 14px;
      border-radius: 5px;
      border: 1px solid #ddd;
      margin-bottom: 10px;
    }

    .form-group {
      margin-bottom: 10px;
    }

    .btn-dark {
      background-color: #333;
      border-color: #333;
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .btn-outline-secondary {
      font-size: 14px;
      margin-bottom: 8px;
    }

    .login-link {
      font-size: 12px;
      margin-top: 12px;
      text-align: center;
    }

    .login-link a {
      color: #666;
      text-decoration: none;
      transition: color 0.2s;
    }

    .login-link a:hover {
      color: #333;
      text-decoration: underline;
    }

    .password-field {
      position: relative;
    }
    .password-toggle {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      border: none;
      background: transparent;
      cursor: pointer;
      color: #6c757d;
      padding: 5px;
      z-index: 10;
    }
    .password-toggle:hover {
      color: #495057;
    }
    .password-input {
      padding-right: 40px;
    }


    @media (max-width: 768px) {
      .card { border-radius: 12px; }
      .card-body { padding: 30px 20px !important; }
      h3 { font-size: 22px; }
      .form-group { margin-bottom: 15px; }
      .form-group label { font-size: 12px; }
      .form-control { padding: 10px 12px; font-size: 14px; }
      .btn-dark, .btn-outline-secondary, .btn-link { padding: 10px 16px; font-size: 13px; }
      .step-indicator { gap: 6px; margin-bottom: 20px; }
      .otp-input-boxes { gap: 8px; }
      .otp-box { width: 45px; height: 55px; font-size: 20px; }
      .info-text { font-size: 12px; }
      .text-center.mt-3 { margin-top: 15px !important; }
      .text-center.mt-3 a { display: block; margin-bottom: 8px; }
    }

    @media (max-width: 480px) {
      .col-md-5 { width: 100%; max-width: 100%; padding: 0 15px; }
      .card-body { padding: 25px 15px !important; }
      h3 { font-size: 20px; margin-bottom: 15px !important; }
      .step-indicator { gap: 5px; margin-bottom: 18px; }
      .step-dot { width: 6px; height: 6px; }
      .step-dot.active { width: 18px; }
      .form-group { margin-bottom: 12px; }
      .form-group label { font-size: 11px; margin-bottom: 6px; }
      .form-control { padding: 9px 10px; font-size: 13px; }
      .btn-dark, .btn-outline-secondary, .btn-link { padding: 9px 12px; font-size: 12px; }
      .btn-action { margin-top: 10px; }
      .otp-input-boxes { gap: 6px; margin-bottom: 12px; }
      .otp-box { width: 40px; height: 50px; font-size: 18px; border-radius: 6px; }
      .info-text { font-size: 11px; margin-top: 8px; }
      .text-center.mt-3 { margin-top: 12px !important; }
      .back-link { font-size: 12px; }
    }

    @media (max-width: 360px) {
      .card-body { padding: 20px 12px !important; }
      h3 { font-size: 18px; margin-bottom: 12px !important; }
      .otp-box { width: 35px; height: 45px; font-size: 16px; }
      .form-control { padding: 8px 8px; font-size: 12px; }
      .btn-dark, .btn-outline-secondary, .btn-link { padding: 8px 10px; font-size: 11px; }
    }
  </style>
</head>
<body class="bg-light">
  <div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
      <div class="col-md-5">
        <div class="card shadow">
          <div class="card-body p-4">
            <h3 class="text-center mb-3">Reset Password</h3>
            
            <div class="step-indicator">
              <div class="step-dot active" id="step1Dot"></div>
              <div class="step-dot" id="step2Dot"></div>
              <div class="step-dot" id="step3Dot"></div>
              <div class="step-dot" id="step4Dot"></div>
            </div>

            <div class="error-message" id="errorMsg"></div>
            
            <!-- Step 1: Email -->
            <div id="step1" class="step active">
              <form id="emailForm">
                <div class="form-group">
                  <label>Email (@cropsay.com)</label>
                  <input type="email" id="email" class="form-control" placeholder="yourname@cropsay.com" required pattern=".*@cropsay\.com$">
                </div>
                <button type="submit" class="btn btn-dark btn-block">Send Reset OTP</button>
              </form>
              <div class="info-text">We'll send a 6-digit code to your email</div>
            </div>

            <!-- Step 2: Verify OTP -->
            <div id="step2" class="step">
              <div class="otp-input-section">
                <label class="info-text" id="otpEmailDisplay"></label>
                <div class="otp-input-boxes" id="otpBoxes"></div>
                <input type="hidden" id="otpFullValue">
                <div class="error-message" id="otpErrorMsg"></div>
                <div class="info-text">Enter the 6-digit code from your email</div>
              </div>
              <button type="button" class="btn btn-dark btn-block btn-action" id="verifyOtpBtn">Verify OTP</button>
              <button type="button" class="btn btn-outline-secondary btn-block btn-action" id="resendOtpBtn">Resend OTP</button>
            </div>

            <!-- Step 3: New Password -->
            <div id="step3" class="step">
              <form id="resetForm">
                <div class="form-group">
                  <label>New Password</label>
                  <div class="password-field">
                    <input type="password" id="password" class="form-control password-input" minlength="6" required>
                    <button type="button" class="password-toggle" onclick="togglePassword('password')" tabindex="-1">
                      <span id="password-eye">👁</span>
                    </button>
                  </div>
                </div>
                <div class="form-group">
                  <label>Confirm Password</label>
                  <div class="password-field">
                    <input type="password" id="confirm_password" class="form-control password-input" minlength="6" required>
                    <button type="button" class="password-toggle" onclick="togglePassword('confirm_password')" tabindex="-1">
                      <span id="confirm_password-eye">👁</span>
                    </button>
                  </div>
                </div>
                <button type="submit" class="btn btn-dark btn-block">Reset Password</button>
                <button type="button" class="btn btn-outline-secondary btn-block btn-action" onclick="goBack(2)">Back</button>
              </form>
            </div>

            <!-- Step 4: Success -->
            <div id="step4" class="step success-container">
              <div class="success-icon">✓</div>
              <div class="success-title">Success!</div>
              <div class="success-message">
                Your password has been reset. Redirecting to login...
              </div>
              <a href="/farmers/login" class="success-button">Go to Login</a>
            </div>

            <div class="login-link">
              <a href="/farmers/login">← Back to Login</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script>
    let userEmail = '';
    let otpBoxes = [];

    function createOtpBoxes() {
      const container = $('#otpBoxes');
      container.empty();
      otpBoxes = [];
      
      for (let i = 0; i < 6; i++) {
        const box = $('<input class="otp-box" type="text" maxlength="1" inputmode="numeric">');
        container.append(box);
        otpBoxes.push(box);
        
        box.on('input', function(e) {
          if (this.value && !/[0-9]/.test(this.value)) {
            this.value = '';
            return;
          }
          
          if (this.value && i < 5) {
            otpBoxes[i + 1][0].focus();
          }
          
          updateOtpValue();
        });
        
        box.on('keydown', function(e) {
          if (e.key === 'Backspace' && !this.value && i > 0) {
            otpBoxes[i - 1][0].focus();
          }
          if (e.key === 'Enter' && $('#otpFullValue').val().length === 6) {
            e.preventDefault();
            $('#verifyOtpBtn').click();
          }
        });
        
        box.on('paste', function(e) {
          e.preventDefault();
          const pastedText = (e.originalEvent || e).clipboardData.getData('text');
          const digits = pastedText.replace(/\D/g, '').slice(0, 6);
          
          if (digits.length > 0) {
            for (let j = 0; j < digits.length && j < 6; j++) {
              otpBoxes[j].val(digits[j]);
            }
            updateOtpValue();
            const nextIndex = Math.min(digits.length, 5);
            otpBoxes[nextIndex][0].focus();
          }
        });
      }
    }

    function updateOtpValue() {
      const otp = otpBoxes.map(b => b.val()).join('');
      $('#otpFullValue').val(otp);
    }

    function showError(message, fieldId = 'errorMsg') {
      const errorEl = $('#' + fieldId);
      errorEl.text(message).addClass('show');
      setTimeout(() => errorEl.removeClass('show'), 5000);
    }

    function updateStepIndicator(step) {
      $('.step-dot').removeClass('active');
      for (let i = 1; i <= step; i++) {
        $('#step' + i + 'Dot').addClass('active');
      }
    }

    function showStep(stepNum) {
      $('.step').removeClass('active');
      $('#step' + stepNum).addClass('active');
      updateStepIndicator(stepNum);
      $('#errorMsg').removeClass('show');
    }

    function goBack(currentStep) {
      if (currentStep === 2) {
        showStep(1);
        $('#email').focus();
        const btn = $('#emailForm').find('button');
        btn.prop('disabled', false).text('Send Reset OTP');
      } else if (currentStep === 3) {
        showStep(2);
        if (otpBoxes.length > 0) {
          otpBoxes[0][0].focus();
        }
      }
    }

    // Step 1: Email
    $('#emailForm').on('submit', function(e) {
      e.preventDefault();
      userEmail = $('#email').val();
      const btn = $(this).find('button');
      
      btn.prop('disabled', true).text('Sending...');
      
      $.post('/api/farmers/forgot-password', { email: userEmail })
        .done(function(res) {
          if (res.success) {
            createOtpBoxes();
            $('#otpEmailDisplay').text('Code sent to: ' + userEmail);
            showStep(2);
            otpBoxes[0][0].focus();
          } else {
            showError(res.message || 'Failed to send OTP');
            btn.prop('disabled', false).text('Send Reset OTP');
          }
        })
        .fail(function(xhr, status, error) {
          console.error('AJAX Error:', error, xhr);
          showError('Error sending OTP. Please try again or check if email exists.');
          btn.prop('disabled', false).text('Send Reset OTP');
        });
    });

    // Step 2: Resend OTP
    $('#resendOtpBtn').on('click', function() {
      const btn = $(this);
      btn.prop('disabled', true).text('Sending...');
      
      $.post('/api/farmers/forgot-password', { email: userEmail })
        .done(function(res) {
          if (res.success) {
            showError('OTP resent to your email', 'otpErrorMsg');
            otpBoxes.forEach(box => box.val(''));
            updateOtpValue();
            otpBoxes[0][0].focus();
            btn.prop('disabled', false).text('Resend OTP');
          } else {
            showError(res.message || 'Failed to resend OTP', 'otpErrorMsg');
            btn.prop('disabled', false).text('Resend OTP');
          }
        })
        .fail(function() {
          showError('Error resending OTP', 'otpErrorMsg');
          btn.prop('disabled', false).text('Resend OTP');
        });
    });

    // Step 2: Verify OTP
    $('#verifyOtpBtn').on('click', function() {
      const otp = $('#otpFullValue').val();
      
      if (otp.length !== 6) {
        showError('Please enter complete 6-digit code', 'otpErrorMsg');
        return;
      }
      
      const btn = $(this);
      btn.prop('disabled', true).text('Verifying...');
      
      $.post('/api/farmers/verify-reset-otp', { email: userEmail, otp: otp })
        .done(function(res) {
          if (res.success) {
            showStep(3);
            $('#password').focus();
          } else {
            showError(res.message || 'Invalid OTP', 'otpErrorMsg');
            btn.prop('disabled', false).text('Verify OTP');
            otpBoxes.forEach(box => box.val(''));
            updateOtpValue();
            otpBoxes[0][0].focus();
          }
        })
        .fail(function() {
          showError('Error verifying OTP. Please try again.', 'otpErrorMsg');
          btn.prop('disabled', false).text('Verify OTP');
        });
    });

    // Step 3: Reset Password
    $('#resetForm').on('submit', function(e) {
      e.preventDefault();
      
      const password = $('#password').val();
      const confirm = $('#confirm_password').val();
      
      if (password !== confirm) {
        showError('Passwords do not match');
        return;
      }
      
      if (password.length < 6) {
        showError('Password must be at least 6 characters');
        return;
      }
      
      const btn = $(this).find('button[type="submit"]');
      btn.prop('disabled', true).text('Resetting...');
      
      $.post('/api/farmers/reset-password', { email: userEmail, password: password })
        .done(function(res) {
          if (res.success) {
            showStep(4);
            // Redirect to login after 3 seconds
            setTimeout(function() {
              window.location = '/farmers/login';
            }, 3000);
          } else {
            showError(res.message || 'Reset failed');
            btn.prop('disabled', false).text('Reset Password');
          }
        })
        .fail(function() {
          showError('Error resetting password. Please try again.');
          btn.prop('disabled', false).text('Reset Password');
        });
    });
    
    function togglePassword(fieldId) {
      const field = document.getElementById(fieldId);
      const eye = document.getElementById(fieldId + '-eye');
      
      if (field.type === 'password') {
        field.type = 'text';
        eye.textContent = '🙈';
      } else {
        field.type = 'password';
        eye.textContent = '👁';
      }
    }
  </script>
</body>
</html>
