<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%= product.name %> | Multivendor System</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/css/lightbox.min.css" />
  <link rel="stylesheet" href="/css/style.blue.css">
  <link rel="stylesheet" href="/custom-theme.css?v=<%= Date.now() %>">
  <link rel="stylesheet" href="/css/floating-button.css" />
  <link rel="stylesheet" href="/css/product-quickview.css?v=1" />
  <link rel="stylesheet" href="/css/image-loading.css?v=<%= Date.now() %>" />
  <link rel="stylesheet" href="/css/recommendations.css?v=<%= Date.now() %>" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <style>
    html, body {
      height: 100%;
      margin: 0;
    }
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .main-content {
      flex: 1 0 auto;
    }
    footer {
      flex-shrink: 0;
      margin-top: 40px;
    }
    .thumbs-img-details-page{margin-left:-4px !important; height:100px; width:100px;}
    .owl-thumbs::-webkit-scrollbar{width:0px;}
    @media only screen and (max-width: 600px){
      .thumbs-img-details-page{margin-left:0px !important;}
      .details-texts h1{font-size:25px !important;}
      .details-texts .text-uppercase{font-size:15px !important;}
      .details-texts .lead{font-weight:500; font-size:15px !important;}
    }
    .show-added-message{position:absolute; left:0; top:0; background:#000; color:#fff; font-size:11px; padding:2px 4px; display:none;}
    /* Added: consistent product card + related styling */
    .product-grid .product{background:#f8f8f8; border:1px solid #f8f8f8; min-height:100%; transition:box-shadow .25s, transform .25s; border-radius:2px;}
    .product-grid .product:hover{box-shadow:0 6px 18px -6px rgba(0,0,0,.12); transform:translateY(-3px);}    
    .product-grid .product img{height:150px; width:100%; object-fit:contain; transition:transform .3s; display:block;}
    .product-grid .product:hover img{transform:scale(1.04);}    
    .product-grid .product h5{font-size:13px; line-height:16px; font-weight:600; margin-top:0; min-height:32px;}
    .product-grid .product h5 a{color:#000; text-decoration:none;}
    .product-grid .btn-dark{background:#000; border-color:#000; font-size:12px;}
    .product-grid .btn-outline-dark{border-color:#000; font-size:12px;}
    .related-products-wrapper{padding-top:5px; padding-bottom:25px;}
    h2.related-title{font-size:13px; letter-spacing:1.5px; font-weight:700; margin-bottom:14px;}

  </style>
</head>
<body>
  <div class="main-content">
  <nav class="navbar navbar-light fixed-top py-0 px-2">
    <div class="container px-0 px-lg-3">
  <a class="navbar-brand" href="/"><img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" height="60"></a>
  <form method="POST" id="search-form-in-navbar">
        <div class="input-group search-input-group">
          <input class="form-control form-control-lg search" id="search" name="search" type="text" placeholder="Search Products">
          <div class="input-group-append">
            <button class="input-group-text search-icon" id="search-icon-id"><i class="fas fa-search"></i></button>
          </div>
        </div>
      </form>
      <ul class="navbar-nav ml-auto phone-in-navbar" style="display: none;">
        <li class="nav-item"><a class="nav-link" href="tel:9811728715"> <i class="fas fa-phone-alt"></i> Need Help? 9811728715</a></li>
      </ul>
    </div>
  </nav>

      <!-- Shared floating cart -->
      <%- include('partials/floating-cart') %>

  <div class="container-fluid" style="margin-top: 80px;">
  <section class="py-2 py-md-5">
    <div class="container px-0 px-sm-2 px-md-3">
      <div class="row mb-5">
        <div class="col-lg-6">
          <!-- PRODUCT SLIDER-->
          <div class="row m-sm-0">
            <div class="col-sm-2 p-sm-0 order-2 order-sm-1 mt-2 mt-sm-0 text-center">
              <i class="fas fa-caret-up caret" style="display:none;"></i>
              <div class="owl-thumbs d-flex flex-row flex-sm-column" id="content" style="max-height: 450px; overflow-y: auto;" data-slider-id="1">
                <div class="owl-thumb-item flex-fill mb-0 mb-sm-1 mr-1 mr-sm-0 active"><img class="thumbs-img-details-page" src="<%= product.image %>" loading="eager" fetchpriority="high"></div>
              </div>
              <i class="fas fa-caret-down caret" style="display:none;"></i>
            </div>
            <div class="col-sm-10 order-1 order-sm-2">
              <div class="owl-carousel product-slider" data-slider-id="1" style="position: relative;">
                <div class="item" style="position: relative;">
                  <% 
                    const isOutOfStock = product.has_variants 
                      ? (product.variants && product.variants.reduce((sum, v) => sum + (v.stock || 0), 0) <= 0)
                      : (product.stock <= 0);
                  %>
                  <img class="img-fluid" src="<%= product.image %>" style="width: 100% !important; <%= isOutOfStock ? 'filter: grayscale(80%) opacity(60%);' : '' %>" loading="eager" fetchpriority="high" decoding="async">
                  <% if (isOutOfStock) { %>
                    <div class="out-of-stock-overlay" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(220, 38, 38, 0.9); color: white; padding: 0.75rem 1.5rem; font-weight: 700; font-size: 16px; border-radius: 4px; box-shadow: 0 4px 10px rgba(0,0,0,0.15); pointer-events: none; z-index: 10; text-transform: uppercase; letter-spacing: 1px; white-space: nowrap;">
                      Out of Stock
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- PRODUCT DETAILS-->
        <div class="col-lg-6 details-texts">
          <h1 class="mt-3 mb-1 mb-md-2"><%= product.name %></h1>
          <% if(!product.has_variants) { %>
            <p class="lead mb-2">Rs. <%= product.price %></p>
          <% } else { %>
            <p class="lead mb-2" id="variantPrice">Rs. <%= product.price %></p>
          <% } %>
          <% const shortDesc = product.short_description || ''; %>
          <% if(shortDesc){ %>
            <p class="text-muted" style="font-size:14px; line-height:1.45; max-width:620px;">
              <%= shortDesc.length > 300 ? shortDesc.substring(0,297)+'…' : shortDesc %>
            </p>
          <% } %>

          <!-- Variant Selector -->
          <% if(product.has_variants && product.variants && product.variants.length > 0) { %>
            <div style="margin-bottom: 1.5rem;">
              <% 
                const attrs = {};
                product.variants.forEach(v => {
                  const combo = v.attribute_combination || {};
                  Object.keys(combo).forEach(key => {
                    if (!attrs[key]) attrs[key] = new Set();
                    attrs[key].add(combo[key]);
                  });
                });
              %>
              <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                <% Object.keys(attrs).forEach(attrName => { %>
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <label style="font-weight: 600; font-size: 14px; text-transform: capitalize; margin: 0;"><%= attrName %>:</label>
                    <select class="variant-select" data-attr="<%= attrName %>" style="padding: 0.4rem 0.75rem; border: 1px solid #ddd; border-radius: 4px; font-size: 14px; min-width: 100px;">
                      <option value="">Select</option>
                      <% Array.from(attrs[attrName]).forEach(val => { %>
                        <option value="<%= val %>"><%= val %></option>
                      <% }); %>
                    </select>
                  </div>
                <% }); %>
              </div>
              <div id="variantInfo" style="display: none; padding: 0.5rem 0; margin-top: 0.5rem;">
                <div style="font-size: 13px; color: #666;">
                  <span>Stock: <strong id="variantStock"></strong></span> | 
                  <span>SKU: <span id="variantSku"></span></span>
                </div>
              </div>
            </div>
          <% } %>

          <div class="row align-items-stretch mb-4">
            <div class="col-sm-5 pr-sm-0">
              <div class="border d-flex align-items-center justify-content-between py-1 px-3 bg-white border-white" style="<%= product.stock <= 0 && !product.has_variants ? 'opacity: 0.5; pointer-events: none;' : '' %>">
                <span class="small text-uppercase text-gray mr-4 no-select">Quantity</span>
                <div class="quantity">
                  <button class="dec-btn p-0"><i class="fas fa-caret-left"></i></button>
                  <input class="form-control border-0 shadow-0 p-0" type="text" id="product_qty" value="1">
                  <button class="inc-btn p-0"><i class="fas fa-caret-right"></i></button>
                </div>
              </div>
            </div>
            <div class="col-sm-3 pl-sm-0">
              <button class="btn btn-dark btn-sm btn-block h-100 d-flex align-items-center justify-content-center px-0" 
                      id="product-add-to-cart" 
                      value="<%= product.id %>" 
                      <%= product.has_variants ? 'disabled' : (product.stock <= 0 ? 'disabled' : '') %>>
                <%= product.has_variants ? 'Select options' : (product.stock <= 0 ? 'Out of Stock' : 'Add to cart') %>
              </button>
            </div>
          </div>

          <ul style="list-style: none;" class="descripton-ul pl-0 text-uppercase">
            <% if (product.long_description) { %>
              <% /* If long_description has bullet-friendly lines without HTML, derive bullets */ %>
              <% if (!/<[a-z][\s\S]*>/i.test(product.long_description.trim())) { 
                   const lines = product.long_description.split('\n').filter(l=>l.trim());
                   lines.forEach(line=>{ line=line.trim().replace(/^[✓✔☑•\-*]\s*/, ''); %>
                     <li><i class="fas fa-check"></i> <%= line %></li>
              <% }); } %>
            <% } %>
          </ul>
          <% if (product.long_description && /<[a-z][\s\S]*>/i.test(product.long_description)) { %>
            <div class="mt-3" style="font-size:14px; line-height:1.55;" id="product-long-html">
              <%- product.long_description %>
            </div>
          <% } %>


          <div class="d-flex flex-wrap align-items-center mb-3" style="font-size: 14px; gap: 2rem;">
            <div class="d-flex align-items-center">
              <span class="text-muted mr-2">Category:</span>
              <a class="text-dark font-weight-medium" href="/shop/<%= product.category %>/" style="text-decoration: none;"><%= product.category %></a>
            </div>
            <% if (product.seller) { %>
              <div class="d-flex align-items-center">
                <span class="text-muted mr-2">Sold by:</span>
                <a class="text-dark font-weight-medium" href="/sellers/<%= product.seller_id %>/" style="text-decoration: none;">
                  <%= product.seller.business_name || product.seller.full_name %>
                </a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
      <!-- Frequently Bought Together Interactive Bundle Builder -->
      <% if(typeof fbtProduct !== 'undefined' && fbtProduct) { %>
        <div class="fbt-wrapper mt-5">
          <div class="rec-section-header">
            <span class="rec-subtitle">Frequently Bought Together</span>
            <h3 class="rec-title">Perfect Combo</h3>
          </div>
          <div class="fbt-grid">
            <div class="fbt-items-container">
              <!-- Current Product -->
              <div class="fbt-item-card disabled">
                <div class="fbt-checkbox-container">
                  <input type="checkbox" checked disabled class="fbt-custom-checkbox">
                </div>
                <img src="<%= product.image %>" alt="<%= product.name %>" class="fbt-item-img">
                <div class="fbt-item-title"><%= product.name %></div>
                <div class="fbt-item-price">Rs. <%= product.price %></div>
              </div>

              <div class="fbt-connector">+</div>

              <!-- Recommended Product -->
              <div class="fbt-item-card" id="fbt-rec-card">
                <div class="fbt-checkbox-container">
                  <input type="checkbox" id="fbt-toggle-checkbox" checked class="fbt-custom-checkbox">
                </div>
                <img src="<%= fbtProduct.image %>" alt="<%= fbtProduct.name %>" class="fbt-item-img">
                <div class="fbt-item-title"><a href="/details/<%= fbtProduct.id %>/"><%= fbtProduct.name %></a></div>
                <div class="fbt-item-price">Rs. <%= fbtProduct.price %></div>
              </div>
            </div>

            <div class="fbt-connector">=</div>

            <!-- FBT Action Summary -->
            <div class="fbt-action-panel">
              <div class="fbt-total-label">Total Price</div>
              <div class="fbt-total-price">Rs. <span id="fbt-bundle-total-price"><%= parseFloat(product.price) + parseFloat(fbtProduct.price) %></span></div>
              <button class="btn btn-bundle-buy" id="fbt-add-bundle-btn">
                <i class="fas fa-shopping-basket"></i> Add Bundle to Cart
              </button>
            </div>
          </div>
        </div>

        <script>
          $(document).ready(function() {
            const basePrice = parseFloat("<%= product.price %>");
            const recPrice = parseFloat("<%= fbtProduct.price %>");
            
            $('#fbt-toggle-checkbox').change(function() {
              const card = $('#fbt-rec-card');
              if (this.checked) {
                card.removeClass('disabled');
                $('#fbt-bundle-total-price').text((basePrice + recPrice).toFixed(2));
              } else {
                card.addClass('disabled');
                $('#fbt-bundle-total-price').text(basePrice.toFixed(2));
              }
            });

            $('#fbt-add-bundle-btn').click(async function() {
              const btn = $(this);
              btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Adding...');
              
              try {
                // Add current product
                const qty = parseInt($('#product_qty').val()) || 1;
                // Check if variants are defined for current product
                if (productData.has_variants && !selectedVariant) {
                  alert('Please select current product variants first!');
                  btn.prop('disabled', false).html('<i class="fas fa-shopping-basket"></i> Add Bundle to Cart');
                  return;
                }
                const currentVariantId = (typeof selectedVariant !== 'undefined' && selectedVariant) ? selectedVariant.id : null;
                
                await $.get('/add_to_cart/?productid=' + "<%= product.id %>" + '&qty=' + qty + (currentVariantId ? '&variantid=' + currentVariantId : ''));
                
                // Add recommended product if checked
                const includeRec = $('#fbt-toggle-checkbox').is(':checked');
                if (includeRec) {
                  await $.get('/add_to_cart/?productid=' + "<%= fbtProduct.id %>" + '&qty=1');
                }
                
                // Animation & success alert
                btn.removeClass('btn-bundle-buy').addClass('btn-success').html('<i class="fas fa-check"></i> Added Bundle!');
                if (typeof updateCartCount === 'function') {
                  updateCartCount();
                } else if (typeof updateCartFloatingIcon === 'function') {
                  updateCartFloatingIcon();
                } else {
                  // Fallback refresh or cookie reading
                  window.location.reload();
                }
                
                setTimeout(() => {
                  btn.removeClass('btn-success').addClass('btn-bundle-buy').prop('disabled', false).html('<i class="fas fa-shopping-basket"></i> Add Bundle to Cart');
                }, 2500);

              } catch(e) {
                console.error(e);
                alert('Failed to add bundle to cart.');
                btn.prop('disabled', false).html('<i class="fas fa-shopping-basket"></i> Add Bundle to Cart');
              }
            });
          });
        </script>
      <% } %>

      <!-- TABS FOR HYBRID RECOMMENDATIONS -->
      <div class="mt-5">
        <div class="rec-tabs-nav">
          <button class="rec-tab-trigger active" data-target="#tab-similar">Similar Products</button>
          <% if(typeof sellerProducts !== 'undefined' && sellerProducts.length > 0) { %>
            <button class="rec-tab-trigger" data-target="#tab-seller">More from this Seller</button>
          <% } %>
        </div>

        <!-- Tab 1: Similar Products -->
        <div class="rec-tab-content active" id="tab-similar">
          <% var __related = (typeof related !== 'undefined' && Array.isArray(related)) ? related : []; %>
          <% if(__related.length){ %>
            <div class="row product-grid related-products-grid">
              <% __related.forEach(function(r){ %>
                <div class="col-xl-2 col-lg-4 col-md-4 col-6 px-1 py-1">
                  <div class="rec-product-card pt-2">
                    <div class="position-relative mb-1">
                      <div class="<%= r.id %>-added-message show-added-message show-added-message-details" style="display:none; position:absolute; left:4px; top:4px; background:#000; color:#fff; font-size:11px; padding:2px 5px; border-radius:3px; z-index:2;"></div>
                      <a class="d-block" href="/details/<%= r.id %>/">
                        <% 
                          const isRelatedOutOfStock = r.has_variants 
                            ? (r.variants ? r.variants.reduce((sum, v) => sum + (v.stock || 0), 0) <= 0 : false)
                            : (r.stock <= 0);
                        %>
                        <div class="rec-img-container" style="position: relative;">
                          <img src="<%= r.image %>" alt="<%- r.name.replace(/\"/g,'&quot;') %>" loading="lazy" decoding="async" style="<%= isRelatedOutOfStock ? 'filter: grayscale(80%) opacity(60%);' : '' %>">
                          <div class="skeleton-loader"></div>
                          <% if (isRelatedOutOfStock) { %>
                            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(220, 38, 38, 0.9); color: #fff; font-size: 10px; font-weight: 700; padding: 4px 8px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.5px; z-index: 3; pointer-events: none; white-space: nowrap; box-shadow: 0 2px 6px rgba(0,0,0,0.15);">Out of Stock</div>
                          <% } %>
                        </div>
                      </a>
                    </div>
                    <div class="rec-card-body">
                      <div class="rec-category-tag"><%= r.category || 'Similar' %></div>
                      <h5 class="rec-product-title">
                        <a href="/details/<%= r.id %>/"><%= r.name %></a>
                      </h5>
                      <div class="rec-price-row">
                        <span class="rec-price">Rs. <%= r.price %></span>
                        <div class="rec-actions">
                          <button class="rec-action-btn rec-view-btn quick-view-btn" 
                                  data-id="<%= r.id %>" 
                                  data-image="<%= r.image %>" 
                                  data-name="<%- r.name %>" 
                                  data-price="<%= r.price %>" 
                                  data-short-description="<%- r.short_description || '' %>" 
                                  data-link="/details/<%= r.id %>/" 
                                  data-has-variants="<%= r.has_variants ? 'true' : 'false' %>"
                                  title="Quick View">
                            <i class="fas fa-expand"></i>
                          </button>
                          <% if (isRelatedOutOfStock) { %>
                            <button class="rec-action-btn rec-add-btn" disabled style="opacity: 0.5; cursor: not-allowed; background: #999; border-color: #999;" title="Out of Stock"><i class="fas fa-times"></i></button>
                          <% } else if(r.has_variants) { %>
                            <a href="/details/<%= r.id %>/" class="rec-action-btn rec-add-btn" title="Select options"><i class="fas fa-cog"></i></a>
                          <% } else { %>
                            <button class="rec-action-btn rec-add-btn" onclick="addToCart('<%= r.id %>','1', false)" title="Add to Cart"><i class="fas fa-plus"></i></button>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <p class="text-muted">No similar products found.</p>
          <% } %>
        </div>

        <!-- Tab 2: Seller Products -->
        <% if(typeof sellerProducts !== 'undefined' && sellerProducts.length > 0) { %>
          <div class="rec-tab-content" id="tab-seller">
            <div class="row product-grid related-products-grid">
              <% sellerProducts.forEach(function(r){ %>
                <div class="col-xl-2 col-lg-4 col-md-4 col-6 px-1 py-1">
                  <div class="rec-product-card pt-2">
                    <div class="position-relative mb-1">
                      <div class="<%= r.id %>-added-message show-added-message show-added-message-details" style="display:none; position:absolute; left:4px; top:4px; background:#000; color:#fff; font-size:11px; padding:2px 5px; border-radius:3px; z-index:2;"></div>
                      <a class="d-block" href="/details/<%= r.id %>/">
                        <% 
                          const isSellerOutOfStock = r.has_variants 
                            ? (r.variants ? r.variants.reduce((sum, v) => sum + (v.stock || 0), 0) <= 0 : false)
                            : (r.stock <= 0);
                        %>
                        <div class="rec-img-container" style="position: relative;">
                          <img src="<%= r.image %>" alt="<%- r.name.replace(/\"/g,'&quot;') %>" loading="lazy" decoding="async" style="<%= isSellerOutOfStock ? 'filter: grayscale(80%) opacity(60%);' : '' %>">
                          <div class="skeleton-loader"></div>
                          <% if (isSellerOutOfStock) { %>
                            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(220, 38, 38, 0.9); color: #fff; font-size: 10px; font-weight: 700; padding: 4px 8px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.5px; z-index: 3; pointer-events: none; white-space: nowrap; box-shadow: 0 2px 6px rgba(0,0,0,0.15);">Out of Stock</div>
                          <% } %>
                        </div>
                      </a>
                    </div>
                    <div class="rec-card-body">
                      <div class="rec-category-tag"><%= r.category || 'Seller' %></div>
                      <h5 class="rec-product-title">
                        <a href="/details/<%= r.id %>/"><%= r.name %></a>
                      </h5>
                      <div class="rec-price-row">
                        <span class="rec-price">Rs. <%= r.price %></span>
                        <div class="rec-actions">
                          <button class="rec-action-btn rec-view-btn quick-view-btn" 
                                  data-id="<%= r.id %>" 
                                  data-image="<%= r.image %>" 
                                  data-name="<%- r.name %>" 
                                  data-price="<%= r.price %>" 
                                  data-short-description="<%- r.short_description || '' %>" 
                                  data-link="/details/<%= r.id %>/" 
                                  data-has-variants="<%= r.has_variants ? 'true' : 'false' %>"
                                  title="Quick View">
                            <i class="fas fa-expand"></i>
                          </button>
                          <% if (isSellerOutOfStock) { %>
                            <button class="rec-action-btn rec-add-btn" disabled style="opacity: 0.5; cursor: not-allowed; background: #999; border-color: #999;" title="Out of Stock"><i class="fas fa-times"></i></button>
                          <% } else if(r.has_variants) { %>
                            <a href="/details/<%= r.id %>/" class="rec-action-btn rec-add-btn" title="Select options"><i class="fas fa-cog"></i></a>
                          <% } else { %>
                            <button class="rec-action-btn rec-add-btn" onclick="addToCart('<%= r.id %>','1', false)" title="Add to Cart"><i class="fas fa-plus"></i></button>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Script for tab toggling -->
      <script>
        $(document).ready(function() {
          $('.rec-tab-trigger').click(function() {
            $('.rec-tab-trigger').removeClass('active');
            $('.rec-tab-content').removeClass('active');
            
            $(this).addClass('active');
            $($(this).data('target')).addClass('active');
          });
        });
      </script>

      <!-- Client-side Cookie Tracking for Recently Viewed Items (Handles Cache Hits) -->
      <script>
        $(document).ready(function() {
          try {
            const currentProductId = "<%= product.id %>";
            
            // Read viewed cookie
            function getCookie(name) {
              const value = `; ${document.cookie}`;
              const parts = value.split(`; ${name}=`);
              if (parts.length === 2) return parts.pop().split(';').shift();
              return null;
            }
            
            let viewed = [];
            const cookieVal = getCookie('recently_viewed');
            if (cookieVal) {
              try {
                viewed = JSON.parse(decodeURIComponent(cookieVal));
                if (!Array.isArray(viewed)) viewed = [];
              } catch (e) {
                viewed = [];
              }
            }
            
            // Update viewed array
            viewed = viewed.filter(id => id !== currentProductId);
            viewed.unshift(currentProductId);
            viewed = viewed.slice(0, 10);
            
            // Set cookie
            const date = new Date();
            date.setTime(date.getTime() + (30 * 24 * 60 * 60 * 1000));
            document.cookie = `recently_viewed=${encodeURIComponent(JSON.stringify(viewed))}; expires=${date.toUTCString()}; path=/; SameSite=Lax`;
            console.log('✅ Tracked product view client-side:', currentProductId);
          } catch(e) {
            console.warn('Failed tracking product client-side:', e);
          }
        });
      </script>
    </div>
  </section>
