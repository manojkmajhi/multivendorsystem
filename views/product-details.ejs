  <script>
    // Unified quickview logic reused
    let quickviewSelectedId=null; let lastFocusedEl=null; let quickviewVariants=null; let quickviewSelectedVariant=null;
    function openQuickview(id,image,name,price,shortDescription,link,variantData){
      quickviewSelectedId=id; lastFocusedEl=document.activeElement; quickviewVariants=variantData; quickviewSelectedVariant=null;
      $('#quickview-img').attr('src', image); $('#quickview-img-link').attr('href', link);
      $('#quickview-title').text(name); $('#quickview-price').text('Rs. '+price);
      const desc = shortDescription && shortDescription.trim() ? shortDescription : 'Premium quality product perfect for you.'; $('#quickview-description').text(desc);
      $('#quickview-qty').val('1');
      
      console.log('🛠️ Opening quickview with variant data:', variantData);
      $('.variant-blocks-container').remove();
      
      if(variantData && variantData.attributes && variantData.attributes.length){
        console.log('✅ Creating variant selectors for', variantData.attributes.length, 'attributes');
        const $container = $('<div class="variant-blocks-container"></div>');
        
        variantData.attributes.forEach(attr => {
          console.log('  ➡️ Adding attribute:', attr.name, 'with', attr.values?.length, 'values');
          const $block = $('<div class="variant-block"></div>');
          $block.append('<span class="quickview-section-label">' + attr.name + ':</span> ');
          
          const $select = $('<select class="quickview-select variant-selector" data-attr="' + attr.slug + '"></select>');
          $select.append('<option value="">Select</option>');
          attr.values.forEach(v => $select.append('<option value="' + v.value + '">' + v.value + '</option>'));
          $block.append($select);
          $container.append($block);
        });
        
        $('#quickview-description').after($container);
        $('.variant-selector').on('change', updateQuickviewVariant);
        $('#quickview-add-to-cart').prop('disabled', true).text('Select Options');
        console.log('✅ Variant selectors created');
      } else {
        console.log('⚠️ No variant data, showing regular add to cart');
        $('#quickview-add-to-cart').prop('disabled', false).text('Add to Cart');
      }
      
      $('#productQuickView').modal('show'); setTimeout(()=> $('#quickview-close-btn').focus(), 400);
    }
    
    function updateQuickviewVariant(){
      if(!quickviewVariants) return;
      
      const selections = {};
      let allSelected = true;
      $('.variant-selector').each(function(){
        const val = $(this).val();
        if(val) selections[$(this).data('attr')] = val;
        else allSelected = false;
      });
      
      if(allSelected && quickviewVariants.variants){
        quickviewSelectedVariant = quickviewVariants.variants.find(v => {
          const combo = v.attribute_combination || {};
          return Object.keys(selections).every(k => combo[k] === selections[k]);
        });
        
        if(quickviewSelectedVariant){
          const finalPrice = quickviewVariants.basePrice + parseFloat(quickviewSelectedVariant.price_adjustment || 0);
          $('#quickview-price').text('Rs. ' + finalPrice.toFixed(2));
          $('#quickview-add-to-cart').prop('disabled', quickviewSelectedVariant.stock <= 0).text(quickviewSelectedVariant.stock <= 0 ? 'Out of Stock' : 'Add to Cart');
          if(quickviewSelectedVariant.image && quickviewSelectedVariant.image.trim()) {
            $('#quickview-img').attr('src', quickviewSelectedVariant.image);
            console.log('✅ Updated quickview image:', quickviewSelectedVariant.image);
          }
        }
      } else {
        $('#quickview-add-to-cart').prop('disabled', true).text('Select Options');
      }
    }
    // Trigger from related quick view buttons
    $(document).on('click', '.quick-view-btn', function(){ 
        const $t=$(this);
        const hasVariants = $t.data('has-variants') === 'true' || $t.data('has-variants') === true;
        const id=$t.data('id'); 
        const image=$t.data('image'); 
        const name=$t.data('name'); 
        const price=$t.data('price'); 
        const link=$t.data('link'); 
        const shortDescription=$t.data('short-description');
        
        console.log('👁️ Quick view clicked:', { id, hasVariants });
        
        if(hasVariants){
          console.log('🔄 Fetching variants for:', id);
          $.get('/api/product-variants/' + id, function(data){
            console.log('✅ Variant data received:', data);
            const variantData = { attributes: data.attributes, variants: data.variants, basePrice: parseFloat(price) };
            openQuickview(id,image,name,price,shortDescription,link,variantData);
          }).fail(function(err){
            console.error('❌ Failed to fetch variants:', err);
            openQuickview(id,image,name,price,shortDescription,link,null);
          });
        } else {
          openQuickview(id,image,name,price,shortDescription,link,null);
        }
    });
    // Quantity & interactions
    $('#quickview-dec').on('click', ()=>{ let v=parseInt($('#quickview-qty').val(),10)||1; v=Math.max(1,v-1); $('#quickview-qty').val(v); });
    $('#quickview-inc').on('click', ()=>{ let v=parseInt($('#quickview-qty').val(),10)||1; v=Math.min(999,v+1); $('#quickview-qty').val(v); });
    $('#quickview-qty').on('input', function(){ let v=this.value.replace(/[^0-9]/g,''); if(!v) v='1'; v=parseInt(v,10); if(v<1) v=1; if(v>999) v=999; this.value=v; });
    $(document).on('click keypress','.color-swatch', function(e){ if(e.type==='click' || (e.type==='keypress' && (e.key==='Enter'|| e.key===' '))){ $('.color-swatch').removeClass('active').attr('aria-checked','false'); $(this).addClass('active').attr('aria-checked','true'); } });
    $('#productQuickView').on('shown.bs.modal', function(){ const focusable=$('#productQuickView').find('button, [href], select, input').filter(':visible'); const first=focusable.first()[0]; const last=focusable.last()[0]; $(this).on('keydown.quicktrap', function(e){ if(e.key==='Tab'){ if(e.shiftKey && document.activeElement===first){ e.preventDefault(); last.focus(); } else if(!e.shiftKey && document.activeElement===last){ e.preventDefault(); first.focus(); } } if(e.key==='Escape'){ $('#productQuickView').modal('hide'); } }); });
    $('#productQuickView').on('hidden.bs.modal', function(){ $(this).off('keydown.quicktrap'); if(lastFocusedEl) $(lastFocusedEl).focus(); });
    $('#quickview-add-to-cart').on('click', function(){ if(!quickviewSelectedId) return; const variantId = quickviewSelectedVariant ? quickviewSelectedVariant.id : null; addToCart(quickviewSelectedId, $('#quickview-qty').val(), true, variantId); $('#productQuickView').modal('hide'); });

    $(document).ready(function(){
      if ($('#content').prop('scrollHeight') > $('#content').prop('clientHeight')){ $(".caret").show(); } else { $(".caret").hide(); }
      // Quick view button clicks
      $(document).on('click', '.quick-view-btn', function(){
        const id = $(this).data('id');
        const image = $(this).data('image');
        const name = $(this).data('name');
        const price = $(this).data('price');
        const link = $(this).data('link');
        // Derive short description from first list item on page if available
        var firstBullet = $('.descripton-ul li:first').text().replace(/^\s*[✓✔☑•\-*]\s*/, '').trim();
        viewproduct(id, image, name, price, firstBullet, link);
      });
    });

  </script>
  <script id="product-data-json" type="application/json">
    <%- JSON.stringify(product) %>
  </script>
  <script>
    const productData = JSON.parse(document.getElementById('product-data-json').textContent);
    let selectedVariant = null;

    $('.variant-select').on('change', function() {
      const selections = {};
      let allSelected = true;
      
      $('.variant-select').each(function() {
        const attr = $(this).data('attr');
        const val = $(this).val();
        if (val) {
          selections[attr] = val;
        } else {
          allSelected = false;
        }
      });

      if (allSelected) {
        selectedVariant = productData.variants.find(v => {
          const combo = v.attribute_combination || {};
          return Object.keys(selections).every(key => combo[key] === selections[key]);
        });

        if (selectedVariant) {
          const finalPrice = parseFloat(productData.price) + parseFloat(selectedVariant.price_adjustment || 0);
          $('#variantPrice').text('Rs. ' + finalPrice.toFixed(2));
          $('#variantStock').text(selectedVariant.stock);
          $('#variantSku').text(selectedVariant.sku);
          $('#variantInfo').show();
          $('#product-add-to-cart').prop('disabled', selectedVariant.stock <= 0).text(selectedVariant.stock <= 0 ? 'Out of Stock' : 'Add to cart');
          
          if (selectedVariant.image) {
            $('.product-slider img').attr('src', selectedVariant.image);
          }

          // Dynamic Out of Stock Image Overlay for selected Variant
          if (selectedVariant.stock <= 0) {
            if ($('.out-of-stock-overlay').length === 0) {
              $('.product-slider .item').append('<div class="out-of-stock-overlay" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(220, 38, 38, 0.9); color: white; padding: 0.75rem 1.5rem; font-weight: 700; font-size: 16px; border-radius: 4px; box-shadow: 0 4px 10px rgba(0,0,0,0.15); pointer-events: none; z-index: 10; text-transform: uppercase; letter-spacing: 1px; white-space: nowrap;">Out of Stock</div>');
            }
            $('.product-slider img').css('filter', 'grayscale(80%) opacity(60%)');
          } else {
            $('.out-of-stock-overlay').remove();
            $('.product-slider img').css('filter', '');
          }
        }
      } else {
        $('#variantInfo').hide();
        $('#product-add-to-cart').prop('disabled', true).text('Select options');
        
        // Restore overall stock status on reset
        const isOverallOut = productData.has_variants 
          ? (productData.variants && productData.variants.reduce((sum, v) => sum + (v.stock || 0), 0) <= 0)
          : (productData.stock <= 0);

        if (isOverallOut) {
          if ($('.out-of-stock-overlay').length === 0) {
            $('.product-slider .item').append('<div class="out-of-stock-overlay" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(220, 38, 38, 0.9); color: white; padding: 0.75rem 1.5rem; font-weight: 700; font-size: 16px; border-radius: 4px; box-shadow: 0 4px 10px rgba(0,0,0,0.15); pointer-events: none; z-index: 10; text-transform: uppercase; letter-spacing: 1px; white-space: nowrap;">Out of Stock</div>');
          }
          $('.product-slider img').css('filter', 'grayscale(80%) opacity(60%)');
        } else {
          $('.out-of-stock-overlay').remove();
          $('.product-slider img').css('filter', '');
        }
      }
    });

    $('#product-add-to-cart').click(function(){ 
      if (productData.has_variants && !selectedVariant) {
        alert('Please select all options');
        return;
      }
      const variantId = selectedVariant ? selectedVariant.id : null;
      addToCart($('#product-add-to-cart').val(), $('#product_qty').val(), true, variantId); 
    });

    // Use shared cart-shared.js for cart logic; keep only product view + search submit
    $("#search-form-in-navbar").submit(function(e){ e.preventDefault(); var search_term = $("#search").val(); if(search_term){ window.location = window.location.origin+"/search/all/?q="+search_term; } });
  </script>
