<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Seller Signup - <%= siteSetting.name %></title>
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
  <link rel="stylesheet" href="/custom-theme.css">
  <style>
    .back-link { color: #666; text-decoration: none; transition: color 0.2s; }
    .back-link:hover { color: #333; text-decoration: underline; }
    .form-group { margin-bottom: 0.75rem; }
    .card-body { padding: 1.5rem !important; }
    h3 { margin-bottom: 1rem !important; font-size: 1.4rem; }
    .container { padding: 20px 15px; }
    .row { min-height: auto; }
  </style>
</head>
<body class="bg-light">
  <div class="container">
    <div class="row justify-content-center" style="padding: 20px 0;">
      <div class="col-md-5">
        <div class="card shadow">
          <div class="card-body">
            <h3 class="text-center">Seller Application</h3>
            
            <div id="message" class="alert" style="display: none;"></div>
            
            <form id="sellerApplicationForm">
              <div class="form-group">
                <label>Full Name *</label>
                <input type="text" id="full_name" class="form-control" required>
              </div>
              <div class="form-group">
                <label>Phone Number *</label>
                <input type="tel" id="phone" class="form-control" required>
              </div>
              <div class="form-group">
                <label>Email</label>
                <input type="email" id="email" class="form-control">
              </div>
              <div class="form-group">
                <label>Business Name</label>
                <input type="text" id="business_name" class="form-control">
              </div>
              <div class="form-group">
                <label>Location</label>
                <input type="text" id="location" class="form-control">
              </div>
              <div class="form-group">
                <label>Message</label>
                <textarea id="message_text" class="form-control" rows="2" placeholder="Tell us about your business..."></textarea>
              </div>
              <button type="submit" class="btn btn-dark btn-block" id="submitBtn">Submit Application</button>
            </form>

            <div class="text-center mt-2">
              <a href="/farmers/login" class="back-link">Already have an account? Login</a><br>
              <a href="/sellers/" class="back-link">← Back to Sellers</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script>
    // Real-time Name validation (only letters and spaces, instantly strips unwanted data)
    $('#full_name').on('input', function() {
      this.value = this.value.replace(/[^a-zA-Z\s]/g, '');
      if (this.value.trim().length > 0) {
        $(this).css('border-color', '#28a745');
      } else {
        $(this).css('border-color', '');
      }
    });

    // Real-time Phone validation (numbers only, exactly 10 digits check)
    $('#phone').on('input', function() {
      this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);
      if (this.value.length === 10) {
        $(this).css('border-color', '#28a745');
      } else if (this.value.length > 0) {
        $(this).css('border-color', '#dc3545');
      } else {
        $(this).css('border-color', '');
      }
    });

    $('#sellerApplicationForm').on('submit', function(e) {
      e.preventDefault();
      
      const fullName = $('#full_name').val().trim();
      const phone = $('#phone').val().trim();
      const email = $('#email').val().trim();
      const businessName = $('#business_name').val().trim();
      const location = $('#location').val().trim();
      const messageText = $('#message_text').val().trim();

      // Full Name Validation
      const nameRegex = /^[a-zA-Z\s]+$/;
      if (!nameRegex.test(fullName)) {
        $('#message').removeClass('alert-success').addClass('alert-danger')
          .text('Name should only contain letters and spaces (no numbers or special characters).')
          .show();
        $('html, body').animate({ scrollTop: 0 }, 300);
        return;
      }

      // Phone Validation (exactly 10 digits)
      const phoneRegex = /^[0-9]{10}$/;
      if (!phoneRegex.test(phone)) {
        $('#message').removeClass('alert-success').addClass('alert-danger')
          .text('Phone number must be exactly 10 digits.')
          .show();
        $('html, body').animate({ scrollTop: 0 }, 300);
        return;
      }

      // Email Validation (optional syntax check) - Enforce @gmail.com or @multivendor.com
      if (email) {
        const emailRegex = /^[a-zA-Z0-9._%+-]+@(gmail\.com|multivendor\.com)$/i;
        if (!emailRegex.test(email)) {
          $('#message').removeClass('alert-success').addClass('alert-danger')
            .text('Please enter a valid Gmail address (ending in @gmail.com).')
            .show();
          $('html, body').animate({ scrollTop: 0 }, 300);
          return;
        }
      }

      // Location Validation (min 5 characters if provided)
      if (location && location.length < 5) {
        $('#message').removeClass('alert-success').addClass('alert-danger')
          .text('Please enter a detailed location (at least 5 characters).')
          .show();
        $('html, body').animate({ scrollTop: 0 }, 300);
        return;
      }

      const formData = {
        full_name: fullName,
        phone: phone,
        email: email,
        business_name: businessName,
        location: location,
        message: messageText
      };
      
      $('#submitBtn').prop('disabled', true).text('Submitting...');
      
      $.post('/api/seller-applications', formData)
        .done(function(data) {
          if (data.success) {
            $('#message').removeClass('alert-danger').addClass('alert-success')
              .html('<strong>🎉 Success!</strong> Your seller application has been received. Our team will review your details and get back to you within 24-48 hours.')
              .show();
            $('#sellerApplicationForm')[0].reset();
          } else {
            $('#message').removeClass('alert-success').addClass('alert-danger')
              .text(data.error || 'Failed to submit application')
              .show();
          }
        })
        .fail(function() {
          $('#message').removeClass('alert-success').addClass('alert-danger')
            .text('Failed to submit application. Please try again.')
            .show();
        })
        .always(function() {
          $('#submitBtn').prop('disabled', false).text('Submit Application');
          $('html, body').animate({ scrollTop: 0 }, 300);
        });
    });
  </script>
</body>
</html>

