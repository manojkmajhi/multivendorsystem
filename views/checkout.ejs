<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Checkout | All Strawhats</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/staticfiles/style.blue.css" />
  <link rel="stylesheet" href="/custom-theme.css?v=<%= Date.now() %>" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@300;400;700&display=swap" />
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <style>
  html{height:100%;}
  body{font-family:'Libre Franklin',Arial,sans-serif; background:#fafbfc; display:flex; flex-direction:column; min-height:100vh; padding-top:70px; overflow-x:hidden;}
  .main-content{flex:1 0 auto; padding-bottom:20px;}
  nav.navbar{box-shadow:0 1px 3px rgba(0,0,0,.08); background:#fff;}
  .breadcrumb-inline{font-size:10px; letter-spacing:1px; text-transform:uppercase; margin:8px 0 12px; opacity:.7;}
  .breadcrumb{background:transparent; padding:0; margin:0;}
  .breadcrumb-item+.breadcrumb-item::before{content:'/'; padding:0 5px; color:#999;}
  .section-heading{font-size:13px; font-weight:700; letter-spacing:1.2px; margin:0 0 12px; color:#1a1a1a; text-transform:uppercase;}
  .form-group{margin-bottom:10px;}
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0;}
  .form-control, .custom-select{border-radius:8px; border:1px solid #e1e4e8; font-size:13px; height:42px; transition:all .25s ease; padding:8px 14px; background:#fff; box-shadow:0 1px 2px rgba(0,0,0,.04);}
  .form-control:focus, .custom-select:focus{box-shadow:0 0 0 3px rgba(0,0,0,.06), 0 1px 3px rgba(0,0,0,.1); border-color:#333; background:#fff; outline:none;}
  .form-control::placeholder{color:#a0a0a0; font-size:13px;}
  textarea.form-control{height:auto; min-height:60px; resize:vertical;}
  .checkout-grid-row{margin-bottom:0;}
  .summary-box{background:#fff; padding:20px 22px 18px; border-radius:10px; border:1px solid #e8eaed; box-shadow:0 2px 12px rgba(0,0,0,.08), 0 1px 3px rgba(0,0,0,.04);}
  .summary-box h5{font-size:14px; letter-spacing:.8px; font-weight:700; margin-bottom:12px; color:#1a1a1a; text-transform:uppercase;}
  .summary-box hr{margin:8px 0 10px; border:0; border-top:1px solid #e8eaed;}    
  .summary-box .line{display:flex; justify-content:space-between; font-size:13px; padding:4px 0; color:#333;}
  .summary-total{font-weight:700; font-size:15px; letter-spacing:.5px; color:#000;}
  .back-cart-btn{border:1px solid #e1e4e8; background:#fff; padding:9px 16px; font-size:12px; letter-spacing:.3px; display:inline-flex; align-items:center; font-weight:500; border-radius:8px; transition:all .25s ease; box-shadow:0 1px 3px rgba(0,0,0,.06);}
  .back-cart-btn:hover{text-decoration:none; background:#000; color:#fff; border-color:#000; box-shadow:0 2px 6px rgba(0,0,0,.15);}
  .place-order-btn{background:linear-gradient(135deg, #000 0%, #1a1a1a 100%); color:#fff; border:none; height:48px; width:100%; font-weight:600; letter-spacing:.6px; transition:all .25s ease; border-radius:8px; font-size:14px; box-shadow:0 3px 10px rgba(0,0,0,.15), 0 1px 3px rgba(0,0,0,.1);}
  .place-order-btn:hover{background:linear-gradient(135deg, #1a1a1a 0%, #333 100%); box-shadow:0 4px 14px rgba(0,0,0,.2), 0 2px 4px rgba(0,0,0,.12); transform:translateY(-1px);}
  .place-order-btn:active{transform:translateY(0); box-shadow:0 2px 6px rgba(0,0,0,.15);}    
  footer{margin-top:0; flex-shrink:0;}
  .helper-text{color:#6c757d; font-size:10px; display:block; margin-top:3px; line-height:1.3;}
  #celebrate{position:fixed; inset:0; background:rgba(0,0,0,.75); display:flex; align-items:center; justify-content:center; z-index:9999; opacity:0; pointer-events:none; transition:opacity .4s ease; backdrop-filter:blur(4px);}
  #celebrate.active{opacity:1; pointer-events:auto;}
  #celebrate .celebrate-box{background:#fff; padding:40px 32px 36px; border-radius:16px; max-width:380px; width:90%; text-align:center; position:relative; box-shadow:0 20px 60px rgba(0,0,0,.3), 0 8px 20px rgba(0,0,0,.15);}    
  #celebrate .icon-circle{width:70px; height:70px; border-radius:50%; background:linear-gradient(135deg, #000 0%, #1a1a1a 100%); display:flex; align-items:center; justify-content:center; font-size:36px; color:#fff; margin:-80px auto 20px; box-shadow:0 8px 24px rgba(0,0,0,.3);} 
  #celebrate h2{font-size:26px; letter-spacing:.5px; font-weight:700; margin-bottom:8px; color:#1a1a1a;}
  #celebrate p{font-size:13px; color:#555; margin-bottom:5px;}
  #celebrate .btn{border-radius:8px; padding:11px 24px; font-weight:600; letter-spacing:.5px; font-size:13px; box-shadow:0 2px 8px rgba(0,0,0,.15);}
  #confettiCanvas{position:absolute; inset:0; width:100%; height:100%; pointer-events:none;}
  .form-section{background:#fff; padding:20px; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,.06), 0 1px 3px rgba(0,0,0,.04); border:1px solid #e8eaed;}
  
  /* Mobile optimizations */
  @media (max-width:991.98px){ 
    .summary-box{margin-top:20px;} 
    body{padding-top:65px;}
  }
  @media (max-width:767.98px){ 
    body{padding-top:60px; background:#fff;}
    .main-content{padding-bottom:15px;}
    .breadcrumb-inline{margin:6px 0 10px;}
    .section-heading{font-size:12px; margin-bottom:10px;}
    .form-group{margin-bottom:8px;}
    .form-control, .custom-select{height:40px; font-size:13px; padding:8px 12px; border-radius:6px;}
    textarea.form-control{min-height:55px;}
    .helper-text{font-size:9px; margin-top:2px;}
    .summary-box{padding:16px 18px 14px; margin-top:15px; border-radius:8px;}
    .summary-box h5{font-size:13px; margin-bottom:10px;}
    .summary-box .line{font-size:12px; padding:3px 0;}
    .summary-total{font-size:14px;}
    .place-order-btn{height:44px; margin-top:8px; font-size:13px; border-radius:6px;}
    .back-cart-btn{padding:8px 14px; font-size:11px; border-radius:6px;}
    .form-section{padding:16px; border-radius:8px;}
    footer{margin-top:20px; font-size:12px;}
    footer .container{padding-top:16px !important; padding-bottom:16px !important;}
    #celebrate .celebrate-box{padding:32px 24px 28px; border-radius:12px;}
    #celebrate .icon-circle{width:60px; height:60px; font-size:30px; margin:-70px auto 16px;}
    #celebrate h2{font-size:22px;}
    #celebrate p{font-size:12px;}
  }
  @media (max-width:575.98px){
    .checkout-grid-row .col-md-6{padding-left:15px; padding-right:15px;}
  }
  </style>
</head>
<body>
  <nav class="navbar navbar-light fixed-top py-0 px-2">
    <div class="container px-0 px-lg-3 d-flex align-items-center justify-content-between">
  <a class="navbar-brand" href="/"><img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" height="60" /></a>
      <ul class="navbar-nav ml-auto phone-in-navbar" style="display:flex; flex-direction:row;">
        <li class="nav-item"><a class="nav-link" href="tel:9814789009"><i class="fas fa-phone-alt"></i> 9814789009<sup><small> NP</small></sup></a></li>
      </ul>
    </div>
  </nav>
  <!-- Removed spacer div; body now has padding-top to account for fixed navbar -->

  <div class="container main-content">
    <div class="breadcrumb-inline">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb px-0 mb-0">
          <li class="breadcrumb-item"><a href="/">Home</a></li>
          <li class="breadcrumb-item"><a href="/cart/">Cart</a></li>
          <li class="breadcrumb-item active" aria-current="page">Checkout</li>
        </ol>
      </nav>
    </div>
    <form id="checkout-form" class="mb-5">
      <div class="row">
        <div class="col-lg-8 mobile-stack">
          <div class="form-section">
          <div class="section-heading">Delivery Details</div>
          <div class="row checkout-grid-row">
            <div class="col-md-6 form-group">
              <label class="sr-only" for="name">Name *</label>
              <input id="name" class="form-control" placeholder="Name *" required />
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="mobile">WhatsApp Number *</label>
              <input id="mobile" class="form-control" placeholder="WhatsApp Number *" type="tel" pattern="[0-9]{10}" maxlength="10" required />
              <small class="helper-text">OTP verification required</small>
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="region">Region</label>
              <select id="region" class="custom-select"><option>Inside Valley</option><option>Outside Valley</option></select>
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="area">Area</label>
              <select id="area" class="custom-select"><option value="">Select Area</option></select>
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="email">Email (Optional)</label>
              <input id="email" type="email" class="form-control" placeholder="Email (Optional)" />
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="address">Detailed Address *</label>
              <input id="address" class="form-control" placeholder="Detailed Address *" required />
            </div>
            <div class="col-12 form-group">
              <label class="sr-only" for="notes">Order Notes (Optional)</label>
              <textarea id="notes" class="form-control" placeholder="Order Notes (Optional)" rows="2"></textarea>
            </div>
            <div class="col-12 form-group mb-0">
              <a href="/cart/" class="back-cart-btn"><span style="font-size:14px; line-height:0;" class="mr-1">&larr;</span> Change Cart</a>
            </div>
          </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="summary-box">
            <h5>SUMMARY</h5>
            <div class="line" style="border-top:1px solid #d1d1d1; margin-top:-4px; margin-bottom:14px;"></div>
            <div class="line"><span>Sub Total</span><span>Rs. <span id="subtotal"><%= total %></span></span></div>
            <div class="line"><span>Delivery</span><span>Rs. <span id="delivery-fee">0</span></span></div>
            <hr />
            <div class="line summary-total"><span>Total</span><span>Rs. <span id="grand-total"><%= total %></span></span></div>
            <button type="submit" class="place-order-btn mt-3">Place order</button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <footer class="bg-dark text-white shadow" style="color: #fff;">
    <div class="container py-3">
      <div class="row">
        <div class="col-lg-6">
          <p class="small text-gray mb-0">&copy; <%= new Date().getFullYear() %> All rights reserved.</p>
          <p class="small text-gray mb-0">Crafted by <a class="text-white reset-anchor" href="https://gauravsah.com.np" target="_blank">Gaurav Sah</a></p>
        </div>
        <div class="col-lg-6 text-lg-right">
          <p class="small mb-0">FIND US &nbsp;
            <a href="<%= (typeof socialLinks !== 'undefined' && socialLinks.facebook_url) ? socialLinks.facebook_url : 'https://facebook.com/allstrawhats/' %>" target="_blank"><i class="fab fa-facebook-square mr-1" style="color: #f5f5f5;"></i></a>
            <a href="<%= (typeof socialLinks !== 'undefined' && socialLinks.instagram_url) ? socialLinks.instagram_url : 'https://instagram.com/allstrawhats/' %>" target="_blank"><i class="fab fa-instagram" style="color: #f5f5f5;"></i></a>
          </p>
          <p class="text-sm text-gray mb-0"><a class="text-gray reset-anchor" href="mailto:<%= (typeof socialLinks !== 'undefined' && socialLinks.contact_email) ? socialLinks.contact_email : 'info@allstrawhats.com' %>" target="_blank"><i class="fas fa-envelope"></i> &nbsp;<%= (typeof socialLinks !== 'undefined' && socialLinks.contact_email) ? socialLinks.contact_email : 'info@allstrawhats.com' %></a></p>
          <p class="text-sm text-gray mb-0 mt-2"><a class="text-white reset-anchor" href="/track-order"><i class="fas fa-shipping-fast"></i> Track Order</a></p>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/js/bootstrap.min.js"></script>
  <script src="https://kit.fontawesome.com/d6db3c2373.js" crossorigin="anonymous"></script>
  
  <%- include('partials/user-auth-popup') %>
  
  <div id="celebrate">
    <canvas id="confettiCanvas"></canvas>
    <div class="celebrate-box">
      <div class="icon-circle">&#10003;</div>
      <h2>Order Placed!</h2>
      <p>Thank you for your order. We'll reach out soon.</p>
      <p style="font-size:12px; letter-spacing:.5px; color:#888;">Order reference will be sent via phone.</p>
      <button id="celebrate-home" class="btn btn-dark mt-2">Continue Shopping</button>
    </div>
  </div>

  <script>
    // Simple region -> area mapping (placeholder)
    const areas = { 'Inside Valley':['Select Area','Kathmandu','Bhaktapur','Lalitpur'], 'Outside Valley':['Select Area','Pokhara','Butwal','Itahari','Chitwan'] };
    function updateAreas(){ const r=document.getElementById('region').value; const sel=document.getElementById('area'); sel.innerHTML=''; areas[r].forEach(a=>{ const o=document.createElement('option'); o.textContent=a; sel.appendChild(o); }); recalc(); }
    document.getElementById('region').addEventListener('change', updateAreas);
    updateAreas();

    function recalc(){ 
      const subtotal=parseInt(document.getElementById('subtotal').textContent,10); 
      const region=document.getElementById('region').value; 
      let fee=0; 
      if(region==='Outside Valley'){ fee=70; } 
      document.getElementById('delivery-fee').textContent=fee; 
      document.getElementById('grand-total').textContent=subtotal+fee; 
    }
    document.getElementById('area').addEventListener('change', recalc);

    // Pre-fill from logged in user
    if (window.currentUser) {
      document.getElementById('mobile').value = window.currentUser.phone.replace(/^\+91/, '');
      document.getElementById('name').value = window.currentUser.name;
    }
    
    // Mobile validation
    document.getElementById('mobile').addEventListener('input', function(e) {
      this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);
    });

    // Celebration + confetti instead of alert
    const celebrateEl=document.getElementById('celebrate');
    const canvas=document.getElementById('confettiCanvas');
    const ctx=canvas.getContext('2d');
    function resizeCanvas(){canvas.width=window.innerWidth; canvas.height=window.innerHeight;} resizeCanvas(); window.addEventListener('resize',resizeCanvas);
    const colors=['#ff4757','#1e90ff','#2ed573','#ffa502','#ff6b81','#3742fa','#70a1ff','#7bed9f','#ff7f50'];
    let pieces=[]; const pieceCount=160; const gravity=0.35; const drag=0.008; const terminal=4.5; let running=false;
    function randomRange(min,max){return Math.random()*(max-min)+min;}
    function initPieces(){pieces=[]; for(let i=0;i<pieceCount;i++){pieces.push({x:canvas.width*Math.random(),y:randomRange(-canvas.height,0),w:randomRange(6,14),h:randomRange(10,22),vx:randomRange(-2.8,2.8),vy:randomRange(1,3),r:randomRange(0,360),vr:randomRange(-6,6),color:colors[i%colors.length],alpha:1});}}
    function update(){ctx.clearRect(0,0,canvas.width,canvas.height); pieces.forEach(p=>{p.vy+=gravity; if(p.vy>terminal) p.vy=terminal; p.x+=p.vx; p.y+=p.vy; p.r+=p.vr; if(p.y>canvas.height+20) {p.y=randomRange(-canvas.height*0.2,0); p.x=Math.random()*canvas.width; p.vy=randomRange(1,3);} ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.r*Math.PI/180); ctx.fillStyle=p.color; ctx.globalAlpha=p.alpha; ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h); ctx.restore(); }); if(running) requestAnimationFrame(update); }
    function startConfetti(){resizeCanvas(); initPieces(); running=true; update(); setTimeout(()=>{running=false;},7000);}    
    
    // Form submission with OTP verification
    document.getElementById('checkout-form').addEventListener('submit', async function(e){ 
      e.preventDefault();
      
      const name = document.getElementById('name').value;
      const mobile = document.getElementById('mobile').value;
      
      if (!name || !mobile) {
        alert('Please fill in all required fields');
        return;
      }
      
      // Show OTP verification
      window.verifyMobileWithOTP(mobile, name, async (verified) => {
        if (verified) {
          await submitOrder();
        }
      });
    });
    
    async function submitOrder() {
      const formData = {
        name: document.getElementById('name')?.value || '',
        mobile: document.getElementById('mobile')?.value || '',
        email: document.getElementById('email')?.value || '',
        region: document.getElementById('region')?.value || 'Inside Valley',
        area: document.getElementById('area')?.value || '',
        address: document.getElementById('address')?.value || '',
        notes: document.getElementById('notes')?.value || '',
        subtotal: parseInt(document.getElementById('subtotal')?.textContent || '0'),
        deliveryFee: parseInt(document.getElementById('delivery-fee')?.textContent || '0'),
        total: parseInt(document.getElementById('grand-total')?.textContent || '0')
      };
      
      // Validate
      if(!formData.name || !formData.mobile || !formData.address || formData.area === 'Select Area') {
        alert('Please fill in all required fields');
        return;
      }
      
      try {
        // Disable submit button
        const submitBtn = document.querySelector('.place-order-btn');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Placing order...';
        
        // Submit order to server
        const response = await fetch('/checkout/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(formData)
        });
        
        const result = await response.json();
        
        if(result.success) {
          // Show celebration
          celebrateEl.classList.add('active'); 
          startConfetti();
        } else {
          throw new Error(result.error || 'Failed to place order');
        }
      } catch(error) {
        console.error('Order submission error:', error);
        alert('Failed to place order. Please try again or contact us directly.');
        // Re-enable button
        const submitBtn = document.querySelector('.place-order-btn');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Place order';
      }
    }
    
    document.getElementById('celebrate-home').addEventListener('click',()=>{window.location='/';});
    // Auto redirect after celebration
    celebrateEl.addEventListener('transitionend',()=>{ if(celebrateEl.classList.contains('active')) setTimeout(()=>{window.location='/'},6000);});
  </script>
</body>
</html>
