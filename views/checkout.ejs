  </div>

  <script>
    // Load eSewa QR code from settings
    fetch('/api/payment-settings')
      .then(r => r.json())
      .then(data => {
        if(data.esewa_qr) {
          document.getElementById('esewaQrImage').src = data.esewa_qr;
        } else {
          document.getElementById('esewaQrImage').src = 'https://i.postimg.cc/mDPmcWp9/Whats-App-Image-2025-10-14-at-16-17-59-1cdf0cb6.jpg';
        }
      })
      .catch(() => {
        document.getElementById('esewaQrImage').src = 'https://i.postimg.cc/mDPmcWp9/Whats-App-Image-2025-10-14-at-16-17-59-1cdf0cb6.jpg';
      });
    
    // Region -> area mapping with Kathmandu Valley locations and Nepal districts
    const areas = { 
      'Inside Valley': ['Select Area', 'Anamnagar', 'Ason', 'Babarmahal', 'Bagbazaar', 'Baghdol', 'Balaju', 'Balambu', 'Balkhu', 'Balkot', 'Balkumari', 'Baluwakhani', 'Baluwatar', 'Baneshwor', 'Bansbari', 'Basbari', 'Basantapur', 'Basundhara', 'Bafal', 'Bhangal', 'Bhaisepati', 'Bhotahity', 'Bijeshwori', 'Bode', 'Boudha', 'Budhanilkantha', 'Budol', 'Bungamati', 'Chabahil', 'Chandol', 'Chandragiri', 'Changunarayan', 'Chapagaun', 'Chapali', 'Chhauni', 'Chhetrapati', 'Chobhar', 'Chunikhel', 'Dakshinkali', 'Dallu', 'Dhapakhel', 'Dhapasi', 'Dhobighat', 'Dholahiti', 'Dhumbarahi', 'Dhulikhel', 'Dilli Bazaar', 'Durbar Marg', 'Duwakot', 'Gairidhara', 'Gaushala', 'Godawari', 'Gongabu', 'Gothatar', 'Gwarko', 'Gyaneshwor', 'Hadigaun', 'Harisiddhi', 'Hattisar', 'Imadol', 'Itumbahal', 'Jamal', 'Jawalakhel', 'Jhamsikhel', 'Jorpati', 'Kabhre', 'Kalimati', 'Kamaladi', 'Kapan', 'Khokana', 'Kirtipur', 'Koteshwor', 'Kuleshwor', 'Kupondole', 'Kusunti', 'Lainchaur', 'Lazimpat', 'Lubhu', 'Machhegaun', 'Mahalaxmi', 'Maharajgunj', 'Maitidevi', 'Maitighar', 'Manamaiju', 'Manohara', 'Mangal Bazar', 'Matatirtha', 'Nagarkot', 'Naikap', 'Nakhipot', 'Nakhkhu', 'Naxal', 'Nayabazar', 'New Baneshwor', 'New Road', 'Old Baneshwor', 'Panga', 'Patan', 'Patan Durbar Square', 'Pepsicola', 'Pharping', 'Pulchowk', 'Samakhushi', 'Sanepa', 'Sanga', 'Sankhamul', 'Sankhu', 'Satdobato', 'Sinamangal', 'Sitapaila', 'Sunakothi', 'Sundarighat', 'Sundarijal', 'Suryabinayak', 'Swayambhu', 'Tangal', 'Taukhel', 'Teku', 'Thaiba', 'Thamel', 'Thankot', 'Thapathali', 'Tinkune', 'Tokha', 'Tokha Municipality', 'Tripureshwor', 'Tusal', 'Tushal'],
      'Outside Valley': ['Select District', 'Achham', 'Arghakhanchi', 'Baglung', 'Baitadi', 'Bajhang', 'Bajura', 'Banke', 'Bara', 'Bardiya', 'Bhojpur', 'Chitwan', 'Dadeldhura', 'Dailekh', 'Dang', 'Darchula', 'Dhading', 'Dhankuta', 'Dhanusa', 'Dolakha', 'Dolpa', 'Doti', 'Gorkha', 'Gulmi', 'Humla', 'Ilam', 'Jajarkot', 'Jhapa', 'Jumla', 'Kailali', 'Kalikot', 'Kanchanpur', 'Kapilvastu', 'Kaski', 'Kavrepalanchok', 'Khotang', 'Lamjung', 'Mahottari', 'Makwanpur', 'Manang', 'Morang', 'Mugu', 'Mustang', 'Myagdi', 'Nawalparasi', 'Nuwakot', 'Okhaldhunga', 'Palpa', 'Panchthar', 'Parbat', 'Parsa', 'Pyuthan', 'Ramechhap', 'Rasuwa', 'Rautahat', 'Rolpa', 'Rukum', 'Rupandehi', 'Salyan', 'Sankhuwasabha', 'Saptari', 'Sarlahi', 'Sindhuli', 'Sindhupalchok', 'Siraha', 'Solukhumbu', 'Sunsari', 'Surkhet', 'Syangja', 'Tanahu', 'Taplejung', 'Terhathum', 'Udayapur']
    };
    let allAreas = [];
    let selectedArea = '';
    
    function updateAreas(){ 
      const r=document.getElementById('region').value; 
      allAreas = areas[r];
      selectedArea = '';
      document.getElementById('areaDisplay').value = '';
      document.getElementById('areaValue').value = '';
      document.getElementById('areaSearch').value = '';
      document.getElementById('areaDropdown').style.display = 'none';
      const placeholder = r === 'Inside Valley' ? 'Click to search area...' : 'Click to search district...';
      document.getElementById('areaDisplay').placeholder = placeholder;
      updatePaymentOptions();
      recalc(); 
    }
    
    document.getElementById('region').addEventListener('change', updateAreas);
    
    // Searchable dropdown for area
    const areaDisplay = document.getElementById('areaDisplay');
    const areaSearch = document.getElementById('areaSearch');
    const areaDropdown = document.getElementById('areaDropdown');
    const areaList = document.getElementById('areaList');
    
    areaDisplay.addEventListener('click', function(){
      areaDropdown.style.display = 'block';
      areaSearch.focus();
      showAreaDropdown('');
    });
    
    areaSearch.addEventListener('input', function(){
      showAreaDropdown(this.value);
    });
    
    document.addEventListener('click', function(e){
      if(!areaDisplay.contains(e.target) && !areaDropdown.contains(e.target)){
        areaDropdown.style.display = 'none';
      }
    });
    
    let nominatimTimeout;
    async function showAreaDropdown(query){
      const filtered = allAreas.filter(a => 
        a.toLowerCase().includes(query.toLowerCase()) && a !== 'Select Area' && a !== 'Select District'
      ).slice(0, 5);
      
      let html = '';
      
      if(filtered.length > 0){
        html += '<div style="padding:6px 10px; font-size:10px; color:#999; font-weight:600; text-transform:uppercase; background:#f8f9fa;">📍 Predefined Areas</div>';
        html += filtered.map(a => 
          `<div class="area-option" style="padding:10px 14px; cursor:pointer; font-size:13px; border-bottom:1px solid #f0f0f0; transition:all .2s;" 
                onmouseover="this.style.background='#f8f9fa'" 
                onmouseout="this.style.background='#fff'" 
                onclick="selectArea('${a.replace(/'/g, "\\'")}')"
          >${a}</div>`
        ).join('');
      }
      
      if(query.length >= 3){
        clearTimeout(nominatimTimeout);
        nominatimTimeout = setTimeout(async () => {
          try {
            const response = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query + ', Kathmandu, Nepal')}&format=json&limit=3`);
            const data = await response.json();
            
            let finalHtml = html;
            
            if(data.length > 0){
              const mapHtml = '<div style="padding:6px 10px; font-size:10px; color:#999; font-weight:600; text-transform:uppercase; background:#f8f9fa; border-top:2px solid #e0e0e0;">🗺️ Map Suggestions</div>' +
                data.map(place => {
                  const name = place.display_name.split(',')[0];
                  return `<div class="area-option" style="padding:10px 14px; cursor:pointer; font-size:13px; border-bottom:1px solid #f0f0f0; transition:all .2s;" 
                        onmouseover="this.style.background='#f8f9fa'" 
                        onmouseout="this.style.background='#fff'" 
                        onclick="selectArea('${name.replace(/'/g, "\\'")}')"
                    ><div style="font-weight:600;">${name}</div><div style="font-size:11px; color:#666;">${place.display_name.split(',').slice(1, 3).join(',')}</div></div>`;
                }).join('');
              finalHtml += mapHtml;
            }
            
            if(query.length >= 2){
              finalHtml += `<div style="padding:6px 10px; font-size:10px; color:#999; font-weight:600; text-transform:uppercase; background:#f8f9fa; border-top:2px solid #e0e0e0;">➕ Custom</div><div class="area-option" style="padding:10px 14px; cursor:pointer; font-size:13px; background:#fff3cd; transition:all .2s;" onmouseover="this.style.background='#fff9e6'" onmouseout="this.style.background='#fff3cd'" onclick="selectArea('${query.replace(/'/g, "\\'")}')"><div style="font-weight:600; color:#856404;"><i class="fas fa-plus-circle"></i> Add "${query}"</div><div style="font-size:11px; color:#856404;">Use this custom area</div></div>`;
            }
            
            areaList.innerHTML = finalHtml;
          } catch(e) {
            let finalHtml = html;
            if(query.length >= 2){
              finalHtml += `<div style="padding:6px 10px; font-size:10px; color:#999; font-weight:600; text-transform:uppercase; background:#f8f9fa; border-top:2px solid #e0e0e0;">➕ Custom</div><div class="area-option" style="padding:10px 14px; cursor:pointer; font-size:13px; background:#fff3cd; transition:all .2s;" onmouseover="this.style.background='#fff9e6'" onmouseout="this.style.background='#fff3cd'" onclick="selectArea('${query.replace(/'/g, "\\'")}')"><div style="font-weight:600; color:#856404;"><i class="fas fa-plus-circle"></i> Add "${query}"</div><div style="font-size:11px; color:#856404;">Use this custom area</div></div>`;
            }
            areaList.innerHTML = finalHtml;
          }
        }, 500);
      } else if(query.length >= 2){
        html += `<div style="padding:6px 10px; font-size:10px; color:#999; font-weight:600; text-transform:uppercase; background:#f8f9fa; border-top:2px solid #e0e0e0;">➕ Custom</div><div class="area-option" style="padding:10px 14px; cursor:pointer; font-size:13px; background:#fff3cd; transition:all .2s;" onmouseover="this.style.background='#fff9e6'" onmouseout="this.style.background='#fff3cd'" onclick="selectArea('${query.replace(/'/g, "\\'")}')"><div style="font-weight:600; color:#856404;"><i class="fas fa-plus-circle"></i> Add "${query}"</div><div style="font-size:11px; color:#856404;">Use this custom area</div></div>`;
        areaList.innerHTML = html;
      } else if(filtered.length === 0){
        html = '<div style="padding:12px; color:#999; font-size:13px; text-align:center;">Type to search areas</div>';
        areaList.innerHTML = html;
      } else {
        areaList.innerHTML = html;
      }
    }
    
    window.selectArea = function(area){
      selectedArea = area;
      document.getElementById('areaDisplay').value = area;
      document.getElementById('areaValue').value = area;
      document.getElementById('areaSearch').value = '';
      areaDropdown.style.display = 'none';
      recalc();
    };
    
    updateAreas();
    
    // Payment method handling
    function updatePaymentOptions(){
      const region = document.getElementById('region').value;
      const codLabel = document.getElementById('codLabel');
      const codRadio = document.getElementById('paymentCod');
      const esewaRadio = document.getElementById('paymentEsewa');
      
      if(region === 'Outside Valley'){
        codLabel.style.opacity = '0.5';
        codLabel.style.pointerEvents = 'none';
        codRadio.disabled = true;
        esewaRadio.checked = true;
        updatePaymentUI();
      } else {
        codLabel.style.opacity = '1';
        codLabel.style.pointerEvents = 'auto';
        codRadio.disabled = false;
      }
    }
    
    function updatePaymentUI(){
      const paymentMethod = document.querySelector('input[name="payment"]:checked').value;
      const qrSection = document.getElementById('esewaQrSection');
      const esewaLabel = document.getElementById('esewaLabel');
      const codLabel = document.getElementById('codLabel');
      
      if(paymentMethod === 'esewa'){
        qrSection.style.display = 'block';
        esewaLabel.style.borderColor = '#4caf50';
        esewaLabel.style.background = '#f1f8f4';
        codLabel.style.borderColor = '#ddd';
        codLabel.style.background = 'transparent';
      } else {
        qrSection.style.display = 'none';
        codLabel.style.borderColor = '#4caf50';
        codLabel.style.background = '#f1f8f4';
        esewaLabel.style.borderColor = '#ddd';
        esewaLabel.style.background = 'transparent';
      }
    }
    
    document.querySelectorAll('input[name="payment"]').forEach(radio => {
      radio.addEventListener('change', updatePaymentUI);
    });
    
    // Screenshot upload handling
    let uploadedScreenshot = null;
    document.getElementById('paymentScreenshot').addEventListener('change', function(e){
      const file = e.target.files[0];
      if(file){
        const reader = new FileReader();
        reader.onload = function(event){
          uploadedScreenshot = event.target.result;
          document.getElementById('screenshotPreview').style.display = 'block';
          console.log('Screenshot uploaded, size:', uploadedScreenshot.length);
        };
        reader.readAsDataURL(file);
      }
    });
    
    updatePaymentOptions();
    updatePaymentUI();

    function recalc(){ 
      const subtotal=parseInt(document.getElementById('subtotal').textContent,10); 
      const region=document.getElementById('region').value; 
      let fee=0; 
      if(region==='Outside Valley'){ fee=100; } 
      document.getElementById('delivery-fee').textContent=fee; 
      document.getElementById('grand-total').textContent=subtotal+fee; 
    }

    // Pre-fill from logged in user
    if (window.currentUser) {
      document.getElementById('mobile').value = window.currentUser.phone.replace(/^\+91/, '');
      document.getElementById('name').value = window.currentUser.name;
    }
    
    // Mobile validation
    document.getElementById('mobile').addEventListener('input', function(e) {
      this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);
    });

    // Celebration + confetti instead of alert
    const celebrateEl=document.getElementById('celebrate');
    const canvas=document.getElementById('confettiCanvas');
    const ctx=canvas.getContext('2d');
    function resizeCanvas(){canvas.width=window.innerWidth; canvas.height=window.innerHeight;} resizeCanvas(); window.addEventListener('resize',resizeCanvas);
    const colors=['#ff4757','#1e90ff','#2ed573','#ffa502','#ff6b81','#3742fa','#70a1ff','#7bed9f','#ff7f50'];
    let pieces=[]; const pieceCount=160; const gravity=0.35; const drag=0.008; const terminal=4.5; let running=false;
    function randomRange(min,max){return Math.random()*(max-min)+min;}
    function initPieces(){pieces=[]; for(let i=0;i<pieceCount;i++){pieces.push({x:canvas.width*Math.random(),y:randomRange(-canvas.height,0),w:randomRange(6,14),h:randomRange(10,22),vx:randomRange(-2.8,2.8),vy:randomRange(1,3),r:randomRange(0,360),vr:randomRange(-6,6),color:colors[i%colors.length],alpha:1});}}
    function update(){ctx.clearRect(0,0,canvas.width,canvas.height); pieces.forEach(p=>{p.vy+=gravity; if(p.vy>terminal) p.vy=terminal; p.x+=p.vx; p.y+=p.vy; p.r+=p.vr; if(p.y>canvas.height+20) {p.y=randomRange(-canvas.height*0.2,0); p.x=Math.random()*canvas.width; p.vy=randomRange(1,3);} ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.r*Math.PI/180); ctx.fillStyle=p.color; ctx.globalAlpha=p.alpha; ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h); ctx.restore(); }); if(running) requestAnimationFrame(update); }
    function startConfetti(){resizeCanvas(); initPieces(); running=true; update(); setTimeout(()=>{running=false;},7000);}    
    
    // Form submission with OTP verification
    document.getElementById('checkout-form').addEventListener('submit', async function(e){ 
      e.preventDefault();
      
      const name = document.getElementById('name').value;
      const mobile = document.getElementById('mobile').value;
      
      if (!name || !mobile) {
        alert('Please fill in all required fields');
        return;
      }
      
      // Show OTP verification
      window.verifyMobileWithOTP(mobile, name, async (verified) => {
        if (verified) {
          await submitOrder();
        }
      });
    });
    
    async function submitOrder() {
      const areaValue = document.getElementById('area')?.value || '';
      const paymentMethod = document.querySelector('input[name="payment"]:checked')?.value || 'esewa';
      
      const formData = {
        name: document.getElementById('name')?.value || '',
        mobile: document.getElementById('mobile')?.value || '',
        email: document.getElementById('email')?.value || '',
        region: document.getElementById('region')?.value || 'Inside Valley',
        area: areaValue,
        address: document.getElementById('address')?.value || '',
        notes: document.getElementById('notes')?.value || '',
        subtotal: parseInt(document.getElementById('subtotal')?.textContent || '0'),
        deliveryFee: parseInt(document.getElementById('delivery-fee')?.textContent || '0'),
        total: parseInt(document.getElementById('grand-total')?.textContent || '0'),
        paymentMethod: paymentMethod,
        paymentScreenshot: uploadedScreenshot
      };
      
      console.log('Submitting order with screenshot:', !!formData.paymentScreenshot);
      
      // Get selected area
      const areaVal = document.getElementById('areaValue').value;
      formData.area = areaVal;
      
      // Validate
      if(!formData.name || !formData.mobile || !formData.address || !areaVal) {
        alert('Please fill in all required fields');
        return;
      }
      
      // Validate payment screenshot for eSewa
      console.log('Payment validation:', { paymentMethod, hasScreenshot: !!uploadedScreenshot });
      if(paymentMethod === 'esewa' && !uploadedScreenshot){
        alert('Please upload payment screenshot for eSewa payment');
        return;
      }
      
      try {
        // Disable submit button
        const submitBtn = document.querySelector('.place-order-btn');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Placing order...';
        
        // Submit order to server
        const response = await fetch('/checkout/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(formData)
        });
        
        const result = await response.json();
        
        if(result.success) {
          // Show celebration
          celebrateEl.classList.add('active'); 
          startConfetti();
        } else {
          throw new Error(result.error || 'Failed to place order');
        }
      } catch(error) {
        console.error('Order submission error:', error);
        alert('Failed to place order. Please try again or contact us directly.');
        // Re-enable button
        const submitBtn = document.querySelector('.place-order-btn');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Place order';
      }
    }
    
    document.getElementById('celebrate-home').addEventListener('click',()=>{window.location='/';});
    
    // Close modal on outside click
    document.getElementById('locationModal').addEventListener('click', (e) => {
      if (e.target.id === 'locationModal') closeLocationPicker();
    });
    

    // Auto redirect after celebration
    celebrateEl.addEventListener('transitionend',()=>{ if(celebrateEl.classList.contains('active')) setTimeout(()=>{window.location='/'},6000);});
    
    // Leaflet with Nominatim
    let map, marker;
    let selectedLat = 27.7172, selectedLng = 85.3240, selectedAddress = '';
    let searchSetupDone = false;
    let searchTimeout;
    
    function openLocationPicker() {
      document.getElementById('locationModal').classList.add('active');
      if (!searchSetupDone) {
        setupLocationSearch();
        searchSetupDone = true;
      }
      if (!map) {
        setTimeout(initMap, 100);
      }
    }
    
    function closeLocationPicker() {
      document.getElementById('locationModal').classList.remove('active');
    }
    
    function setupLocationSearch() {
      const searchInput = document.getElementById('locationSearch');
      const resultsDiv = document.getElementById('searchResults');
      const searchStatus = document.getElementById('searchStatus');
      let currentRequest = null;
      
      searchInput.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        const query = this.value.trim();
        
        if (query.length < 2) {
          resultsDiv.style.display = 'none';
          searchStatus.textContent = '';
          if (currentRequest) currentRequest.abort();
          return;
        }
        
        searchStatus.textContent = 'Searching...';
        searchStatus.style.animation = 'pulse 1s infinite';
        
        searchTimeout = setTimeout(async () => {
          try {
            if (currentRequest) currentRequest.abort();
            currentRequest = new AbortController();
            
            const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)},Nepal&countrycodes=np&limit=8&addressdetails=1`, {
              headers: {'Accept-Language': 'en'},
              signal: currentRequest.signal
            });
            const results = await res.json();
            
            searchStatus.textContent = '';
            searchStatus.style.animation = '';
            
            if (results.length > 0) {
              resultsDiv.style.display = 'block';
              resultsDiv.innerHTML = results.map(loc => {
                const icon = getLocationIcon(loc.type);
                const name = loc.display_name.split(',')[0];
                const addr = loc.display_name.split(',').slice(1, 3).join(',');
                return `<div class="search-result-item" onclick='selectPlace(${JSON.stringify(loc.display_name)}, ${loc.lat}, ${loc.lon})'><div class="search-result-icon">${icon}</div><div class="search-result-content"><div class="search-result-title">${name}</div><div class="search-result-subtitle">${addr}</div></div></div>`;
              }).join('');
            } else {
              resultsDiv.style.display = 'block';
              resultsDiv.innerHTML = `<div style="padding:16px; text-align:center; color:#999; font-size:12px;">
                <div style="margin-bottom:8px;">No results for "${query}"</div>
                <div style="font-size:11px; color:#aaa;">Try different keywords</div>
              </div>`;
            }
          } catch (e) {
            if (e.name !== 'AbortError') {
              searchStatus.textContent = '';
              searchStatus.style.animation = '';
              resultsDiv.style.display = 'block';
              resultsDiv.innerHTML = '<div style="padding:16px; text-align:center; color:#e74c3c; font-size:12px;">Search failed</div>';
            }
          }
        }, 150);
      });
    }
    
    function getLocationIcon(type) {
      const icons = {school: '🏫', university: '🎓', college: '🎓', hospital: '🏥', clinic: '🏥', doctor: '🏥', restaurant: '🍽️', cafe: '☕', food: '🍔', hotel: '🏨', lodging: '🏨', mall: '🏬', shop: '🏪', store: '🏪', park: '🌳', garden: '🌿', temple: '🛕', church: '⛪', mosque: '🕌', airport: '✈️', bus_station: '🚌', train_station: '🚆', bank: '🏦', atm: '🏧', police: '👮', fire_station: '🚒', post_office: '🏤', library: '📚', stadium: '🏟️', gym: '🏋️'};
      return icons[type] || '📍';
    }
    
    function selectPlace(name, lat, lng) {
      selectedAddress = name;
      selectedLat = parseFloat(lat);
      selectedLng = parseFloat(lng);
      document.getElementById('locationSearch').value = name.split(',')[0];
      document.getElementById('searchResults').style.display = 'none';
      if (!map) initMap();
      if (map && marker) {
        map.setView([selectedLat, selectedLng], 16, {animate: false});
        marker.setLatLng([selectedLat, selectedLng]);
      }
      updateLocationDisplay();
    }
    
    function initMap() {
      if (map) return;
      
      map = L.map('locationMap', {
        center: [selectedLat, selectedLng],
        zoom: 14,
        zoomControl: true,
        attributionControl: true,
        preferCanvas: true
      });
      
      L.tileLayer('https://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}', {
        maxZoom: 20,
        subdomains: ['mt0', 'mt1', 'mt2', 'mt3'],
        attribution: '© Google',
        updateWhenIdle: true,
        updateWhenZooming: false,
        keepBuffer: 2
      }).addTo(map);
      
      marker = L.marker([selectedLat, selectedLng], {draggable: true}).addTo(map);
      
      marker.on('dragend', function() {
        const pos = marker.getLatLng();
        selectedLat = pos.lat;
        selectedLng = pos.lng;
        selectedAddress = '';
        updateLocationDisplay();
      });
      
      map.on('click', function(e) {
        selectedLat = e.latlng.lat;
        selectedLng = e.latlng.lng;
        marker.setLatLng([selectedLat, selectedLng]);
        selectedAddress = '';
        updateLocationDisplay();
      });
      
      setTimeout(() => map.invalidateSize(), 100);
    }
    
    async function updateLocationDisplay() {
      let displayText = selectedAddress || `${selectedLat.toFixed(6)}, ${selectedLng.toFixed(6)}`;
      
      if (!selectedAddress) {
        try {
          const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${selectedLat}&lon=${selectedLng}&zoom=18&addressdetails=1`);
          const data = await res.json();
          if (data.address) {
            const addr = data.address;
            const parts = [];
            
            // Priority: specific locations first
            if (addr.road) parts.push(addr.road);
            else if (addr.neighbourhood) parts.push(addr.neighbourhood);
            else if (addr.suburb) parts.push(addr.suburb);
            
            if (addr.amenity) parts.unshift(addr.amenity);
            if (addr.building) parts.unshift(addr.building);
            if (addr.shop) parts.unshift(addr.shop);
            if (addr.tourism) parts.unshift(addr.tourism);
            
            if (addr.city || addr.town || addr.village) {
              parts.push(addr.city || addr.town || addr.village);
            }
            
            displayText = parts.length > 0 ? parts.join(', ') : data.display_name.split(',').slice(0, 3).join(',');
            selectedAddress = displayText;
          } else if (data.display_name) {
            displayText = data.display_name.split(',').slice(0, 3).join(',');
            selectedAddress = displayText;
          }
        } catch (e) {}
      }
      
      document.getElementById('selectedLocationText').textContent = displayText;
      document.getElementById('selectedCoords').textContent = `${selectedLat.toFixed(6)}, ${selectedLng.toFixed(6)}`;
    }
    
    function getCurrentLocation() {
      if (navigator.geolocation) {
        const btn = event.target;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<span>⏳</span> Getting...';
        btn.disabled = true;
        
        navigator.geolocation.getCurrentPosition(
          (position) => {
            selectedLat = position.coords.latitude;
            selectedLng = position.coords.longitude;
            selectedAddress = '';
            if (!map) initMap();
            if (map && marker) {
              map.setView([selectedLat, selectedLng], 16, {animate: false});
              marker.setLatLng([selectedLat, selectedLng]);
            }
            updateLocationDisplay();
            btn.innerHTML = originalText;
            btn.disabled = false;
          },
          () => {
            alert('Enable location access in your browser.');
            btn.innerHTML = originalText;
            btn.disabled = false;
          }
        );
      }
    }
    
    function confirmLocation() {
      if (selectedLat && selectedLng) {
        const address = selectedAddress || document.getElementById('selectedLocationText').textContent;
        const fullAddress = `${address} (${selectedLat.toFixed(6)}, ${selectedLng.toFixed(6)})`;
        document.getElementById('address').value = fullAddress;
        document.getElementById('latitude').value = selectedLat.toFixed(6);
        document.getElementById('longitude').value = selectedLng.toFixed(6);
        closeLocationPicker();
      } else {
        alert('Please select a location on the map.');
      }
    }
  </script>
</body>
</html>
