<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Checkout | Cropsay</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/style.blue.css" />
  <link rel="stylesheet" href="/custom-theme.css?v=<%= Date.now() %>" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@300;400;700&display=swap" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="preload" as="image" href="https://i.postimg.cc/c42fF8HH/esewa.png" />
  <link rel="preload" as="image" href="https://i.postimg.cc/GhVvXs2r/Cod.png" />

  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <style>
  html{height:100%;}
  body{font-family:'Libre Franklin',Arial,sans-serif; background:#fafbfc; display:flex; flex-direction:column; min-height:100vh; padding-top:70px; overflow-x:hidden;}
  .main-content{flex:1 0 auto; padding-bottom:20px;}
  nav.navbar{box-shadow:0 1px 3px rgba(0,0,0,.08); background:#fff;}
  .breadcrumb-inline{font-size:10px; letter-spacing:1px; text-transform:uppercase; margin:8px 0 12px; opacity:.7;}
  .breadcrumb{background:transparent; padding:0; margin:0;}
  .breadcrumb-item+.breadcrumb-item::before{content:'/'; padding:0 5px; color:#999;}
  .section-heading{font-size:13px; font-weight:700; letter-spacing:1.2px; margin:0 0 12px; color:#1a1a1a; text-transform:uppercase;}
  .form-group{margin-bottom:10px;}
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0;}
  .form-control, .custom-select{border-radius:8px; border:1px solid #e1e4e8; font-size:13px; height:42px; transition:all .25s ease; padding:8px 14px; background:#fff; box-shadow:0 1px 2px rgba(0,0,0,.04);}
  .form-control:focus, .custom-select:focus{box-shadow:0 0 0 3px rgba(0,0,0,.06), 0 1px 3px rgba(0,0,0,.1); border-color:#333; background:#fff; outline:none;}
  .form-control::placeholder{color:#a0a0a0; font-size:13px;}
  textarea.form-control{height:auto; min-height:60px; resize:vertical;}
  .checkout-grid-row{margin-bottom:0;}
  .summary-box{background:#fff; padding:20px 22px 18px; border-radius:10px; border:1px solid #e8eaed; box-shadow:0 2px 12px rgba(0,0,0,.08), 0 1px 3px rgba(0,0,0,.04);}
  .summary-box h5{font-size:14px; letter-spacing:.8px; font-weight:700; margin-bottom:12px; color:#1a1a1a; text-transform:uppercase;}
  .summary-box hr{margin:8px 0 10px; border:0; border-top:1px solid #e8eaed;}    
  .summary-box .line{display:flex; justify-content:space-between; font-size:13px; padding:4px 0; color:#333;}
  .summary-total{font-weight:700; font-size:15px; letter-spacing:.5px; color:#000;}
  .back-cart-btn{border:1px solid #e1e4e8; background:#fff; padding:9px 16px; font-size:12px; letter-spacing:.3px; display:inline-flex; align-items:center; font-weight:500; border-radius:8px; transition:all .25s ease; box-shadow:0 1px 3px rgba(0,0,0,.06);}
  .back-cart-btn:hover{text-decoration:none; background:#000; color:#fff; border-color:#000; box-shadow:0 2px 6px rgba(0,0,0,.15);}
  .place-order-btn{background:linear-gradient(135deg, #000 0%, #1a1a1a 100%); color:#fff; border:none; height:48px; width:100%; font-weight:600; letter-spacing:.6px; transition:all .25s ease; border-radius:8px; font-size:14px; box-shadow:0 3px 10px rgba(0,0,0,.15), 0 1px 3px rgba(0,0,0,.1);}
  .place-order-btn:hover{background:linear-gradient(135deg, #1a1a1a 0%, #333 100%); box-shadow:0 4px 14px rgba(0,0,0,.2), 0 2px 4px rgba(0,0,0,.12); transform:translateY(-1px);}
  .place-order-btn:active{transform:translateY(0); box-shadow:0 2px 6px rgba(0,0,0,.15);}    
  footer{margin-top:0; flex-shrink:0;}
  .helper-text{color:#6c757d; font-size:10px; display:block; margin-top:3px; line-height:1.3;}
  .payment-container{display:flex; gap:8px; flex-wrap:wrap;}
  .payment-method-label{cursor:pointer; border:2px solid #ddd; border-radius:8px; padding:12px 16px; display:flex; align-items:center; justify-content:center; gap:8px; transition:all .25s ease; background:#fff; flex:1; min-width:140px;}
  .payment-method-label:hover{border-color:#4caf50; transform:translateY(-2px); box-shadow:0 4px 10px rgba(0,0,0,.1);}
  .payment-method-label.active{border-color:#4caf50; background:#f1f8f4; box-shadow:0 2px 8px rgba(76,175,80,.2);}
  #esewaModal{display:none; position:fixed; inset:0; background:rgba(0,0,0,.75); z-index:9999; align-items:center; justify-content:center; backdrop-filter:blur(4px); padding:20px; animation:fadeIn .3s ease;}
  #esewaModal.active{display:flex;}
  .esewa-modal-content{background:#fff; border-radius:16px; max-width:480px; width:100%; box-shadow:0 20px 60px rgba(0,0,0,.3); animation:slideUp .3s ease; overflow:hidden;}
  .esewa-modal-header{padding:16px 20px; background:linear-gradient(135deg, #4caf50 0%, #45a049 100%); color:#fff; display:flex; justify-content:space-between; align-items:center;}
  .esewa-modal-header h3{margin:0; font-size:18px; font-weight:700; display:flex; align-items:center; gap:8px;}
  .esewa-close-btn{background:rgba(255,255,255,.2); border:none; color:#fff; font-size:24px; cursor:pointer; padding:0; width:32px; height:32px; display:flex; align-items:center; justify-content:center; border-radius:50%; transition:all .2s;}
  .esewa-close-btn:hover{background:rgba(255,255,255,.3); transform:rotate(90deg);}
  .esewa-modal-body{padding:24px; text-align:center;}
  .esewa-qr-container{background:#f8f9fa; padding:16px; border-radius:12px; margin-bottom:16px; display:inline-block;}
  .esewa-actions{display:flex; gap:10px; margin-top:20px;}
  .esewa-btn{flex:1; padding:12px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; transition:all .2s; border:none; box-shadow:0 2px 6px rgba(0,0,0,.1);}
  .esewa-btn-primary{background:#4caf50; color:#fff;}
  .esewa-btn-primary:hover{background:#45a049; transform:translateY(-1px); box-shadow:0 4px 10px rgba(0,0,0,.15);}
  .esewa-btn-secondary{background:#f5f5f5; color:#333;}
  .esewa-btn-secondary:hover{background:#e0e0e0;}
  .screenshot-preview{margin-top:12px; padding:12px; background:#f8f9fa; border-radius:8px; display:none;}
  .screenshot-preview.show{display:block;}
  .screenshot-preview img{width:100px; height:100px; border-radius:8px; object-fit:cover; box-shadow:0 2px 6px rgba(0,0,0,.1);}
  #celebrate{position:fixed; inset:0; background:rgba(0,0,0,.75); display:flex; align-items:center; justify-content:center; z-index:9999; opacity:0; pointer-events:none; transition:opacity .4s ease; backdrop-filter:blur(4px);}
  #celebrate.active{opacity:1; pointer-events:auto;}
  #celebrate .celebrate-box{background:#fff; padding:40px 32px 36px; border-radius:16px; max-width:380px; width:90%; text-align:center; position:relative; box-shadow:0 20px 60px rgba(0,0,0,.3), 0 8px 20px rgba(0,0,0,.15);}    
  #celebrate .icon-circle{width:70px; height:70px; border-radius:50%; background:linear-gradient(135deg, #000 0%, #1a1a1a 100%); display:flex; align-items:center; justify-content:center; font-size:36px; color:#fff; margin:-80px auto 20px; box-shadow:0 8px 24px rgba(0,0,0,.3);} 
  #celebrate h2{font-size:26px; letter-spacing:.5px; font-weight:700; margin-bottom:8px; color:#1a1a1a;}
  #celebrate p{font-size:13px; color:#555; margin-bottom:5px;}
  #celebrate .btn{border-radius:8px; padding:11px 24px; font-weight:600; letter-spacing:.5px; font-size:13px; box-shadow:0 2px 8px rgba(0,0,0,.15);}
  #confettiCanvas{position:absolute; inset:0; width:100%; height:100%; pointer-events:none;}
  .form-section{background:#fff; padding:20px; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,.06), 0 1px 3px rgba(0,0,0,.04); border:1px solid #e8eaed;}
  .location-picker-wrapper{position:relative;}
  .location-picker-wrapper .form-control{padding-right:45px !important;}
  .location-btn{position:absolute; right:8px; top:50%; transform:translateY(-50%); background:#333; color:#fff; border:none; border-radius:6px; width:30px; height:30px; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all .3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow:none; z-index:5; padding:0;}
  .location-btn:hover{background:#444; transform:translateY(-50%) scale(1.05);}
  .location-btn:active{transform:translateY(-50%) scale(0.95);}
  .location-btn i{font-size:14px; transition:transform .3s cubic-bezier(0.4, 0, 0.2, 1);}
  .location-btn:hover i{transform:scale(1.05);}
  #locationModal{display:none; position:fixed; inset:0; background:rgba(0,0,0,.8); z-index:9998; align-items:center; justify-content:center; backdrop-filter:blur(6px); padding:20px; animation:fadeIn .3s ease; overflow:auto;}
  #locationModal.active{display:flex;}
  .location-modal-content{background:#fff; border-radius:16px; width:100%; max-width:600px; height:auto; max-height:calc(100vh - 40px); overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.4); display:flex; flex-direction:column; animation:slideUp .3s ease;}
  @keyframes fadeIn{from{opacity:0;} to{opacity:1;}}
  @keyframes slideUp{from{transform:translateY(20px); opacity:0;} to{transform:translateY(0); opacity:1;}}
  .location-modal-header{padding:14px 18px; border-bottom:1px solid #e0e0e0; display:flex; justify-content:space-between; align-items:center; background:#fff; flex-shrink:0;}
  .location-modal-header h3{margin:0; font-size:16px; font-weight:700; color:#1a1a1a; display:flex; align-items:center; gap:8px;}
  .location-close-btn{background:#f5f5f5; border:none; font-size:18px; color:#666; cursor:pointer; padding:0; width:32px; height:32px; display:flex; align-items:center; justify-content:center; border-radius:50%; transition:all .2s;}
  .location-close-btn:hover{background:#e0e0e0; color:#000; transform:rotate(90deg);}
  .location-search-input{width:100%; padding:12px 16px; border:2px solid #e0e0e0; border-radius:10px; font-size:14px; transition:all .2s; background:#fafafa; font-weight:400;}
  .location-search-input:focus{outline:none; border-color:#000; box-shadow:0 2px 8px rgba(0,0,0,.08); background:#fff;}
  .location-search-input::placeholder{color:#aaa; font-weight:400;}
  .search-status{position:absolute; right:16px; top:50%; transform:translateY(-50%); font-size:10px; color:#999; pointer-events:none; font-weight:500;}
  @keyframes pulse{0%, 100%{opacity:1;} 50%{opacity:.5;}}

  .location-modal-body{flex:1; display:flex; flex-direction:column; overflow:auto; position:relative; min-height:0;}
  .location-search-wrapper{padding:12px 16px; background:#fff; position:relative; z-index:10; flex-shrink:0;}
  #locationMap{width:100%; height:280px; z-index:1; flex-shrink:0; background:#f5f5f5;}
  .leaflet-container{font-family:'Libre Franklin',Arial,sans-serif; font-size:13px;}
  .map-overlay-controls{position:absolute; top:12px; right:12px; z-index:1000; display:flex; flex-direction:column; gap:8px;}
  .current-location-btn{background:#fff; color:#1a1a1a; border:none; padding:10px 16px; border-radius:50px; cursor:pointer; box-shadow:0 2px 8px rgba(0,0,0,.15); font-size:12px; font-weight:600; transition:all .2s; display:flex; align-items:center; gap:6px;}
  .current-location-btn:hover{background:#1a1a1a; color:#fff; transform:translateY(-1px); box-shadow:0 4px 12px rgba(0,0,0,.25);}
  .current-location-btn:active{transform:translateY(0);}
  .leaflet-control-attribution{font-size:9px !important; background:rgba(255,255,255,.9) !important;}
  .location-info{padding:12px 16px; background:#fff; border-top:1px solid #e0e0e0; flex-shrink:0;}
  .location-info-card{background:#f8f9fa; padding:12px; border-radius:10px; border:1px solid #e8eaed;}
  .location-info-label{font-weight:600; color:#666; margin-bottom:6px; font-size:10px; text-transform:uppercase; letter-spacing:.6px; display:flex; align-items:center; gap:4px;}
  .location-info-text{color:#1a1a1a; font-size:13px; margin-bottom:4px; font-weight:600; line-height:1.3;}
  .location-info-coords{color:#888; font-size:11px; font-family:monospace; background:#fff; padding:4px 8px; border-radius:4px; display:inline-block; margin-top:2px;}
  .location-modal-footer{padding:12px 16px; border-top:1px solid #e0e0e0; display:flex; gap:10px; justify-content:space-between; background:#fff; flex-shrink:0;}
  .location-btn-primary{background:#000; color:#fff; padding:12px 28px; border-radius:50px; font-size:13px; font-weight:600; border:none; cursor:pointer; transition:all .2s; flex:1; box-shadow:0 2px 8px rgba(0,0,0,.2);}
  .location-btn-primary:hover{background:#1a1a1a; transform:translateY(-1px); box-shadow:0 4px 12px rgba(0,0,0,.3);}
  .location-btn-primary:active{transform:translateY(0);}
  .location-btn-secondary{background:#f5f5f5; color:#1a1a1a; border:none; padding:12px 20px; border-radius:50px; font-size:13px; font-weight:600; cursor:pointer; transition:all .2s;}
  .location-btn-secondary:hover{background:#e0e0e0;}
  .search-result-item{padding:10px 12px; cursor:pointer; border-bottom:1px solid #f0f0f0; font-size:12px; transition:all .2s; display:flex; align-items:start; gap:10px; background:#fff;}
  .search-result-item:hover{background:#f8f9fa; padding-left:16px; border-left:3px solid #000;}
  .search-result-item:active{background:#f0f0f0;}
  .search-result-item:last-child{border-bottom:none;}
  .search-result-icon{font-size:18px; margin-top:1px; opacity:.8;}
  .search-result-content{flex:1; min-width:0;}
  .search-result-title{font-weight:600; color:#1a1a1a; margin-bottom:3px; font-size:13px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .search-result-subtitle{font-size:11px; color:#888; line-height:1.3; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .search-results-container{max-height:200px; overflow-y:auto; border-radius:10px; background:#fff; box-shadow:0 2px 12px rgba(0,0,0,.12); margin-top:10px; border:1px solid #e0e0e0;}
  .search-results-container::-webkit-scrollbar{width:5px;}
  .search-results-container::-webkit-scrollbar-track{background:#f5f5f5;}
  .search-results-container::-webkit-scrollbar-thumb{background:#ccc; border-radius:3px;}
  .search-results-container::-webkit-scrollbar-thumb:hover{background:#999;}
  @keyframes fadeIn{from{opacity:0;} to{opacity:1;}}
  @keyframes slideUp{from{transform:translateY(30px); opacity:0;} to{transform:translateY(0); opacity:1;}}
  @media (min-width:768px){
    .location-modal-content{max-width:580px;}
    #locationMap{height:320px;}
  }
  @media (min-width:1024px){
    .location-modal-content{max-width:620px;}
    #locationMap{height:340px;}
  }
  @media (max-width:767.98px){
    #locationModal{padding:0;}
    .location-modal-content{border-radius:0; max-width:100%; max-height:100%; height:100%;}
    .location-modal-header{padding:12px 16px;}
    .location-modal-header h3{font-size:15px;}
    .location-search-wrapper{padding:10px 16px;}
    .location-search-input{padding:10px 14px; font-size:13px;}
    .search-status{right:14px; font-size:9px;}
    #locationMap{height:calc(100vh - 320px); min-height:250px;}
    .location-info{padding:10px 16px;}
    .location-info-card{padding:10px;}
    .location-info-text{font-size:12px;}
    .location-info-coords{font-size:10px;}
    .location-modal-footer{padding:10px 16px; flex-direction:column-reverse;}
    .location-btn-primary, .location-btn-secondary{width:100%; padding:11px;}
    .map-overlay-controls{top:10px; right:10px;}
    .current-location-btn{padding:8px 12px; font-size:11px;}
    .search-results-container{max-height:150px;}
  }
  
  /* Mobile optimizations */
  @media (max-width:991.98px){ 
    .summary-box{margin-top:20px;} 
    body{padding-top:65px;}
  }
  @media (max-width:767.98px){ 
    body{padding-top:60px; background:#fff;}
    .payment-container{gap:6px;}
    .payment-method-label{padding:10px 14px; min-width:120px;}
    #esewaModal{padding:0;}
    .esewa-modal-content{border-radius:0; max-width:100%; height:100%;}
    .esewa-modal-body{padding:20px;}
    .esewa-actions{flex-direction:column-reverse;}
    .main-content{padding-bottom:15px;}
    .breadcrumb-inline{margin:6px 0 10px;}
    .section-heading{font-size:12px; margin-bottom:10px;}
    .form-group{margin-bottom:8px;}
    .form-control, .custom-select{height:40px; font-size:13px; padding:8px 12px; border-radius:6px;}
    textarea.form-control{min-height:55px;}
    .helper-text{font-size:9px; margin-top:2px;}
    .summary-box{padding:16px 18px 14px; margin-top:15px; border-radius:8px;}
    .summary-box h5{font-size:13px; margin-bottom:10px;}
    .summary-box .line{font-size:12px; padding:3px 0;}
    .summary-total{font-size:14px;}
    .place-order-btn{height:44px; margin-top:8px; font-size:13px; border-radius:6px;}
    .back-cart-btn{padding:8px 14px; font-size:11px; border-radius:6px;}
    .form-section{padding:16px; border-radius:8px;}
    footer{margin-top:20px; font-size:12px;}
    footer .container{padding-top:16px !important; padding-bottom:16px !important;}
    #celebrate .celebrate-box{padding:32px 24px 28px; border-radius:12px;}
    #celebrate .icon-circle{width:60px; height:60px; font-size:30px; margin:-70px auto 16px;}
    #celebrate h2{font-size:22px;}
    #celebrate p{font-size:12px;}
  }
  @media (max-width:575.98px){
    .checkout-grid-row .col-md-6{padding-left:15px; padding-right:15px;}
  }
  </style>
</head>
<body>
  <nav class="navbar navbar-light fixed-top py-0 px-2">
    <div class="container px-0 px-lg-3 d-flex align-items-center justify-content-between">
  <a class="navbar-brand" href="/"><img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" height="60" /></a>
      <ul class="navbar-nav ml-auto phone-in-navbar" style="display:flex; flex-direction:row;">
        <li class="nav-item"><a class="nav-link" href="tel:9814789009"><i class="fas fa-phone-alt"></i> 9814789009<sup><small> NP</small></sup></a></li>
      </ul>
    </div>
  </nav>
  <!-- Removed spacer div; body now has padding-top to account for fixed navbar -->

  <div class="container main-content">
    <div class="breadcrumb-inline">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb px-0 mb-0">
          <li class="breadcrumb-item"><a href="/">Home</a></li>
          <li class="breadcrumb-item"><a href="/cart/">Cart</a></li>
          <li class="breadcrumb-item active" aria-current="page">Checkout</li>
        </ol>
      </nav>
    </div>
    <form id="checkout-form" class="mb-5">
      <div class="row">
        <div class="col-lg-8 mobile-stack">
          <div class="form-section">
          <div class="section-heading">Delivery Details</div>
          <div class="row checkout-grid-row">
            <div class="col-md-6 form-group">
              <label class="sr-only" for="name">Name *</label>
              <input id="name" class="form-control" placeholder="Name *" required />
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="mobile">WhatsApp Number *</label>
              <input id="mobile" class="form-control" placeholder="WhatsApp Number *" type="tel" pattern="[0-9]{10}" maxlength="10" required />
              <small class="helper-text">OTP verification required</small>
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="region">Region</label>
              <select id="region" class="custom-select"><option>Inside Valley</option><option>Outside Valley</option></select>
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="area">Area / District</label>
              <div style="position:relative;">
                <input type="text" id="areaDisplay" class="form-control" placeholder="Click to search area / district..." autocomplete="off" readonly style="cursor:pointer; background:#fff;" />
                <input type="hidden" id="areaValue" />
                <div id="areaDropdown" style="display:none; position:absolute; top:100%; left:0; right:0; background:#fff; border:1px solid #e1e4e8; border-radius:8px; max-height:250px; overflow-y:auto; z-index:1000; box-shadow:0 4px 12px rgba(0,0,0,.15); margin-top:4px;">
                  <input type="text" id="areaSearch" class="form-control" placeholder="Type to search..." autocomplete="off" style="border:none; border-bottom:2px solid #e1e4e8; border-radius:8px 8px 0 0; margin:0; box-shadow:none;" />
                  <div id="areaList" style="max-height:200px; overflow-y:auto;"></div>
                </div>
              </div>
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="email">Email (Optional)</label>
              <input id="email" type="email" class="form-control" placeholder="Email (Optional)" />
            </div>
            <div class="col-md-6 form-group">
              <label class="sr-only" for="address">Detailed Address *</label>
              <div class="location-picker-wrapper">
                <input id="address" class="form-control" placeholder="Detailed Address *" required />
                <button type="button" class="location-btn" onclick="openLocationPicker()" title="Pick location on map">
                  <i class="fas fa-map-marker-alt"></i>
                </button>
              </div>
              <input type="hidden" id="latitude" />
              <input type="hidden" id="longitude" />
            </div>
            <div class="col-12 form-group">
              <label class="sr-only" for="notes">Order Notes (Optional)</label>
              <textarea id="notes" class="form-control" placeholder="Order Notes (Optional)" rows="2"></textarea>
            </div>
            <div class="col-12 form-group mb-0">
              <a href="/cart/" class="back-cart-btn"><span style="font-size:14px; line-height:0;" class="mr-1">&larr;</span> Change Cart</a>
            </div>
            <div class="col-12 form-group">
