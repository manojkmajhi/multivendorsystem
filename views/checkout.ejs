  <script>
    // Load eSewa QR code
    let qrImageUrl = '';
    const preloadQr = new Image();
    preloadQr.src = 'https://i.postimg.cc/mDPmcWp9/Whats-App-Image-2025-10-14-at-16-17-59-1cdf0cb6.jpg';
    
    fetch('/api/payment-settings')
      .then(r => r.json())
      .then(data => {
        qrImageUrl = data.esewa_qr || 'https://i.postimg.cc/mDPmcWp9/Whats-App-Image-2025-10-14-at-16-17-59-1cdf0cb6.jpg';
        document.getElementById('esewaQrImageModal').src = qrImageUrl;
      })
      .catch(() => {
        qrImageUrl = 'https://i.postimg.cc/mDPmcWp9/Whats-App-Image-2025-10-14-at-16-17-59-1cdf0cb6.jpg';
        document.getElementById('esewaQrImageModal').src = qrImageUrl;
      });
    
    // eSewa modal functions
    function openEsewaModal() {
      document.getElementById('esewaModal').classList.add('active');
    }
    
    window.closeEsewaModal = function() {
      document.getElementById('esewaModal').classList.remove('active');
    };
    
    // Close modal on outside click
    document.getElementById('esewaModal').addEventListener('click', function(e) {
      if(e.target.id === 'esewaModal') closeEsewaModal();
    });
    
    // Download QR from modal
    document.getElementById('downloadQrModal').addEventListener('click', async function(e){
      e.preventDefault();
      try {
        const response = await fetch(qrImageUrl);
        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'esewa-qr.jpg';
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
        document.body.removeChild(a);
      } catch(err) {
        window.open(qrImageUrl, '_blank');
      }
    });
    
