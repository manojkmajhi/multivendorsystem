<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Our Farmers - <%= siteSetting.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="fixed top-0 w-full bg-white shadow-sm z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center">
          <img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" alt="<%= (siteSetting && siteSetting.name) || 'All Strawhats' %>" class="h-12 w-auto">
        </a>
        <div class="flex items-center gap-2">
          <a href="/farmers/signup" class="px-4 py-2 text-sm font-medium text-green-600 hover:bg-green-50 rounded-lg transition-colors">Farmer Signup</a>
          <a href="/farmers/login" class="px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-lg transition-colors">Farmer Login</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="pt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Meet Our Farmers</h1>
        <p class="text-gray-600">Connect with our network of dedicated organic farmers</p>
      </div>

      <!-- Search & Filter -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <div class="relative">
          <input type="text" id="searchFarmers" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" placeholder="Search farmers by name or location...">
          <i class="fas fa-search absolute right-3 top-3 text-gray-400"></i>
        </div>
        <select id="filterCategory" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition">
          <option value="">All Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.name %>"><%= cat.name %></option>
          <% }); %>
        </select>
      </div>

      <!-- Farmers Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="farmersGrid">
        <!-- Apply Card (First Position) -->
        <div class="farmer-apply-card cursor-pointer group" onclick="document.getElementById('applyModal').classList.remove('hidden')">
          <div class="h-full bg-gradient-to-br from-green-50 to-green-100 border-2 border-dashed border-green-400 rounded-lg p-6 text-center hover:shadow-lg transition-all duration-300 flex flex-col items-center justify-center">
            <div class="w-16 h-16 bg-green-500 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
              <i class="fas fa-plus text-2xl text-white"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Become a Seller</h3>
            <p class="text-sm text-gray-600">Join our platform and sell your organic products</p>
          </div>
        </div>

        <!-- Farmer Cards -->
        <% farmers.forEach(farmer => { %>
          <div class="farmer-item" data-name="<%= farmer.full_name.toLowerCase() %>" data-location="<%= (farmer.location || '').toLowerCase() %>">
            <div class="bg-white rounded-lg shadow-sm hover:shadow-xl transition-all duration-300 cursor-pointer transform hover:-translate-y-2 overflow-hidden group" onclick="window.location='/farmers/<%= farmer.id %>'">
              <div class="p-6 text-center">
                <img src="<%= farmer.profile_image || '/staticfiles/default-avatar.png' %>" alt="<%= farmer.full_name %>" class="w-20 h-20 rounded-full mx-auto mb-4 object-cover border-4 border-green-100">
                <h3 class="text-lg font-semibold text-gray-900 mb-1"><%= farmer.full_name %></h3>
                <% if (farmer.business_name) { %>
                  <p class="text-sm text-gray-600 mb-2"><%= farmer.business_name %></p>
                <% } %>
                <% if (farmer.location) { %>
                  <p class="text-xs text-gray-500 flex items-center justify-center gap-1">
                    <i class="fas fa-map-marker-alt text-green-600"></i> <%= farmer.location %>
                  </p>
                <% } %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </div>

  <!-- Apply Modal -->
  <div id="applyModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full fade-in">
      <!-- Modal Header -->
      <div class="flex items-center justify-between p-6 border-b border-gray-200">
        <h2 class="text-2xl font-bold text-gray-900">Apply to Become a Farmer/Seller</h2>
        <button onclick="document.getElementById('applyModal').classList.add('hidden')" class="text-gray-500 hover:text-gray-700 text-2xl">&times;</button>
      </div>

      <!-- Modal Body -->
      <form id="applyForm" class="p-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
          <input type="text" name="full_name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" required>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number *</label>
          <input type="tel" name="phone" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" required>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" name="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Business/Farm Name</label>
          <input type="text" name="business_name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Location</label>
          <input type="text" name="location" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tell us about yourself</label>
          <textarea name="message" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" rows="3"></textarea>
        </div>

        <!-- Modal Footer -->
        <div class="flex gap-3 pt-4">
          <button type="button" onclick="document.getElementById('applyModal').classList.add('hidden')" class="flex-1 px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
          <button type="submit" class="flex-1 px-4 py-2 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors">Submit Application</button>
        </div>
      </form>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script>
    // Search functionality
    $('#searchFarmers').on('input', function() {
      const query = $(this).val().toLowerCase();
      $('.farmer-item').each(function() {
        const name = $(this).data('name');
        const location = $(this).data('location');
        if (name.includes(query) || location.includes(query)) {
          $(this).show();
        } else {
          $(this).hide();
        }
      });
    });

    // Apply form submission
    $('#applyForm').on('submit', function(e) {
      e.preventDefault();
      const formData = {
        full_name: $('input[name="full_name"]').val(),
        phone: $('input[name="phone"]').val(),
        email: $('input[name="email"]').val(),
        business_name: $('input[name="business_name"]').val(),
        location: $('input[name="location"]').val(),
        message: $('textarea[name="message"]').val()
      };
      
      $.post('/api/farmer-applications', formData)
        .done(function(res) {
          alert('Application submitted successfully! We will review and contact you soon.');
          document.getElementById('applyModal').classList.add('hidden');
          $('#applyForm')[0].reset();
        })
        .fail(function() {
          alert('Failed to submit application. Please try again.');
        });
    });

    // Close modal when clicking outside
    document.getElementById('applyModal').addEventListener('click', function(e) {
      if (e.target === this) {
        this.classList.add('hidden');
      }
    });
  </script>
</body>
</html>
