<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Farmer Dashboard - <%= siteSetting.name %></title>
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <link rel="stylesheet" href="/custom-theme.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/"><%= siteSetting.name %></a>
      <div class="ml-auto">
        <span class="text-white mr-3">Welcome, <%= farmer.full_name %></span>
        <form action="/farmers/logout" method="POST" style="display: inline;">
          <button type="submit" class="btn btn-sm btn-outline-light">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <div class="container-fluid mt-4">
    <div class="row">
      <!-- Sidebar -->
      <div class="col-md-2 bg-light p-3">
        <ul class="nav flex-column">
          <li class="nav-item"><a class="nav-link active" href="#profile" data-toggle="tab"><i class="fas fa-user"></i> Profile</a></li>
          <li class="nav-item"><a class="nav-link" href="#products" data-toggle="tab"><i class="fas fa-box"></i> Products</a></li>
          <li class="nav-item"><a class="nav-link" href="#posts" data-toggle="tab"><i class="fas fa-images"></i> Posts</a></li>
        </ul>
      </div>

      <!-- Main Content -->
      <div class="col-md-10">
        <div class="tab-content">
          <!-- Profile Tab -->
          <div id="profile" class="tab-pane fade show active">
            <h3>Edit Profile</h3>
            <form id="profileForm" enctype="multipart/form-data">
              <div class="row">
                <div class="col-md-6">
                  <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="full_name" class="form-control" value="<%= farmer.full_name %>" required>
                  </div>
                  <div class="form-group">
                    <label>Business Name</label>
                    <input type="text" name="business_name" class="form-control" value="<%= farmer.business_name || '' %>">
                  </div>
                  <div class="form-group">
                    <label>Location</label>
                    <input type="text" name="location" class="form-control" value="<%= farmer.location || '' %>">
                  </div>
                  <div class="form-group">
                    <label>Bio</label>
                    <textarea name="bio" class="form-control" rows="4"><%= farmer.bio || '' %></textarea>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-group">
                    <label>Profile Image</label>
                    <input type="file" name="profile_image" class="form-control-file" accept="image/*">
                    <% if (farmer.profile_image) { %>
                      <img src="<%= farmer.profile_image %>" class="mt-2" style="width: 100px; height: 100px; object-fit: cover; border-radius: 50%;">
                    <% } %>
                  </div>
                  <div class="form-group">
                    <label>Cover Image</label>
                    <input type="file" name="cover_image" class="form-control-file" accept="image/*">
                    <% if (farmer.cover_image) { %>
                      <img src="<%= farmer.cover_image %>" class="mt-2" style="width: 200px; height: 100px; object-fit: cover;">
                    <% } %>
                  </div>
                </div>
              </div>
              <button type="submit" class="btn btn-success">Save Profile</button>
            </form>
          </div>

          <!-- Products Tab -->
          <div id="products" class="tab-pane fade">
            <h3>My Products <button class="btn btn-sm btn-success float-right" data-toggle="modal" data-target="#addProductModal">+ Add Product</button></h3>
            <table class="table mt-3">
              <thead>
                <tr><th>Image</th><th>Name</th><th>Price</th><th>Stock</th><th>Status</th></tr>
              </thead>
              <tbody id="productsTable">
                <% products.forEach(p => { %>
                  <tr>
                    <td><img src="<%= p.image %>" style="width: 50px; height: 50px; object-fit: cover;"></td>
                    <td><%= p.name %></td>
                    <td>Rs. <%= p.price %></td>
                    <td><%= p.stock || 0 %></td>
                    <td><span class="badge badge-<%= p.active ? 'success' : 'secondary' %>"><%= p.active ? 'Active' : 'Inactive' %></span></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <!-- Posts Tab -->
          <div id="posts" class="tab-pane fade">
            <h3>My Posts <button class="btn btn-sm btn-success float-right" data-toggle="modal" data-target="#addPostModal">+ Add Post</button></h3>
            <div class="row mt-3" id="postsGrid">
              <% posts.forEach(post => { %>
                <div class="col-md-3 mb-3">
                  <div class="card">
                    <% if (post.media_type === 'image') { %>
                      <img src="<%= post.media_url %>" class="card-img-top" style="height: 150px; object-fit: cover;">
                    <% } else if (post.media_type === 'video') { %>
                      <video class="card-img-top" style="height: 150px; object-fit: cover;" controls>
                        <source src="<%= post.media_url %>">
                      </video>
                    <% } %>
                    <div class="card-body p-2">
                      <p class="small mb-0"><%= post.content || '' %></p>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Product Modal -->
  <div class="modal fade" id="addProductModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Add Product</h5>
          <button type="button" class="close" data-dismiss="modal">&times;</button>
        </div>
        <form id="addProductForm" enctype="multipart/form-data">
          <div class="modal-body">
            <div class="form-group">
              <label>Product Name *</label>
              <input type="text" name="name" class="form-control" required>
            </div>
            <div class="row">
              <div class="col-md-6">
                <div class="form-group">
                  <label>Price *</label>
                  <input type="number" name="price" class="form-control" step="0.01" required>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-group">
                  <label>Stock</label>
                  <input type="number" name="stock" class="form-control" value="0">
                </div>
              </div>
            </div>
            <div class="form-group">
              <label>Short Description</label>
              <textarea name="short_description" class="form-control" rows="2"></textarea>
            </div>
            <div class="form-group">
              <label>Long Description</label>
              <textarea name="long_description" class="form-control" rows="4"></textarea>
            </div>
            <div class="form-group">
              <label>Product Image *</label>
              <input type="file" name="image" class="form-control-file" accept="image/*" required>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-success">Add Product</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Add Post Modal -->
  <div class="modal fade" id="addPostModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Add Post</h5>
          <button type="button" class="close" data-dismiss="modal">&times;</button>
        </div>
        <form id="addPostForm" enctype="multipart/form-data">
          <div class="modal-body">
            <div class="form-group">
              <label>Caption</label>
              <textarea name="content" class="form-control" rows="3"></textarea>
            </div>
            <div class="form-group">
              <label>Media Type *</label>
              <select name="media_type" class="form-control" id="mediaType" required>
                <option value="image">Image</option>
                <option value="video">Video</option>
                <option value="link">Link</option>
              </select>
            </div>
            <div class="form-group" id="fileUpload">
              <label>Upload File *</label>
              <input type="file" name="media_file" class="form-control-file" accept="image/*,video/*">
            </div>
            <div class="form-group" id="linkInput" style="display: none;">
              <label>Media URL *</label>
              <input type="url" name="media_url" class="form-control">
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-success">Post</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Media type toggle
    $('#mediaType').on('change', function() {
      if ($(this).val() === 'link') {
        $('#fileUpload').hide();
        $('#linkInput').show();
      } else {
        $('#fileUpload').show();
        $('#linkInput').hide();
      }
    });

    // Profile form
    $('#profileForm').on('submit', function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      $.ajax({
        url: '/farmers/profile/update',
        method: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function() {
          alert('Profile updated successfully!');
          location.reload();
        },
        error: function() {
          alert('Failed to update profile');
        }
      });
    });

    // Add product form
    $('#addProductForm').on('submit', function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      $.ajax({
        url: '/farmers/products/add',
        method: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function() {
          alert('Product added successfully!');
          location.reload();
        },
        error: function() {
          alert('Failed to add product');
        }
      });
    });

    // Add post form
    $('#addPostForm').on('submit', function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      $.ajax({
        url: '/farmers/posts/add',
        method: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function() {
          alert('Post added successfully!');
          location.reload();
        },
        error: function() {
          alert('Failed to add post');
        }
      });
    });
  </script>
</body>
</html>
