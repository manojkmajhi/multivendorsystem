<!-- OTP Verification Modal -->
<div id="otpVerifyModal" class="user-auth-modal">
  <div class="user-auth-content">
    <button class="user-auth-close" onclick="closeOTPModal()">&times;</button>
    <div style="padding: 32px 28px;">
      <h3>Verify Mobile Number</h3>
      <p class="text-muted small">Enter OTP sent to <strong id="verifyPhone"></strong> via WhatsApp</p>
      <input type="text" id="otpInput" class="form-control" placeholder="Enter 6-digit OTP" maxlength="6" style="font-size: 24px; text-align: center; letter-spacing: 8px; margin: 20px 0;" onkeypress="if(event.key==='Enter')verifyOTP()" oninput="this.value=this.value.replace(/[^0-9]/g,''); if(this.value.length===6){setTimeout(verifyOTP, 300);}" autocomplete="one-time-code">
      <button id="verifyOTPBtn" onclick="verifyOTP()" class="btn btn-dark btn-block" style="height: 48px; font-weight: 600;">Verify OTP</button>
      <div id="otpMessage" style="display: none; margin-top: 15px; padding: 10px; border-radius: 8px; font-size: 13px; text-align: center; font-weight: 500; transition: all 0.3s ease;"></div>
      <p class="text-center text-muted small mt-3">Didn't receive? <a href="#" onclick="resendOTP(); return false;">Resend OTP</a></p>
    </div>
  </div>
</div>

<!-- User Profile Modal -->
<div id="userAuthModal" class="user-auth-modal">
  <div class="user-auth-content">
    <button class="user-auth-close" onclick="closeUserModal()">&times;</button>
    <div style="padding: 32px 28px;">
      <div class="user-profile-header">
        <div class="user-avatar">
          <i class="fas fa-user-circle"></i>
        </div>
        <h4 id="userName">User</h4>
        <p id="userPhone" class="text-muted small"></p>
      </div>
      <div class="user-menu">
        <a href="/track-order" class="user-menu-item">
          <i class="fas fa-box"></i> My Orders
        </a>
        <button onclick="logout()" class="user-menu-item logout-btn">
          <i class="fas fa-sign-out-alt"></i> Logout
        </button>
      </div>
    </div>
  </div>
</div>

<style>
.user-auth-modal {
  display: none;
  position: fixed;
  z-index: 9999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.5);
}

.user-auth-modal.active {
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-auth-content {
  background: white;
  border-radius: 12px;
  width: 90%;
  max-width: 420px;
  position: relative;
  box-shadow: 0 10px 40px rgba(0,0,0,0.2);
}

.user-auth-close {
  position: absolute;
  right: 16px;
  top: 16px;
  font-size: 28px;
  font-weight: 300;
  color: #999;
  background: none;
  border: none;
  cursor: pointer;
  line-height: 1;
  padding: 0;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}

.user-auth-close:hover {
  background: #f5f5f5;
  color: #333;
}

.user-profile-header {
  text-align: center;
  padding-bottom: 20px;
  border-bottom: 1px solid #eee;
}

.user-avatar {
  font-size: 64px;
  color: #333;
  margin-bottom: 12px;
}

.user-profile-header h4 {
  margin: 0 0 4px;
  font-size: 20px;
  font-weight: 600;
}

.user-menu {
  margin-top: 16px;
}

.user-menu-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border: none;
  background: white;
  width: 100%;
  text-align: left;
  font-size: 15px;
  color: #333;
  text-decoration: none;
  border-radius: 8px;
  transition: background 0.2s;
  cursor: pointer;
  margin-bottom: 8px;
}

.user-menu-item:hover {
  background: #f8f8f8;
  text-decoration: none;
  color: #333;
}

.user-menu-item i {
  margin-right: 12px;
  width: 20px;
  font-size: 16px;
}

.logout-btn {
  color: #dc3545;
  margin-top: 8px;
}

.logout-btn:hover {
  background: #fff5f5;
  color: #dc3545;
}
</style>

<script>
let currentUser = null;
let otpCallback = null;
let pendingPhone = '';
let pendingName = '';
let otpOrderId = '';
let isVerifying = false;

function loadUser() {
  const stored = localStorage.getItem('user');
  if (stored) {
    try {
      currentUser = JSON.parse(stored);
      updateUserIcon();
    } catch(e) {
      localStorage.removeItem('user');
    }
  }
}

function updateUserIcon() {
  const icon = document.getElementById('userIcon');
  if (icon && currentUser) {
    icon.classList.add('logged-in');
    icon.title = currentUser.name;
  }
}

function openUserModal() {
  if (currentUser) {
    document.getElementById('userName').textContent = currentUser.name;
    document.getElementById('userPhone').textContent = currentUser.phone;
    document.getElementById('userAuthModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }
}

function closeUserModal() {
  document.getElementById('userAuthModal').classList.remove('active');
  document.body.style.overflow = '';
}

function closeOTPModal() {
  document.getElementById('otpVerifyModal').classList.remove('active');
  document.body.style.overflow = '';
  const msgEl = document.getElementById('otpMessage');
  if (msgEl) msgEl.style.display = 'none';
}

function showOtpMessage(text, type = 'success') {
  const msgEl = document.getElementById('otpMessage');
  if (msgEl) {
    msgEl.textContent = text;
    msgEl.style.display = 'block';
    if (type === 'success') {
      msgEl.style.background = '#e8f5e9';
      msgEl.style.color = '#2e7d32';
      msgEl.style.border = '1px solid #a5d6a7';
    } else {
      msgEl.style.background = '#ffebee';
      msgEl.style.color = '#c62828';
      msgEl.style.border = '1px solid #ef9a9a';
    }
  }
}

function logout() {
  currentUser = null;
  localStorage.removeItem('user');
  const icon = document.getElementById('userIcon');
  if (icon) {
    icon.classList.remove('logged-in');
    icon.title = 'My Account';
  }
  closeUserModal();
}

async function verifyMobileWithOTP(phone, name, callback) {
  otpCallback = callback;
  // Remove any spaces, dashes, or special characters
  const cleanPhone = phone.replace(/[^0-9]/g, '');
  // Add Nepal country code if not present
  pendingPhone = cleanPhone.startsWith('977') ? '+' + cleanPhone : '+977' + cleanPhone;
  pendingName = name;
  
  document.getElementById('verifyPhone').textContent = pendingPhone;
  document.getElementById('otpInput').value = '';
  const msgEl = document.getElementById('otpMessage');
  if (msgEl) msgEl.style.display = 'none';
  document.getElementById('otpVerifyModal').classList.add('active');
  document.body.style.overflow = 'hidden';
  
  // Try WebOTP API for auto-read
  if ('OTPCredential' in window) {
    try {
      const ac = new AbortController();
      setTimeout(() => ac.abort(), 60000); // 1 min timeout
      
      navigator.credentials.get({
        otp: { transport: ['sms'] },
        signal: ac.signal
      }).then(otp => {
        if (otp && otp.code) {
          document.getElementById('otpInput').value = otp.code;
          setTimeout(verifyOTP, 300);
        }
      }).catch(err => {
        console.log('WebOTP not available:', err);
      });
    } catch(e) {
      console.log('WebOTP API not supported');
    }
  }
  
  // Send OTP via server
  try {
    console.log('📱 Sending OTP request...');
    console.log('Phone (before format):', phone);
    console.log('Pending phone (after format):', pendingPhone);
    
    const response = await fetch('/api/send-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone: pendingPhone })
    });
    const data = await response.json();
    console.log('OTP sent:', data);
    if (data.orderId) {
      otpOrderId = data.orderId;
      return true;
    } else {
      showOtpMessage('Failed to send OTP: ' + (data.message || data.errorMessage || 'Unknown error'), 'danger');
      return false;
    }
  } catch(e) {
    console.error('Failed to send OTP:', e);
    showOtpMessage('Failed to send OTP: ' + e.message, 'danger');
    return false;
  }
}

async function verifyOTP() {
  if (isVerifying) return;
  
  const otp = document.getElementById('otpInput').value;
  
  if (!otp || otp.length !== 6) {
    showOtpMessage('Please enter 6-digit OTP', 'danger');
    return;
  }
  
  isVerifying = true;
  const verifyBtn = document.getElementById('verifyOTPBtn');
  if (verifyBtn) {
    verifyBtn.disabled = true;
    verifyBtn.textContent = 'Verifying...';
  }
  
  try {
    const response = await fetch('/api/verify-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone: pendingPhone, otp: otp })
    });
    const data = await response.json();
    
    if (data.success && (data.isOTPVerified || data.verified)) {
      currentUser = {
        phone: pendingPhone,
        name: pendingName,
        verified: true
      };
      localStorage.setItem('user', JSON.stringify(currentUser));
      updateUserIcon();
      closeOTPModal();
      if (otpCallback) {
        otpCallback(true);
      }
    } else {
      isVerifying = false;
      if (verifyBtn) {
        verifyBtn.disabled = false;
        verifyBtn.textContent = 'Verify OTP';
      }
      showOtpMessage('Invalid OTP. Please try again.', 'danger');
      document.getElementById('otpInput').value = '';
      document.getElementById('otpInput').focus();
    }
  } catch(e) {
    console.error('Failed to verify OTP:', e);
    isVerifying = false;
    if (verifyBtn) {
      verifyBtn.disabled = false;
      verifyBtn.textContent = 'Verify OTP';
    }
    showOtpMessage('Failed to verify OTP. Please try again.', 'danger');
  }
}

async function resendOTP() {
  const cleanPhone = pendingPhone.replace(/^\+977/, '');
  const resendBtn = document.querySelector('a[onclick*="resendOTP"]');
  if (resendBtn) {
    resendBtn.style.pointerEvents = 'none';
    resendBtn.style.opacity = '0.5';
  }
  
  showOtpMessage('Resending OTP...', 'success');
  const success = await verifyMobileWithOTP(cleanPhone, pendingName, otpCallback);
  
  if (resendBtn) {
    resendBtn.style.pointerEvents = '';
    resendBtn.style.opacity = '';
  }
  
  if (success) {
    showOtpMessage('OTP has been successfully resent to ' + pendingPhone, 'success');
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', loadUser);
} else {
  loadUser();
}

window.verifyMobileWithOTP = verifyMobileWithOTP;
window.currentUser = currentUser;
</script>
