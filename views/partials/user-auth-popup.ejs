<!-- OTP Verification Modal -->
<div id="otpVerifyModal" class="user-auth-modal">
  <div class="user-auth-content">
    <button class="user-auth-close" onclick="closeOTPModal()">&times;</button>
    <div style="padding: 32px 28px;">
      <h3>Verify Mobile Number</h3>
      <p class="text-muted small">Enter OTP sent to <strong id="verifyPhone"></strong> via WhatsApp</p>
      <input type="text" id="otpInput" class="form-control" placeholder="Enter 6-digit OTP" maxlength="6" style="font-size: 24px; text-align: center; letter-spacing: 8px; margin: 20px 0;" onkeypress="if(event.key==='Enter')verifyOTP()" oninput="if(this.value.length===6)verifyOTP()">
      <button onclick="verifyOTP()" class="btn btn-dark btn-block" style="height: 48px; font-weight: 600;">Verify OTP</button>
      <p class="text-center text-muted small mt-3">Didn't receive? <a href="#" onclick="resendOTP(); return false;">Resend OTP</a></p>
    </div>
  </div>
</div>

<!-- User Profile Modal -->
<div id="userAuthModal" class="user-auth-modal">
  <div class="user-auth-content">
    <button class="user-auth-close" onclick="closeUserModal()">&times;</button>
    <div style="padding: 32px 28px;">
      <div class="user-profile-header">
        <div class="user-avatar">
          <i class="fas fa-user-circle"></i>
        </div>
        <h4 id="userName">User</h4>
        <p id="userPhone" class="text-muted small"></p>
      </div>
      <div class="user-menu">
        <a href="/track-order" class="user-menu-item">
          <i class="fas fa-box"></i> My Orders
        </a>
        <button onclick="logout()" class="user-menu-item logout-btn">
          <i class="fas fa-sign-out-alt"></i> Logout
        </button>
      </div>
    </div>
  </div>
</div>

<style>
.user-auth-modal {
  display: none;
  position: fixed;
  z-index: 9999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.5);
}

.user-auth-modal.active {
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-auth-content {
  background: white;
  border-radius: 12px;
  width: 90%;
  max-width: 420px;
  position: relative;
  box-shadow: 0 10px 40px rgba(0,0,0,0.2);
}

.user-auth-close {
  position: absolute;
  right: 16px;
  top: 16px;
  font-size: 28px;
  font-weight: 300;
  color: #999;
  background: none;
  border: none;
  cursor: pointer;
  line-height: 1;
  padding: 0;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}

.user-auth-close:hover {
  background: #f5f5f5;
  color: #333;
}

.user-profile-header {
  text-align: center;
  padding-bottom: 20px;
  border-bottom: 1px solid #eee;
}

.user-avatar {
  font-size: 64px;
  color: #333;
  margin-bottom: 12px;
}

.user-profile-header h4 {
  margin: 0 0 4px;
  font-size: 20px;
  font-weight: 600;
}

.user-menu {
  margin-top: 16px;
}

.user-menu-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border: none;
  background: white;
  width: 100%;
  text-align: left;
  font-size: 15px;
  color: #333;
  text-decoration: none;
  border-radius: 8px;
  transition: background 0.2s;
  cursor: pointer;
  margin-bottom: 8px;
}

.user-menu-item:hover {
  background: #f8f8f8;
  text-decoration: none;
  color: #333;
}

.user-menu-item i {
  margin-right: 12px;
  width: 20px;
  font-size: 16px;
}

.logout-btn {
  color: #dc3545;
  margin-top: 8px;
}

.logout-btn:hover {
  background: #fff5f5;
  color: #dc3545;
}
</style>

<script>
let currentUser = null;
let otpCallback = null;
let pendingPhone = '';
let pendingName = '';
let otpOrderId = '';

function loadUser() {
  const stored = localStorage.getItem('user');
  if (stored) {
    try {
      currentUser = JSON.parse(stored);
      updateUserIcon();
    } catch(e) {
      localStorage.removeItem('user');
    }
  }
}

function updateUserIcon() {
  const icon = document.getElementById('userIcon');
  if (icon && currentUser) {
    icon.classList.add('logged-in');
    icon.title = currentUser.name;
  }
}

function openUserModal() {
  if (currentUser) {
    document.getElementById('userName').textContent = currentUser.name;
    document.getElementById('userPhone').textContent = currentUser.phone;
    document.getElementById('userAuthModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }
}

function closeUserModal() {
  document.getElementById('userAuthModal').classList.remove('active');
  document.body.style.overflow = '';
}

function closeOTPModal() {
  document.getElementById('otpVerifyModal').classList.remove('active');
  document.body.style.overflow = '';
}

function logout() {
  currentUser = null;
  localStorage.removeItem('user');
  const icon = document.getElementById('userIcon');
  if (icon) {
    icon.classList.remove('logged-in');
    icon.title = 'My Account';
  }
  closeUserModal();
}

async function verifyMobileWithOTP(phone, name, callback) {
  otpCallback = callback;
  pendingPhone = '+977' + phone;
  pendingName = name;
  
  document.getElementById('verifyPhone').textContent = pendingPhone;
  document.getElementById('otpInput').value = '';
  document.getElementById('otpVerifyModal').classList.add('active');
  document.body.style.overflow = 'hidden';
  
  // Send OTP via server
  try {
    const response = await fetch('/api/send-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone: pendingPhone })
    });
    const data = await response.json();
    console.log('OTP sent:', data);
    if (data.orderId) {
      otpOrderId = data.orderId;
    } else {
      alert('Failed to send OTP: ' + (data.message || data.errorMessage || 'Unknown error'));
    }
  } catch(e) {
    console.error('Failed to send OTP:', e);
    alert('Failed to send OTP. Please try again.');
  }
}

async function verifyOTP() {
  const otp = document.getElementById('otpInput').value;
  
  if (!otp || otp.length !== 6) {
    alert('Please enter 6-digit OTP');
    return;
  }
  
  try {
    const response = await fetch('/api/verify-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone: pendingPhone, otp: otp, orderId: otpOrderId })
    });
    const data = await response.json();
    
    if (data.isOTPVerified) {
      currentUser = {
        phone: pendingPhone,
        name: pendingName,
        verified: true
      };
      localStorage.setItem('user', JSON.stringify(currentUser));
      updateUserIcon();
      closeOTPModal();
      if (otpCallback) otpCallback(true);
    } else {
      alert('Invalid OTP. Please try again.');
    }
  } catch(e) {
    console.error('Failed to verify OTP:', e);
    alert('Failed to verify OTP. Please try again.');
  }
}

async function resendOTP() {
  await verifyMobileWithOTP(pendingPhone.replace('+977', ''), pendingName, otpCallback);
  alert('OTP resent to ' + pendingPhone);
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', loadUser);
} else {
  loadUser();
}

window.verifyMobileWithOTP = verifyMobileWithOTP;
window.currentUser = currentUser;
</script>
