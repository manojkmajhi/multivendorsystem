<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Hero Images - Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/staticfiles/admin-style.css?v=3.0" />
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="admin-navbar">
    <div class="admin-navbar-container">
      <a href="/admin/" class="admin-brand">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" />
        <% } %>
      </a>
      
      <!-- Desktop Navigation Links -->
      <div class="desktop-nav-links">
        <a href="/admin/" class="nav-link">
          <span class="nav-icon">📊</span>
          <span>Dashboard</span>
        </a>
        <a href="/admin/products" class="nav-link">
          <span class="nav-icon">📦</span>
          <span>Products</span>
        </a>
        <a href="/admin/categories" class="nav-link">
          <span class="nav-icon">📁</span>
          <span>Categories</span>
        </a>
        <a href="/admin/hero-images" class="nav-link active">
          <span class="nav-icon">🖼️</span>
          <span>Hero Images</span>
        </a>
        <a href="/admin/settings" class="nav-link">
          <span class="nav-icon">⚙️</span>
          <span>Settings</span>
        </a>
        <form method="POST" action="/admin/logout" style="display: inline;">
          <button type="submit" class="nav-link nav-logout-btn">
            <span class="nav-icon">🚪</span>
            <span>Logout</span>
          </button>
        </form>
      </div>
      
      <!-- Mobile Hamburger Menu -->
      <button class="mobile-menu-toggle" onclick="toggleSidebar()" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Sidebar -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
    <div class="sidebar-content">
      <div class="sidebar-header">
        <% if(siteSetting && siteSetting.logo_url){ %>
          <img src="<%= siteSetting.logo_url %>" alt="Logo" class="sidebar-logo" />
        <% } %>
        <h3 class="sidebar-title"><%= (siteSetting && siteSetting.name) || 'Admin Panel' %></h3>
        <button class="sidebar-close" onclick="toggleSidebar()" aria-label="Close menu">&times;</button>
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/" class="sidebar-link">
          <span class="sidebar-icon">📊</span>
          <span>Dashboard</span>
        </a>
        <a href="/admin/products" class="sidebar-link">
          <span class="sidebar-icon">📦</span>
          <span>Products</span>
        </a>
        <a href="/admin/categories" class="sidebar-link">
          <span class="sidebar-icon">📁</span>
          <span>Categories</span>
        </a>
        <a href="/admin/hero-images" class="sidebar-link active">
          <span class="sidebar-icon">🖼️</span>
          <span>Hero Images</span>
        </a>
        <a href="/admin/settings" class="sidebar-link">
          <span class="sidebar-icon">⚙️</span>
          <span>Settings</span>
        </a>
      </nav>
      
      <div class="sidebar-footer">
        <form method="POST" action="/admin/logout">
          <button type="submit" class="sidebar-logout-btn">
            <span class="sidebar-icon">🚪</span>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="admin-container">
    <div class="page-header">
      <h1 class="page-title">Hero Images</h1>
    </div>

    <% if(msg){ %>
      <div class="alert alert-success"><%= msg %></div>
    <% } %>

    <div class="grid-form-table">
      <!-- Hero Images Table -->
      <div>
        <% if(items && items.length > 0) { %>
          <div class="table-container">
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th style="width:60px;">Pos</th>
                    <th style="width:100px;">Preview</th>
                    <th>Title</th>
                    <th>Link</th>
                    <th style="width:90px;">Status</th>
                    <th style="width:220px;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% items.forEach(img => { %>
                    <tr>
                      <td><strong><%= img.position %></strong></td>
                      <td>
                        <img class="img-thumbnail" src="<%= img.image_url %>" alt="<%= img.title || 'Hero image' %>">
                      </td>
                      <td><strong><%= img.title || '-' %></strong></td>
                      <td style="font-size:12px;word-break:break-all;max-width:150px;">
                        <%= img.link_url || '-' %>
                      </td>
                      <td>
                        <span class="badge <%= img.active? 'badge-success':'badge-secondary' %>">
                          <%= img.active? 'Active':'Inactive' %>
                        </span>
                      </td>
                      <td>
                        <div class="table-actions">
                          <button class="btn btn-sm btn-outline-primary" 
                                  data-hero='<%- JSON.stringify(img) %>'
                                  onclick="editHero(JSON.parse(this.dataset.hero))">
                            Edit
                          </button>
                          <form method="POST" action="/admin/hero-images/<%= img.id %>/toggle-active" style="display:inline;">
                            <button class="btn btn-sm btn-outline-warning">Toggle</button>
                          </form>
                          <form method="POST" action="/admin/hero-images/<%= img.id %>/delete" onsubmit="return confirm('Delete this hero image?');" style="display:inline;">
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        <% } else { %>
          <div class="card">
            <div class="card-body">
              <div class="empty-state">
                <div class="empty-state-icon">🖼️</div>
                <h3 class="empty-state-title">No Hero Images Yet</h3>
                <p class="empty-state-text">Add hero images to showcase on your homepage.</p>
              </div>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Add Hero Image Form -->
      <div>
        <div class="card">
          <div class="card-header">
            <h2 class="card-title" id="heroFormTitle">Add Hero Image</h2>
          </div>
          <div class="card-body">
            <form method="POST" action="/admin/hero-images/new" id="heroForm" enctype="multipart/form-data">
              <input type="hidden" name="heroId" id="heroId" value="" />
              
              <div class="form-group">
                <label class="form-label">Title *</label>
                <input class="form-control" name="title" id="heroTitle" required placeholder="e.g., One Piece Collection" />
              </div>
              
              <div class="form-group">
                <label class="form-label">Hero Image</label>
                <div style="margin-bottom: 1rem;">
                  <input type="file" name="imageFile" id="heroImageFile" class="form-control" accept="image/*" onchange="previewHeroImage(event)" />
                  <small class="form-text">Upload a banner image (recommended: 1920x800px, max 5MB)</small>
                </div>
                <div style="margin-top: 1rem;">
                  <label style="display: block; margin-bottom: 0.5rem; color: var(--gray-700);">Or enter image URL:</label>
                  <input class="form-control" name="image_url" id="heroImageUrl" placeholder="/staticfiles/hero-banner.jpg or https://..." />
                  <small class="form-text">If you upload a file, it will override the URL</small>
                </div>
              </div>
              
              <div class="form-group" id="heroImagePreview" style="display: none;">
                <label class="form-label">Image Preview</label>
                <div style="padding: 1rem; background: var(--gray-100); border-radius: var(--border-radius-sm); display: inline-block;">
                  <img id="heroPreviewImg" style="max-height: 200px; max-width: 100%; object-fit: contain;" alt="Preview">
                </div>
              </div>
              
              <div class="form-group">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="description" id="heroDescription" placeholder="Short supporting text" rows="3"></textarea>
              </div>
              
              <div class="form-group">
                <label class="form-label">Link URL</label>
                <input class="form-control" name="link_url" id="heroLinkUrl" placeholder="/shop/All/" />
                <small class="form-text">Where should this banner link to?</small>
              </div>
              
              <div class="form-group">
                <label class="form-label">CTA Label</label>
                <input class="form-control" name="cta_label" id="heroCtaLabel" placeholder="Shop now" />
                <small class="form-text">Button text (optional)</small>
              </div>
              
              <div class="form-group">
                <label class="form-label">Position</label>
                <input type="number" class="form-control" name="position" id="heroPosition" value="0" />
                <small class="form-text">Display order (lower numbers appear first)</small>
              </div>
              
              <div style="display: flex; gap: 0.5rem;">
                <button type="submit" class="btn btn-primary" id="heroSubmitBtn">Add Hero Image</button>
                <button type="button" class="btn btn-outline-secondary" id="heroCancelBtn" onclick="resetHeroForm()" style="display: none;">Cancel</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="admin-footer">
    &copy; <%= new Date().getFullYear() %> <%= (siteSetting && siteSetting.name) || 'Admin' %>. All rights reserved.
  </footer>

  <script src="/staticfiles/admin-enhancements.js?v=3.0"></script>
  <script>
    function previewHeroImage(event) {
      const file = event.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          document.getElementById('heroPreviewImg').src = e.target.result;
          document.getElementById('heroImagePreview').style.display = 'block';
        };
        reader.readAsDataURL(file);
      } else {
        document.getElementById('heroImagePreview').style.display = 'none';
      }
    }
    
    function editHero(img) {
      document.getElementById('heroFormTitle').textContent = 'Edit Hero Image';
      document.getElementById('heroForm').action = '/admin/hero-images/' + img.id + '/edit';
      document.getElementById('heroId').value = img.id;
      document.getElementById('heroTitle').value = img.title || '';
      document.getElementById('heroImageUrl').value = img.image_url || '';
      document.getElementById('heroDescription').value = img.description || '';
      document.getElementById('heroLinkUrl').value = img.link_url || '';
      document.getElementById('heroCtaLabel').value = img.cta_label || '';
      document.getElementById('heroPosition').value = img.position || 0;
      document.getElementById('heroSubmitBtn').textContent = 'Update Hero Image';
      document.getElementById('heroCancelBtn').style.display = 'inline-block';
      
      if (img.image_url) {
        document.getElementById('heroPreviewImg').src = img.image_url;
        document.getElementById('heroImagePreview').style.display = 'block';
      }
      
      // Scroll to form
      document.getElementById('heroForm').scrollIntoView({ behavior: 'smooth' });
    }
    
    function resetHeroForm() {
      document.getElementById('heroFormTitle').textContent = 'Add Hero Image';
      document.getElementById('heroForm').action = '/admin/hero-images/new';
      document.getElementById('heroForm').reset();
      document.getElementById('heroId').value = '';
      document.getElementById('heroSubmitBtn').textContent = 'Add Hero Image';
      document.getElementById('heroCancelBtn').style.display = 'none';
      document.getElementById('heroImagePreview').style.display = 'none';
    }
  </script>
</body>
</html>