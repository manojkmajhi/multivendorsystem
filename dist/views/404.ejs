<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title><%= (siteSetting && siteSetting.name) ? siteSetting.name : 'All Strawhats' %> · Page not found</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css">
    <link rel="stylesheet" href="/staticfiles/style.blue.css">
    <style>
      :root{--accent:#0a58ca;}
      body{background:linear-gradient(180deg,#fff 0%,#f7f9fb 100%);min-height:100vh;display:flex;flex-direction:column;font-family: inherit}
      .site-nav{background:transparent;border-bottom:0}
      main{flex:1;display:flex;align-items:center;justify-content:center;padding:40px 16px}
      .card-404{max-width:960px;width:100%;display:flex;align-items:center;gap:24px;padding:28px;border-radius:12px;box-shadow:0 10px 30px rgba(10,10,10,.06);background:#fff}
      .left{flex:1;min-width:220px}
      .right{flex:1;min-width:220px}
      .big-num{font-weight:800;font-size:86px;line-height:0.9;color:var(--accent);letter-spacing:-3px}
      .headline{font-size:22px;font-weight:700;margin-bottom:8px}
      .muted{color:#6c757d}
      .home-btn{background:var(--accent);border:none;color:#fff;padding:.6rem 1.1rem;border-radius:8px}

      /* small mascot / illustration animation */
      .mascot-wrap{display:flex;align-items:center;justify-content:center}
      .mascot{width:240px;height:240px;border-radius:12px;display:flex;align-items:center;justify-content:center;overflow:hidden;transform-origin:center;box-shadow:0 8px 24px rgba(10,10,10,.08);}
      .mascot img{width:100%;height:100%;object-fit:cover;display:block;transform:translateY(0)}
      @keyframes floaty{0%{transform:translateY(0)}50%{transform:translateY(-10px)}100%{transform:translateY(0)}}
      .mascot{animation:floaty 4s ease-in-out infinite}

      @media (max-width:768px){.card-404{flex-direction:column;text-align:center}.mascot{width:200px;height:200px}.big-num{font-size:64px}}
      @media (prefers-reduced-motion:reduce){.mascot, .mascot img{animation:none;transition:none}}
    </style>
  </head>
  <body>
    <nav class="navbar navbar-light fixed-top site-nav py-2">
      <div class="container px-2 px-lg-3">
        <a class="navbar-brand d-flex align-items-center" href="/">
          <img src="<%= (siteSetting && siteSetting.logo_url) || '/staticfiles/brand.svg' %>" height="48" alt="logo">
          <span class="ml-2 font-weight-bold small text-muted" style="letter-spacing:.4px"><%= (siteSetting && siteSetting.name) || 'All Strawhats' %></span>
        </a>
      </div>
    </nav>

    <div style="height:72px"></div>

    <main class="container text-center">
      <div style="max-width:760px;margin:0 auto;padding:40px 18px;">
        <div>
          <!-- Clean, single GIF animation as requested -->
          <img src="https://www.dochipo.com/wp-content/uploads/2024/01/404-Error-Animation-4.gif" alt="404 animation" style="max-width:100%;height:auto;border-radius:12px;box-shadow:0 12px 30px rgba(10,10,10,.08)" />
        </div>
        <div style="margin-top:20px;">
          <a class="btn btn-primary btn-lg" href="/shop/all">Visit Shop</a>
        </div>
      </div>
    </main>

    <footer class="text-center text-muted py-4">
      <small>&copy; <%= new Date().getFullYear() %> <%= (siteSetting && siteSetting.name) || 'All Strawhats' %></small>
    </footer>

    <script>
      // Gentle entrance animation without changing layout
      document.documentElement.classList.add('loaded-404');
    </script>
  </body>
  </html>
