# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Admin Authentication
ADMIN_TOKEN=change_this_to_secure_password

# Server Configuration
PORT=3000
NODE_ENV=production

# Google Maps API (for checkout location picker)
# Get your free API key: https://console.cloud.google.com/
# See GOOGLE_MAPS_SETUP.md for detailed setup guide
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Configuration (Cropsa domain with Supabase auth)
SMTP_HOST=smtp.cropsa.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@cropsa.com
SMTP_PASS=your-cropsa-email-password
SMTP_FROM_EMAIL=noreply@cropsa.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+your_twilio_number_here

# EmailJS Configuration
EMAILJS_SERVICE_ID=service_hbht5b5
EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
EMAILJS_PRIVATE_KEY=your_emailjs_private_key_here
